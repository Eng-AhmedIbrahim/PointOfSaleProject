@using POS.Contract.Dtos.ItemDto
@using BlazorBase.Services
@using BlazorBase.ERPFrontServices.ItemServices
@inject IItemService ItemService
@inject ISnackbar Snackbar

<MudDialog Class="custom-dialog">
    <DialogContent>
        <RadzenTemplateForm TItem="ClassificationFormModel" Data="@model" Submit="@Submit" InvalidSubmit="@OnInvalidSubmit">
            <div class="p-4" dir="@(IsArabic ? "rtl" : "ltr")">
                <div class="row gy-4">
                    <!-- ID Section -->
                    <div class="col-12">
                        <RadzenLabel Text="@(IsArabic ? "رقم القسم (كود)" : "Classification ID")" Component="Id" Style="margin-bottom: 0.8rem; font-weight: 700; font-size: 1rem; color: #1e293b;" />
                        <div class="id-premium-card d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <span class="id-icon-wrapper me-3">
                                    <RadzenIcon Icon="fingerprint" Style="font-size: 1.5rem; color: white;" />
                                </span>
                                <div class="d-flex flex-column">
                                    <RadzenNumeric Name="Id" @bind-Value="model.Id" ReadOnly="true" TValue="int" ShowUpDown="false"
                                                   Style="width: 100px; border: none; background: transparent; font-weight: 800; color: #1e293b; font-size: 1.8rem; padding: 0; height: auto; line-height: 1;" />
                                    <small class="text-muted" style="font-size: 0.75rem; margin-top: 2px;">@(IsArabic ? "هذا الرقم فريد ولا يمكن تعديله" : "Unique identifier (read-only)")</small>
                                </div>
                            </div>
                            <div class="auto-badge">
                                <RadzenIcon Icon="auto_awesome" Style="font-size: 1rem; margin-inline-end: 4px;" />
                                @(IsArabic ? "تلقائي" : "Auto")
                            </div>
                        </div>
                    </div>

                    <!-- Arabic Name Section -->
                    <div class="col-12 mt-4">
                        <RadzenLabel Text="@(IsArabic ? "الاسم بالعربي" : "Arabic Name")" Component="ArabicName" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenTextBox Name="ArabicName" @bind-Value="model.ArabicName" Style="width: 100%; border-radius: 10px; padding: 12px; border: 2px solid #e2e8f0;" Placeholder="@(IsArabic ? "أدخل الاسم بالعربية..." : "Enter Arabic name...")" AutoComplete="false" />
                        <RadzenRequiredValidator Component="ArabicName" Text="@(IsArabic ? "الاسم العربي مطلوب" : "Arabic name is required")" Popup="false" Style="position: absolute; font-size: 0.85rem; color: #ef4444;" />
                    </div>

                    <!-- English Name Section -->
                    <div class="col-12">
                        <RadzenLabel Text="@(IsArabic ? "الاسم بالإنجليزي" : "English Name")" Component="Name" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenTextBox Name="Name" @bind-Value="model.Name" Style="width: 100%; border-radius: 10px; padding: 12px; border: 2px solid #e2e8f0;" Placeholder="@(IsArabic ? "أدخل الاسم بالإنجليزية..." : "Enter English name...")" AutoComplete="false" />
                        <RadzenRequiredValidator Component="Name" Text="@(IsArabic ? "الاسم الانجليزي مطلوب" : "English name is required")" Popup="false" Style="position: absolute; font-size: 0.85rem; color: #ef4444;" />
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end px-4 pb-4 gap-3 mt-4 border-top pt-4">
                <RadzenButton Click="@Cancel" Text="@(IsArabic ? "إلغاء" : "Cancel")" ButtonStyle="Radzen.ButtonStyle.Light" Style="border-radius: 10px; padding: 0 25px; height: 48px; font-weight: 600;" />
                <RadzenButton ButtonType="Radzen.ButtonType.Submit" 
                               ButtonStyle="Radzen.ButtonStyle.Primary" 
                               Disabled="@_isSaving"
                               Style="border-radius: 10px; font-weight: 700; background: linear-gradient(135deg, #2563eb, #3b82f6); border: none; min-width: 140px; height: 48px; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);">
                    @if (_isSaving)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Color="MudBlazor.Color.Inherit" />
                            <span>@(IsArabic ? "جاري..." : "Saving...")</span>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <RadzenIcon Icon="save" />
                            <span>@(IsArabic ? "حفظ" : "Save")</span>
                        </div>
                    }
                </RadzenButton>
            </div>
        </RadzenTemplateForm>
    </DialogContent>
</MudDialog>

<style>
    .custom-dialog .mud-dialog-title { display: none; }
    .custom-dialog .mud-dialog-content { padding: 0 !important; overflow: visible !important; }
    
    .id-premium-card {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px 24px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .id-icon-wrapper {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.2);
    }

    .auto-badge {
        background: #eff6ff;
        color: #2563eb;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 800;
        display: flex;
        align-items: center;
    }

    .rz-textbox, .rz-numeric-input {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem !important;
    }

    .rz-textbox:focus, .rz-numeric-input:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        background: #fff !important;
    }

    /* Remove arrows from numeric */
    .id-premium-card input::-webkit-outer-spin-button,
    .id-premium-card input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .id-premium-card input[type=number] {
        -moz-appearance: textfield;
    }

    .rz-label {
        letter-spacing: -0.01em;
    }
</style>

@using MudBlazor
@using Radzen
@using Radzen.Blazor

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public bool IsArabic { get; set; }
    [Parameter] public ItemsClassificationsDto? ClassificationToEdit { get; set; }
    [Parameter] public List<ItemsClassificationsDto> ExistingClassifications { get; set; } = new();

    private bool _isSaving = false;
    private ClassificationFormModel model = new();

    public class ClassificationFormModel
    {
        public int Id { get; set; }
        public string ArabicName { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        if (ClassificationToEdit != null)
        {
            model.Id = ClassificationToEdit.Id;
            model.ArabicName = ClassificationToEdit.ArabicName ?? string.Empty;
            model.Name = ClassificationToEdit.Name ?? string.Empty;
        }
        else
        {
            // Auto-calculate next ID
            model.Id = ExistingClassifications.Any() ? ExistingClassifications.Max(x => x.Id) + 1 : 1;
        }
    }

    private void OnInvalidSubmit(FormInvalidSubmitEventArgs args)
    {
        Snackbar.Add(IsArabic ? "يرجى التحقق من المدخلات" : "Please check the input", Severity.Warning);
    }

    private async Task Submit()
    {
        _isSaving = true;

        try
        {
            if (ClassificationToEdit == null)
            {
                var newClassification = new ItemsClassificationsDto
                {
                    Id = model.Id,
                    ArabicName = model.ArabicName,
                    Name = model.Name
                };

                var response = await ItemService.CreateClassificationAsync(newClassification);
                if (response != null && response.Success)
                {
                    Snackbar.Add(IsArabic ? "تم الإضافة بنجاح" : "Added successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(response.Data));
                }
                else
                {
                    Snackbar.Add(response?.Message ?? "Error saving classification", Severity.Error);
                }
            }
            else
            {
                var updatedClassification = new ItemsClassificationsDto
                {
                    Id = model.Id,
                    ArabicName = model.ArabicName,
                    Name = model.Name
                };

                var response = await ItemService.UpdateClassificationAsync(updatedClassification);
                if (response != null && response.Success)
                {
                    Snackbar.Add(IsArabic ? "تم التعديل بنجاح" : "Updated successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(response.Data));
                }
                else
                {
                    Snackbar.Add(response?.Message ?? "Error updating classification", Severity.Error);
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add(IsArabic ? "حدث خطأ أثناء الحفظ" : "An error occurred while saving", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
