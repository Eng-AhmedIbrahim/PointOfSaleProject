@using POS.Contract.Dtos.PaymentDtos
@using BlazorBase.Services
@using BlazorBase.ERPFrontServices.PaymentMethodServices
@inject IPaymentMethodServices PaymentMethodServices
@inject ISnackbar Snackbar

<MudDialog Class="premium-dialog">
    <DialogContent>
        <div class="p-4" dir="@(IsArabic ? "rtl" : "ltr")">
            <RadzenTemplateForm TItem="PaymentMethodDto" Data="@MethodModel" Submit="@HandleSubmit">
                <div class="row gy-4">
                    <!-- Method ID header visual -->
                    <div class="col-12 mb-2">
                        <div class="id-visual-card d-flex align-items-center">
                            <div class="id-label">@(IsArabic ? "كود الوسيلة" : "Payment ID")</div>
                            <div class="id-value">@(IsEditMode ? MethodToEdit.Id.ToString() : "NEW")</div>
                        </div>
                    </div>

                    <!-- Arabic Name -->
                    <div class="col-12">
                        <RadzenLabel Text="@(IsArabic ? "الاسم العربي" : "Arabic Name")" Style="display: block; margin-bottom: 8px; font-weight: 700; color: #475569;" />
                        <RadzenTextBox @bind-Value="MethodModel.NameAr" Name="NameAr" Style="width: 100%; height: 48px; border-radius: 12px; border: 2px solid #e2e8f0; font-weight: 600; padding: 0 15px;" />
                        <RadzenRequiredValidator Component="NameAr" Text="@(IsArabic ? "الاسم العربي مطلوب" : "Arabic name is required")" Popup="true" />
                    </div>

                    <!-- English Name -->
                    <div class="col-12">
                        <RadzenLabel Text="@(IsArabic ? "الاسم الإنجليزي" : "English Name")" Style="display: block; margin-bottom: 8px; font-weight: 700; color: #475569;" />
                        <RadzenTextBox @bind-Value="MethodModel.NameEn" Name="NameEn" Style="width: 100%; height: 48px; border-radius: 12px; border: 2px solid #e2e8f0; font-weight: 600; padding: 0 15px;" />
                        <RadzenRequiredValidator Component="NameEn" Text="@(IsArabic ? "الاسم الإنجليزي مطلوب" : "English name is required")" Popup="true" />
                    </div>

                    <!-- Is Active -->
                    <div class="col-12">
                        <div class="d-flex align-items-center gap-3">
                            <RadzenLabel Text="@(IsArabic ? "نشط" : "Is Active")" Style="font-weight: 700; color: #475569;" />
                            <RadzenCheckBox @bind-Value="MethodModel.IsActive" TValue="bool" />
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5">
                    <RadzenButton Click="@Cancel" Text="@(IsArabic ? "إلغاء" : "Cancel")" ButtonStyle="Radzen.ButtonStyle.Light" Style="border-radius: 12px; padding: 0 25px; height: 48px; font-weight: 600;" />
                    <RadzenButton ButtonType="Radzen.ButtonType.Submit" 
                                   ButtonStyle="Radzen.ButtonStyle.Primary" 
                                   Disabled="@_isSaving"
                                   Style="border-radius: 12px; font-weight: 800; background: linear-gradient(135deg, #1e90ff, #0070e0); border: none; min-width: 140px; height: 48px;">
                        @if (_isSaving)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Color="MudBlazor.Color.Inherit" />
                                <span>@(IsArabic ? "جاري..." : "Saving...")</span>
                            </div>
                        }
                        else
                        {
                            <span>@(IsArabic ? "حفظ البيانات" : "Save Method")</span>
                        }
                    </RadzenButton>
                </div>
            </RadzenTemplateForm>
        </div>
    </DialogContent>
</MudDialog>

<style>
    .premium-dialog .mud-dialog-title { display: none; }
    .premium-dialog .mud-dialog-content { padding: 0 !important; }

    .id-visual-card {
        background: #f0f9ff;
        border: 2px dashed #bae6fd;
        border-radius: 12px;
        padding: 12px 20px;
        gap: 15px;
    }

    .id-label {
        font-weight: 800;
        color: #0369a1;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .id-value {
        font-family: 'Monaco', 'Consolas', monospace;
        font-weight: 900;
        font-size: 1.2rem;
        color: #0284c7;
        letter-spacing: 2px;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public bool IsArabic { get; set; }
    [Parameter] public PaymentMethodToReturnDto? MethodToEdit { get; set; }

    private PaymentMethodDto MethodModel = new();
    private bool IsEditMode => MethodToEdit != null;
    private bool _isSaving = false;

    protected override void OnInitialized()
    {
        if (IsEditMode)
        {
            MethodModel = new PaymentMethodDto
            {
                NameAr = MethodToEdit!.NameAr,
                NameEn = MethodToEdit.NameEn,
                IsActive = MethodToEdit.IsActive
            };
        }
        else
        {
            MethodModel.IsActive = true;
        }
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        try
        {
            if (IsEditMode)
            {
                var response = await PaymentMethodServices.UpdatePaymentMethod(MethodToEdit!.Id, MethodModel);
                if (response.Success)
                {
                    Snackbar.Add(IsArabic ? "تم التعديل بنجاح" : "Updated successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    Snackbar.Add(response.Message ?? (IsArabic ? "فشل التعديل" : "Failed to update"), Severity.Error);
                }
            }
            else
            {
                var response = await PaymentMethodServices.CreatePaymentMethod(MethodModel);
                if (response.Success)
                {
                    Snackbar.Add(IsArabic ? "تمت الإضافة بنجاح" : "Added successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    Snackbar.Add(response.Message ?? (IsArabic ? "فشل الإضافة" : "Failed to add"), Severity.Error);
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add(IsArabic ? "حدث خطأ غير متوقع" : "Unexpected error", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
