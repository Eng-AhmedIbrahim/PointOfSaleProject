@using POS.Contract.Dtos.DeliveryDtos.DeliveryZoneDtos
@using BlazorBase.Services
@using BlazorBase.ERPFrontServices.DeliveryServices
@using BlazorBase.ERPFrontServices.BranchServices
@using POS.Contract.Dtos.CompanyDtos
@inject IDeliveryServices DeliveryService
@inject IBranchService BranchService
@inject ISnackbar Snackbar

<MudDialog Class="custom-dialog">
    <DialogContent>
        <RadzenTemplateForm TItem="ZoneFormModel" Data="@model" Submit="@Submit" InvalidSubmit="@OnInvalidSubmit">
            <div class="p-4" dir="@(IsArabic ? "rtl" : "ltr")">
                <div class="row gy-4">
                    <!-- Zone ID Section -->
                    <div class="col-12">
                        <RadzenLabel Text="@(IsArabic ? "رقم المنطقة (كود)" : "Zone ID")" Component="Id" Style="margin-bottom: 0.8rem; font-weight: 700; font-size: 1rem; color: #1e293b;" />
                        <div class="id-premium-card d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <span class="id-icon-wrapper me-3">
                                    <RadzenIcon Icon="layers" Style="font-size: 1.5rem; color: white;" />
                                </span>
                                <div class="d-flex flex-column">
                                    <RadzenNumeric Name="Id" @bind-Value="model.Id" ReadOnly="true" TValue="int" ShowUpDown="false"
                                                   Style="width: 100px; border: none; background: transparent; font-weight: 800; color: #1e293b; font-size: 1.8rem; padding: 0; height: auto; line-height: 1;" />
                                    <small class="text-muted" style="font-size: 0.75rem; margin-top: 2px;">@(IsArabic ? "رقم فريد للمنطقة" : "Unique identifier for the zone")</small>
                                </div>
                            </div>
                            <div class="auto-badge">
                                <RadzenIcon Icon="auto_awesome" Style="font-size: 1rem; margin-inline-end: 4px;" />
                                @(IsArabic ? "تلقائي" : "Auto")
                            </div>
                        </div>
                    </div>

                    <!-- Zone Name Section -->
                    <div class="col-12 mt-4">
                        <RadzenLabel Text="@(IsArabic ? "اسم المنطقة" : "Zone Name")" Component="ZoneName" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenTextBox Name="ZoneName" @bind-Value="model.ZoneName" Style="width: 100%; border-radius: 10px; padding: 12px; border: 2px solid #e2e8f0;" Placeholder="@(IsArabic ? "أدخل اسم المنطقة..." : "Enter zone name...")" AutoComplete="false" />
                        <RadzenRequiredValidator Component="ZoneName" Text="@(IsArabic ? "اسم المنطقة مطلوب" : "Zone name is required")" Popup="false" Style="position: absolute; font-size: 0.85rem; color: #ef4444;" />
                    </div>

                    <!-- Delivery Fee and Bonus Section -->
                    <div class="col-md-6 mt-4">
                        <RadzenLabel Text="@(IsArabic ? "رسوم التوصيل" : "Delivery Fee")" Component="DeliveryFee" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenNumeric Name="DeliveryFee" @bind-Value="model.DeliveryFee" TValue="decimal?" Style="width: 100%; border-radius: 10px; padding: 8px; border: 2px solid #e2e8f0;" Placeholder="0.00" />
                    </div>

                    <div class="col-md-6 mt-4">
                        <RadzenLabel Text="@(IsArabic ? "بونص المنطقة" : "Zone Bonus")" Component="ZoneBonus" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenNumeric Name="ZoneBonus" @bind-Value="model.ZoneBonus" TValue="decimal?" Style="width: 100%; border-radius: 10px; padding: 8px; border: 2px solid #e2e8f0;" Placeholder="0.00" />
                    </div>

                    <div class="col-12 mt-4">
                        <RadzenLabel Text="@(IsArabic ? "الفرع" : "Branch")" Component="BranchId" Style="margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #475569;" />
                        <RadzenDropDown @bind-Value="model.BranchId" Data="@Branches" TextProperty="Name" ValueProperty="Id" Name="BranchId"
                                        Style="width: 100%; border-radius: 10px; padding: 4px; border: 2px solid #e2e8f0;" Placeholder="@(IsArabic ? "اختر الفرع..." : "Select branch...")" />
                        <RadzenRequiredValidator Component="BranchId" Text="@(IsArabic ? "الفرع مطلوب" : "Branch is required")" DefaultValue="0" Popup="false" Style="position: absolute; font-size: 0.85rem; color: #ef4444;" />
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end px-4 pb-4 gap-3 mt-4 border-top pt-4">
                <RadzenButton Click="@Cancel" Text="@(IsArabic ? "إلغاء" : "Cancel")" ButtonStyle="Radzen.ButtonStyle.Light" Style="border-radius: 10px; padding: 0 25px; height: 48px; font-weight: 600;" />
                <RadzenButton ButtonType="Radzen.ButtonType.Submit" 
                               ButtonStyle="Radzen.ButtonStyle.Primary" 
                               Disabled="@_isSaving"
                               Style="border-radius: 10px; font-weight: 700; background: linear-gradient(135deg, #2563eb, #3b82f6); border: none; min-width: 140px; height: 48px; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);">
                    @if (_isSaving)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Color="MudBlazor.Color.Inherit" />
                            <span>@(IsArabic ? "جاري..." : "Saving...")</span>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <RadzenIcon Icon="save" />
                            <span>@(IsArabic ? "حفظ" : "Save")</span>
                        </div>
                    }
                </RadzenButton>
            </div>
        </RadzenTemplateForm>
    </DialogContent>
</MudDialog>

<style>
    .custom-dialog .mud-dialog-title { display: none; }
    .custom-dialog .mud-dialog-content { padding: 0 !important; overflow: visible !important; }
    
    .id-premium-card {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px 24px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .id-icon-wrapper {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.2);
    }

    .auto-badge {
        background: #eff6ff;
        color: #2563eb;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 800;
        display: flex;
        align-items: center;
    }

    .rz-textbox, .rz-numeric-input, .rz-dropdown {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem !important;
    }

    .rz-textbox:focus, .rz-numeric-input:focus, .rz-dropdown:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        background: #fff !important;
    }

    /* Remove arrows from numeric */
    .id-premium-card input::-webkit-outer-spin-button,
    .id-premium-card input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .id-premium-card input[type=number] {
        -moz-appearance: textfield;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public bool IsArabic { get; set; }
    [Parameter] public DeliveryZonesToReturnDto? ZoneToEdit { get; set; }
    [Parameter] public List<DeliveryZonesToReturnDto> ExistingZones { get; set; } = new();

    private bool _isSaving = false;
    private ZoneFormModel model = new();
    private List<BranchToReturnDto> Branches = new();

    public class ZoneFormModel
    {
        public int Id { get; set; }
        public string ZoneName { get; set; } = string.Empty;
        public decimal? DeliveryFee { get; set; }
        public decimal? ZoneBonus { get; set; }
        public int BranchId { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();

        if (ZoneToEdit != null)
        {
            model.Id = ZoneToEdit.Id;
            model.ZoneName = ZoneToEdit.ZoneName ?? string.Empty;
            model.DeliveryFee = ZoneToEdit.DeliveryFee;
            model.ZoneBonus = ZoneToEdit.ZoneBonus;
            model.BranchId = ZoneToEdit.BranchId;
        }
        else
        {
            model.Id = ExistingZones.Any() ? ExistingZones.Max(x => x.Id) + 1 : 1;
            if (Branches.Count == 1)
            {
                model.BranchId = Branches[0].Id;
            }
        }
    }

    private async Task LoadBranches()
    {
        try
        {
            var result = await BranchService.GetBranches();
            Branches = result.ToList();
        }
        catch (Exception)
        {
            Snackbar.Add(IsArabic ? "فشل تحميل الفروع" : "Failed to load branches", Severity.Error);
        }
    }

    private void OnInvalidSubmit(FormInvalidSubmitEventArgs args)
    {
        Snackbar.Add(IsArabic ? "يرجى التحقق من المدخلات" : "Please check the input", Severity.Warning);
    }

    private async Task Submit()
    {
        _isSaving = true;

        try
        {
            if (ZoneToEdit == null)
            {
                var newZone = new DeliveryZoneDto
                {
                    ZoneName = model.ZoneName,
                    DeliveryFee = model.DeliveryFee,
                    ZoneBonus = model.ZoneBonus,
                    BranchId = model.BranchId
                };

                var response = await DeliveryService.CreateZone(newZone);
                if (response != null && response.Success)
                {
                    Snackbar.Add(IsArabic ? "تم الإضافة بنجاح" : "Added successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(response.Data));
                }
                else
                {
                    Snackbar.Add(response?.Message ?? "Error saving zone", Severity.Error);
                }
            }
            else
            {
                var updatedZone = new DeliveryZonesToReturnDto
                {
                    Id = model.Id,
                    ZoneName = model.ZoneName,
                    DeliveryFee = model.DeliveryFee,
                    ZoneBonus = model.ZoneBonus,
                    BranchId = model.BranchId
                };

                var response = await DeliveryService.UpdateZone(model.Id, updatedZone);
                if (response != null && response.Success)
                {
                    Snackbar.Add(IsArabic ? "تم التعديل بنجاح" : "Updated successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(response.Data));
                }
                else
                {
                    Snackbar.Add(response?.Message ?? "Error updating zone", Severity.Error);
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add(IsArabic ? "حدث خطأ أثناء الحفظ" : "An error occurred while saving", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
