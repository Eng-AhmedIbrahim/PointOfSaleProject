@page "/basicdata/inventory"
@using BackOffice.Desktop.Components.Pages.BasicData.Items
@using POS.Contract.Dtos.InventoryDtos
@using BlazorBase.ERPFrontServices.InventoryServices
@using Radzen
@using Radzen.Blazor
@inject IInventoryFrontService InventoryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LocalizationService Localizer
@inject NotificationService NotificationService
@inject Radzen.DialogService RadzenDialogService

<style>
    .inventory-page { font-family: 'Outfit', 'Noto Sans Arabic', sans-serif; background: #f0f2f5; min-height: 100vh; padding: 2rem; }
    .page-header { background: white; padding: 1.5rem 2rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); margin-bottom: 2rem; }
    .header-title { display: flex; align-items: center; gap: 1rem; }
    .header-icon { background: #6366f1; color: white; padding: 12px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3); }
    .header-text h1 { margin: 0; font-size: 1.75rem; font-weight: 800; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .header-text p { margin: 0; color: #64748b; font-size: 0.9rem; }
    
    .stats-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .stat-card { background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 1.25rem; transition: transform 0.2s; cursor: default; }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .stat-card .icon-box { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .stat-card.total .icon-box { background: #eff6ff; color: #3b82f6; }
    .stat-card.low .icon-box { background: #fffbeb; color: #f59e0b; }
    .stat-card.available .icon-box { background: #f0fdf4; color: #10b981; }
    .stat-card.out .icon-box { background: #fef2f2; color: #ef4444; }
    .stat-info .label { font-size: 0.85rem; color: #64748b; font-weight: 600; }
    .stat-info .value { font-size: 1.5rem; font-weight: 800; color: #1e293b; }

    .grid-card { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); overflow: hidden; }
    .grid-toolbar { padding: 1rem 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; background: #fafafa; }
    
    .rz-datagrid { border: none !important; }
    .rz-datagrid-header { background: #f8fafc !important; }
    .rz-column-title { color: #64748b !important; font-weight: 700 !important; font-size: 0.8rem !important; text-transform: uppercase !important; letter-spacing: 0.05em !important; }
    .rz-cell-data { padding: 12px 16px !important; }
    
    .item-cell { display: flex; align-items: center; gap: 1rem; }
    .item-avatar { width: 36px; height: 36px; border-radius: 10px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #6366f1; border: 1px solid #e2e8f0; }
    .item-names { line-height: 1.2; }
    .item-name-ar { font-weight: 700; color: #1e293b; display: block; }
    .item-name-en { font-size: 0.8rem; color: #64748b; display: block; }

    .action-btn { border-radius: 8px !important; text-transform: none !important; font-weight: 600 !important; }
    .badge-opening { background: #6366f1 !important; color: white !important; }
    .badge-init { background: #3b82f6 !important; color: white !important; }
    .badge-units { background: #ec4899 !important; color: white !important; }
</style>

<div class="inventory-page" dir="@(Localizer.GetCurrentLanguage() == "ar" ? "rtl" : "ltr")">
    <div class="page-header">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="header-title">
                    <div class="header-icon">
                        <RadzenIcon Icon="inventory_2" />
                    </div>
                    <div class="header-text">
                        <h1>@(Localizer.GetCurrentLanguage() == "ar" ? "إدارة المخزون" : "Inventory Management")</h1>
                        <p>@(Localizer.GetCurrentLanguage() == "ar" ? "تتبع الكميات والمواد الخام والوصفات" : "Track stock levels, raw materials and recipes")</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 d-flex justify-content-end gap-2">
                <RadzenButton Click="@(() => NavigationManager.NavigateTo("/basicdata/units"))" Icon="straighten" Text="@(Localizer.GetCurrentLanguage() == "ar" ? "الوحدات" : "Units")" ButtonStyle="ButtonStyle.Secondary" Class="action-btn badge-units" />
                <RadzenButton Click="@InitializeAll" Icon="autorenew" Text="@(Localizer.GetCurrentLanguage() == "ar" ? "تهيئة الكل" : "Initialize All")" ButtonStyle="ButtonStyle.Info" Class="action-btn badge-init" />
                <RadzenButton Click="@OpenOpeningStockDialog" Icon="add_circle" Text="@(Localizer.GetCurrentLanguage() == "ar" ? "رصيد أول المدة" : "Opening Stock")" ButtonStyle="ButtonStyle.Primary" Class="action-btn badge-opening" />
            </div>
        </div>
    </div>

    <div class="stats-container">
        <div class="stat-card total">
            <div class="icon-box"><RadzenIcon Icon="category" /></div>
            <div class="stat-info">
                 <div class="label">@(Localizer.GetCurrentLanguage() == "ar" ? "إجمالي الأصناف" : "Total Items")</div>
                 <div class="value">@InventoryItems.Count</div>
            </div>
        </div>
        <div class="stat-card low">
            <div class="icon-box"><RadzenIcon Icon="warning" /></div>
            <div class="stat-info">
                 <div class="label">@(Localizer.GetCurrentLanguage() == "ar" ? "نواقص" : "Low Stock")</div>
                 <div class="value">@LowStockCount</div>
            </div>
        </div>
        <div class="stat-card available">
            <div class="icon-box"><RadzenIcon Icon="check_circle" /></div>
            <div class="stat-info">
                 <div class="label">@(Localizer.GetCurrentLanguage() == "ar" ? "متوفر" : "Available")</div>
                 <div class="value">@InStockCount</div>
            </div>
        </div>
        <div class="stat-card out">
            <div class="icon-box"><RadzenIcon Icon="error" /></div>
            <div class="stat-info">
                 <div class="label">@(Localizer.GetCurrentLanguage() == "ar" ? "نفذ" : "Out of Stock")</div>
                 <div class="value">@OutOfStockCount</div>
            </div>
        </div>
    </div>

    <div class="grid-card">
        <div class="grid-toolbar">
            <RadzenText TextStyle="TextStyle.H6" Class="m-0 font-weight-bold">@(Localizer.GetCurrentLanguage() == "ar" ? "كشف الجرد" : "Inventory Audit")</RadzenText>
            <RadzenTextBox Placeholder="@(Localizer.GetCurrentLanguage() == "ar" ? "بحث عن صنف..." : "Search items...")" 
                             @bind-Value="SearchString" 
                             @oninput="@((args) => OnSearch(args.Value?.ToString()))"
                             Style="width: 300px; border-radius: 10px;" />
        </div>
        
        <RadzenDataGrid @ref="grid" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="10"
                        AllowSorting="true" Data="@FilteredInventory" TItem="InventoryItemDto" 
                        EmptyText="@(Localizer.GetCurrentLanguage() == "ar" ? "لا توجد بيانات" : "No results found")"
                        ColumnWidth="200px" SelectionMode="DataGridSelectionMode.Single"
                        Density="Density.Default">
            <Columns>
                <RadzenDataGridColumn TItem="InventoryItemDto" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الصنف" : "Item")" Width="250px" Filterable="false">
                    <Template Context="item">
                        <div class="item-cell">
                            <div class="item-avatar">@((string.IsNullOrEmpty(item.ItemNameEn) ? "?" : item.ItemNameEn[0].ToString()).ToUpper())</div>
                            <div class="item-names">
                                <span class="item-name-ar">@item.ItemNameAr</span>
                                <span class="item-name-en">@item.ItemNameEn</span>
                            </div>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                
                <RadzenDataGridColumn TItem="InventoryItemDto" Property="Unit" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الوحدة" : "Unit")" Width="150px">
                    <Template Context="item">
                        <RadzenDropDown TValue="int?" Value="@item.UnitId" Data="@AllUnits" TextProperty="@(Localizer.GetCurrentLanguage() == "ar" ? "ArabicName" : "EnglishName")" 
                                        ValueProperty="Id" Change="@((val) => UpdateItemUnit(item, (int?)val))" 
                                        Style="width: 100%;" Placeholder="---" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="InventoryItemDto" Property="CurrentQuantity" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الرصيد" : "Stock")" Width="120px" TextAlign="TextAlign.Center">
                    <Template Context="item">
                        <RadzenBadge Text="@item.CurrentQuantity.ToString("N2")" BadgeStyle="@GetStockBadgeStyle(item)" Style="font-size: 1rem; padding: 8px 12px; border-radius: 8px;" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="InventoryItemDto" Property="MinimumQuantity" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "حد الطلب" : "Min")" Width="100px" TextAlign="TextAlign.Center" />

                <RadzenDataGridColumn TItem="InventoryItemDto" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "إجراءات" : "Actions")" Width="130px" TextAlign="TextAlign.Right" Filterable="false" Sortable="false">
                    <Template Context="item">
                        <RadzenSplitButton Icon="more_vert" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                           Click="@((args) => HandleAction(item, args))">
                            <ChildContent>
                                <RadzenSplitButtonItem Text="@(Localizer.GetCurrentLanguage() == "ar" ? "تعديل رصيد" : "Stock Adjust")" Icon="tune" Value="adjust" />
                                <RadzenSplitButtonItem Text="@(Localizer.GetCurrentLanguage() == "ar" ? "جرد فعلي" : "Physical Count")" Icon="fact_check" Value="physical" />
                                <RadzenSplitButtonItem Text="@(Localizer.GetCurrentLanguage() == "ar" ? "رصيد أول المدة" : "Opening Stock")" Icon="play_circle" Value="opening" />
                                <RadzenSplitButtonItem Text="@(Localizer.GetCurrentLanguage() == "ar" ? "سجل الحركات" : "History")" Icon="history" Value="history" />
                                <RadzenSplitButtonItem Text="@(Localizer.GetCurrentLanguage() == "ar" ? "الريسيبي" : "Recipe")" Icon="restaurant_menu" Value="recipe" />
                            </ChildContent>
                        </RadzenSplitButton>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@code {
    private bool IsLoading = true;
    private List<InventoryItemDto> InventoryItems = new();
    private List<UnitDto> AllUnits = new();
    private string SearchString = "";
    private RadzenDataGrid<InventoryItemDto> grid = default!;

    [Inject] public IUnitFrontService UnitFrontService { get; set; } = default!;
    [Inject] public NavigationManager NavigationManager { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadUnits();
        await LoadData();
    }

    private async Task LoadUnits()
    {
        var response = await UnitFrontService.GetAllUnitsAsync();
        if (response.Success) AllUnits = response.Data.ToList();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            var response = await InventoryService.GetAllInventoryAsync();
            if (response.Success)
            {
                InventoryItems = response.Data?.ToList() ?? new();
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = response.Message });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
        finally
        {
            IsLoading = false;
        }
    }

    private IEnumerable<InventoryItemDto> FilteredInventory => string.IsNullOrWhiteSpace(SearchString) 
        ? InventoryItems 
        : InventoryItems.Where(i => (i.ItemNameAr?.Contains(SearchString, StringComparison.OrdinalIgnoreCase) ?? false) || 
                                     (i.ItemNameEn?.Contains(SearchString, StringComparison.OrdinalIgnoreCase) ?? false));

    private void OnSearch(string? value)
    {
        SearchString = value ?? "";
    }

    private BadgeStyle GetStockBadgeStyle(InventoryItemDto item)
    {
        if (item.CurrentQuantity <= 0) return BadgeStyle.Danger;
        if (item.CurrentQuantity <= item.MinimumQuantity) return BadgeStyle.Warning;
        return BadgeStyle.Success;
    }

    private int LowStockCount => InventoryItems.Count(i => i.CurrentQuantity > 0 && i.CurrentQuantity <= i.MinimumQuantity);
    private int InStockCount => InventoryItems.Count(i => i.CurrentQuantity > i.MinimumQuantity);
    private int OutOfStockCount => InventoryItems.Count(i => i.CurrentQuantity <= 0);

    private async Task InitializeAll()
    {
        var parameters = new DialogParameters<PremiumConfirmDialog>
        {
            { x => x.Title, Localizer.GetCurrentLanguage() == "ar" ? "تأكيد التهيئة" : "Initialize Confirmation" },
            { x => x.Message, Localizer.GetCurrentLanguage() == "ar" ? "هل تريد تهيئة جميع الأصناف للمخزن؟ سيتم إضافة الأصناف غير الموجودة حالياً." : "Do you want to initialize all items for the warehouse? New items will be added." },
            { x => x.ConfirmText, Localizer.GetCurrentLanguage() == "ar" ? "تأكيد الآن" : "Confirm Now" },
            { x => x.CancelText, Localizer.GetCurrentLanguage() == "ar" ? "إلغاء التنفيذ" : "Cancel" },
            { x => x.Icon, "autorenew" },
            { x => x.StyleClass, "info" }
        };

        var options = new MudBlazor.DialogOptions { NoHeader = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PremiumConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await InventoryService.InitializeAllItemsAsync();
            if (response.Success)
            {
                Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "تمت التهيئة بنجاح" : "Initialized successfully", Severity.Success);
                await LoadData();
            }
        }
    }

    private async Task OpenOpeningStockDialog()
    {
        Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "يرجى اختيار صنف من القائمة لتعيين رصيد أول المدة" : "Please select an item from the list to set opening stock", Severity.Info);
    }

    private async Task UpdateItemUnit(InventoryItemDto item, int? unitId)
    {
        item.UnitId = unitId;
        await InventoryService.InitializeInventoryAsync(item);
        await LoadData();
    }

    private async Task HandleAction(InventoryItemDto item, RadzenSplitButtonItem args)
    {
        if (args == null) return;
        var action = args.Value?.ToString();
        if (string.IsNullOrEmpty(action)) return;
        
        switch (action)
        {
            case "adjust": await OpenAdjustmentDialog(item); break;
            case "physical": await OpenPhysicalCountDialog(item); break;
            case "opening": await OpenOpeningStockForItem(item); break;
            case "history": await OpenHistory(item); break;
            case "recipe": await ManageRecipe(item); break;
        }
    }

    private async Task OpenAdjustmentDialog(InventoryItemDto item)
    {
        var parameters = new DialogParameters { ["Item"] = item, ["Mode"] = InventoryDialog.DialogMode.Adjustment };
        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<InventoryDialog>(Localizer.GetCurrentLanguage() == "ar" ? "تعديل رصيد" : "Stock Adjustment", parameters, options);
        if (!(await dialog.Result).Canceled) await LoadData();
    }

    private async Task OpenPhysicalCountDialog(InventoryItemDto item)
    {
        var parameters = new DialogParameters { ["Item"] = item, ["Mode"] = InventoryDialog.DialogMode.PhysicalCount };
        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<InventoryDialog>(Localizer.GetCurrentLanguage() == "ar" ? "جرد يدوي" : "Physical Count", parameters, options);
        if (!(await dialog.Result).Canceled) await LoadData();
    }

    private async Task OpenOpeningStockForItem(InventoryItemDto item)
    {
        var parameters = new DialogParameters { ["Item"] = item, ["Mode"] = InventoryDialog.DialogMode.OpeningStock };
        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<InventoryDialog>(Localizer.GetCurrentLanguage() == "ar" ? "رصيد أول المدة" : "Opening Stock", parameters, options);
        if (!(await dialog.Result).Canceled) await LoadData();
    }

    private async Task OpenHistory(InventoryItemDto item)
    {
        var parameters = new DialogParameters { ["Item"] = item };
        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<StockHistoryDialog>(Localizer.GetCurrentLanguage() == "ar" ? "سجل الحركات" : "Transaction History", parameters, options);
    }

    private async Task ManageRecipe(InventoryItemDto item)
    {
        var parameters = new DialogParameters { ["Item"] = item };
        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<RecipeDialog>(Localizer.GetCurrentLanguage() == "ar" ? "إدارة الريسيبي" : "Manage Recipe", parameters, options);
    }
}
