@page "/basicdata/units"
@using POS.Contract.Dtos.InventoryDtos
@using BlazorBase.ERPFrontServices.InventoryServices
@inject IUnitFrontService UnitService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LocalizationService Localizer
@inject Radzen.DialogService RadzenDialogService

<style>
    .units-page { font-family: 'Outfit', 'Noto Sans Arabic', sans-serif; background: #f0f2f5; min-height: 100vh; padding: 2rem; }
    .page-header { background: white; padding: 1.5rem 2rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); margin-bottom: 2rem; }
    .header-title { display: flex; align-items: center; gap: 1rem; }
    .header-icon { background: #6366f1; color: white; padding: 12px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3); }
    .header-text h1 { margin: 0; font-size: 1.75rem; font-weight: 800; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .header-text p { margin: 0; color: #64748b; font-size: 0.9rem; }
    
    .stats-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .stat-card { background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 1.25rem; transition: transform 0.2s; cursor: default; }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .stat-card .icon-box { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .stat-card.total .icon-box { background: #eff6ff; color: #3b82f6; }
    .stat-info .label { font-size: 0.85rem; color: #64748b; font-weight: 600; }
    .stat-info .value { font-size: 1.5rem; font-weight: 800; color: #1e293b; }

    .grid-card { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); overflow: hidden; }
    .grid-toolbar { padding: 1rem 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; background: #fafafa; }
    
    .rz-datagrid { border: none !important; }
    .rz-datagrid-header { background: #f8fafc !important; }
    .rz-column-title { color: #64748b !important; font-weight: 700 !important; font-size: 0.8rem !important; text-transform: uppercase !important; }
    
    .premium-add-btn {
        border-radius: 12px !important;
        padding: 0 1.5rem !important;
        height: 44px !important;
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%) !important;
        color: white !important;
        border: none !important;
        font-weight: 700 !important;
        display: inline-flex !important;
        align-items: center !important;
    }

    .action-btn { border-radius: 8px !important; transition: all 0.2s; }
    .action-btn:hover { transform: scale(1.05); }

    [dir="rtl"] .header-text { text-align: right; }
    [dir="rtl"] .stat-info { text-align: right; }
</style>

<div class="units-page animate__animated animate__fadeIn" dir="@(Localizer.GetCurrentLanguage() == "ar" ? "rtl" : "ltr")">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="header-title">
                <div class="header-icon">
                    <RadzenIcon Icon="straighten" />
                </div>
                <div class="header-text">
                    <h1>@(Localizer.GetCurrentLanguage() == "ar" ? "تعريف الوحدات" : "Unit Definitions")</h1>
                    <p>@(Localizer.GetCurrentLanguage() == "ar" ? "إدارة وحدات القياس (كيلو، جرام، قطعة، لتر، إلخ)" : "Manage measurement units")</p>
                </div>
            </div>
            <RadzenButton Click="() => OpenUnitDialog(null)" 
                          Icon="add" 
                          Text="@(Localizer.GetCurrentLanguage() == "ar" ? "إضافة وحدة جديدة" : "Add New Unit")" 
                          Class="premium-add-btn" />
        </div>
    </div>

    <div class="stats-container">
        <div class="stat-card total">
            <div class="icon-box">
                <RadzenIcon Icon="list_alt" />
            </div>
            <div class="stat-info">
                <div class="label">@(Localizer.GetCurrentLanguage() == "ar" ? "إجمالي الوحدات" : "Total Units")</div>
                <div class="value">@Units.Count</div>
            </div>
        </div>
    </div>

    <div class="grid-card">
        <RadzenDataGrid Data="@Units" TItem="UnitDto" 
                        AllowFiltering="true" FilterMode="FilterMode.Simple" 
                        AllowPaging="true" PageSize="10" 
                        AllowSorting="true" 
                        Responsive="true"
                        EmptyText="@(Localizer.GetCurrentLanguage() == "ar" ? "لا توجد وحدات معرفة حالياً" : "No units defined")">
            <Columns>
                <RadzenDataGridColumn TItem="UnitDto" Property="ArabicName" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الاسم بالعربي" : "Arabic Name")">
                    <Template Context="unit">
                        <span style="font-weight: 700; color: #1e293b;">@unit.ArabicName</span>
                    </Template>
                </RadzenDataGridColumn>
                
                <RadzenDataGridColumn TItem="UnitDto" Property="EnglishName" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الاسم بالإنجليزي" : "English Name")" />
                
                <RadzenDataGridColumn TItem="UnitDto" Property="Code" Title="@(Localizer.GetCurrentLanguage() == "ar" ? "الكود / الرمز" : "Code")" Width="150px">
                    <Template Context="unit">
                        <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@unit.Code" Style="border-radius: 8px; padding: 4px 12px; font-weight: 700;" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="UnitDto" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="120px">
                    <HeaderTemplate>
                        @(Localizer.GetCurrentLanguage() == "ar" ? "إجراءات" : "Actions")
                    </HeaderTemplate>
                    <Template Context="unit">
                        <div class="d-flex justify-content-center gap-2">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" 
                                          Click="@(() => OpenUnitDialog(unit))" Class="action-btn" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" 
                                          Click="@(() => DeleteUnit(unit.Id))" Class="action-btn" />
                        </div>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@code {
    private List<UnitDto> Units = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUnits();
    }

    private async Task LoadUnits()
    {
        IsLoading = true;
        var response = await UnitService.GetAllUnitsAsync();
        if (response.Success) Units = response.Data.ToList();
        IsLoading = false;
        StateHasChanged();
    }

    private async Task OpenUnitDialog(UnitDto? unit)
    {
        var parameters = new DialogParameters<UnitEditDialog> { ["Unit"] = unit ?? new UnitDto() };
        var options = new MudBlazor.DialogOptions { 
            CloseButton = true, 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true,
            NoHeader = true 
        };
        
        var dialog = await DialogService.ShowAsync<UnitEditDialog>("", parameters, options);
            
        var result = await dialog.Result;
        if (!result.Canceled) await LoadUnits();
    }

    private async Task DeleteUnit(int id)
    {
        var parameters = new DialogParameters<PremiumConfirmDialog>
        {
            { x => x.Title, Localizer.GetCurrentLanguage() == "ar" ? "حذف الوحدة" : "Delete Unit" },
            { x => x.Message, Localizer.GetCurrentLanguage() == "ar" ? "هل أنت متأكد من حذف هذه الوحدة؟ قد يؤثر ذلك على الأصناف والوحدات المرتبطة بها." : "Are you sure you want to delete this unit? This might affect related items." },
            { x => x.ConfirmText, Localizer.GetCurrentLanguage() == "ar" ? "حذف نهائي" : "Delete Permanently" },
            { x => x.CancelText, Localizer.GetCurrentLanguage() == "ar" ? "إلغاء الحذف" : "Cancel" },
            { x => x.Icon, "delete_forever" },
            { x => x.StyleClass, "danger" }
        };

        var options = new MudBlazor.DialogOptions { NoHeader = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PremiumConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await UnitService.DeleteUnitAsync(id);
            if (response.Success)
            {
                Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "تم الحذف بنجاح" : "Deleted successfully", Severity.Success);
                await LoadUnits();
            }
        }
    }
}
