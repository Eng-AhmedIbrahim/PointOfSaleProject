@page "/basicdata/users"
@using Radzen
@using Radzen.Blazor
@using BlazorBase.ERPFrontServices.AccountServices
@attribute [Authorize]
@inject IAccountService AccountService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ContextMenuService ContextMenuService
@inject BlazorBase.Services.LocalizationService LocalizerService

<div class="user-management-container @(IsArabic ? "rtl-mode" : "") py-2" dir="@(IsArabic ? "rtl" : "ltr")">
    <RadzenTabs RenderMode="Radzen.TabRenderMode.Client">
        <Tabs>
            <RadzenTabsItem Text="@(IsArabic ? "البحث والتمحيص" : "Search & List")" Icon="manage_search">
                <div class="tab-content">
                    <div class="search-container mb-3" style="max-width: 500px;">
                        <MudTextField @bind-Value="SearchTerm" 
                                      Placeholder="@(IsArabic ? "بحث باسم المستخدم أو الاسم الكامل..." : "Search by username or name...")"
                                      Variant="MudBlazor.Variant.Outlined" 
                                      Adornment="Adornment.Start" 
                                      AdornmentIcon="@Icons.Material.Filled.Search" 
                                      AdornmentColor="MudBlazor.Color.Primary"
                                      Clearable="true"
                                      Immediate="true"
                                      Margin="MudBlazor.Margin.Dense"
                                      Style="background: white; border-radius: 24px; font-weight: 900;"
                                      Class="premium-search-input" />
                    </div>

                    <div class="grid-container">
                        @if (IsLoading)
                        {
                            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; background: white;">
                                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="margin-bottom: 1rem;" />
                                <h4 style="color: #64748b; font-weight: 700;">@(IsArabic ? "جاري تحميل البيانات..." : "Loading data...")</h4>
                            </div>
                        }
                        else
                        {
                            <RadzenDataGrid @ref="usersGrid" AllowFiltering="false" AllowColumnResize="true"
                                            AllowAlternatingRows="false" AllowSorting="true"
                                            PageSize="15" AllowPaging="true"
                                            PagerHorizontalAlign="HorizontalAlign.Left" ShowPagingSummary="true"
                                            Data="@FilteredUsers" TItem="UserDto"
                                            SelectionMode="DataGridSelectionMode.Single"
                                            Style="flex: 1; min-height: 0; font-size: 1.05rem;">
                                <Columns>
                                    <RadzenDataGridColumn TItem="UserDto" Property="UserId" Title="Id" Width="80px" TextAlign="Radzen.TextAlign.Center" />
                                    <RadzenDataGridColumn TItem="UserDto" Property="UserName" Title="@(IsArabic ? "اسم المستخدم" : "Username")" />
                                    <RadzenDataGridColumn TItem="UserDto" Property="ArabicName" Title="@(IsArabic ? "الاسم" : "Name")" />
                                    <RadzenDataGridColumn TItem="UserDto" Property="PhoneNumber" Title="@(IsArabic ? "رقم الهاتف" : "Phone")" Width="150px" />
                                    <RadzenDataGridColumn TItem="UserDto" Property="Email" Title="@(IsArabic ? "البريد" : "Email")" />
                                    <RadzenDataGridColumn TItem="UserDto" Title="@(IsArabic ? "الأدوار" : "Roles")">
                                        <Template Context="user">
                                            <div style="display: flex; flex-wrap: wrap; gap: 4px; justify-content: center;">
                                                @if (user.Roles != null && user.Roles.Any())
                                                {
                                                    @foreach (var role in user.Roles)
                                                    {
                                                        <RadzenBadge Text="@role" BadgeStyle="BadgeStyle.Primary" IsPill="true" Class="role-badge" />
                                                    }
                                                }
                                                else
                                                {
                                                    <span style="color: #cbd5e1;">-</span>
                                                }
                                            </div>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="UserDto" Property="IsActive" Title="@(IsArabic ? "الحالة" : "Status")" Width="100px" TextAlign="TextAlign.Center">
                                        <Template Context="user">
                                            <RadzenBadge BadgeStyle="@(user.IsActive ? BadgeStyle.Success : BadgeStyle.Light)" Text="@(user.IsActive ? (IsArabic ? "نشط" : "Active") : (IsArabic ? "غير نشط" : "Inactive"))" IsPill="true" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="UserDto" Context="user" Filterable="false" Sortable="false" TextAlign="Radzen.TextAlign.Center" Width="200px" Title="@(IsArabic ? "الإجراءات" : "Actions")">
                                        <Template Context="user">
                                            <RadzenSplitButton Click="@((args) => OnActionClick(args, user))"
                                                               Text="@(IsArabic ? "تعديل" : "Edit")"
                                                               Icon="edit"
                                                               ButtonStyle="ButtonStyle.Primary"
                                                               Variant="Radzen.Variant.Filled"
                                                               Size="ButtonSize.Medium"
                                                               Style="font-weight: 900; font-size: 1.1rem; width: 140px;">
                                                <ChildContent>
                                                    <RadzenSplitButtonItem Text="@(IsArabic ? "تعديل" : "Edit")" Value="edit" Icon="edit" />
                                                    <RadzenSplitButtonItem Text="@(IsArabic ? "حذف" : "Delete")" Value="delete" Icon="delete" />
                                                </ChildContent>
                                            </RadzenSplitButton>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </div>
                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="@(IsArabic ? "إنشاء مستخدم" : "Create User")" Icon="person_add">
                <div class="tab-content" style="overflow-y: auto;">
                    <RadzenTemplateForm TItem="RegisterDto" Data="@RegisterModel" Submit="@OnSubmit" id="create-user-form">
                        <RadzenRow Gap="1.5rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <div class="form-section-title mb-3">
                                    <RadzenIcon Icon="badge" Style="vertical-align: middle; margin-inline-end: 8px;" />
                                    <span>@(IsArabic ? "المعلومات الأساسية" : "Basic Information")</span>
                                </div>
                                
                                <div class="create-form-grid">
                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "الاسم إنجليزي" : "English Name")" Component="UserName" class="custom-field-label" />
                                        <RadzenTextBox @bind-Value="RegisterModel.UserName" Name="UserName" class="custom-field-input" />
                                        <RadzenRequiredValidator Component="UserName" Text="@(IsArabic ? "الاسم الإنجليزي مطلوب" : "Required")" />
                                    </div>

                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "الاسم عربي" : "Arabic Name")" Component="ArabicName" class="custom-field-label" />
                                        <RadzenTextBox @bind-Value="RegisterModel.ArabicName" Name="ArabicName" class="custom-field-input" />
                                    </div>

                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "رقم الهاتف (اختياري)" : "Phone Number (Optional)")" Component="PhoneNumber" class="custom-field-label" />
                                        <RadzenTextBox @bind-Value="RegisterModel.PhoneNumber" Name="PhoneNumber" class="custom-field-input" />
                                    </div>

                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "البريد الإلكتروني (اختياري)" : "Email Address (Optional)")" Component="Email" class="custom-field-label" />
                                        <RadzenTextBox @bind-Value="RegisterModel.Email" Name="Email" class="custom-field-input" />
                                    </div>

                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "تاريخ الميلاد (اختياري)" : "Date of Birth (Optional)")" Component="DateOfBirth" class="custom-field-label" />
                                        <RadzenDatePicker @bind-Value="RegisterModel.DateOfBirth" Name="DateOfBirth" class="custom-field-input-date" ShowTime="false" />
                                    </div>
                                </div>
                            </RadzenColumn>

                            <RadzenColumn Size="12" SizeMD="6">
                                <div class="form-section-title mb-3">
                                    <RadzenIcon Icon="security" Style="vertical-align: middle; margin-inline-end: 8px;" />
                                    <span>@(IsArabic ? "مستوى الوصول وكلمة المرور" : "Access & Security")</span>
                                </div>

                                <div class="create-form-grid">
                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "الدور الوظيفي" : "User Role")" Component="RoleName" class="custom-field-label" />
                                        <RadzenDropDown TValue="string" Data="@Roles" TextProperty="Name" ValueProperty="Name" @bind-Value="RegisterModel.roleName" Name="RoleName" class="custom-field-dropdown" />
                                        <RadzenRequiredValidator Component="RoleName" Text="@(IsArabic ? "الدور مطلوب" : "Role is required")" />
                                    </div>

                                    <div class="custom-field-container">
                                        <RadzenLabel Text="@(IsArabic ? "كلمة المرور" : "Password")" Component="Password" class="custom-field-label" />
                                        <RadzenPassword @bind-Value="RegisterModel.Password" Name="Password" class="custom-field-input" />
                                        <RadzenRequiredValidator Component="Password" Text="@(IsArabic ? "كلمة المرور مطلوبة" : "Password is required")" />
                                    </div>
                                    
                                    <div class="info-card mt-3">
                                        <RadzenIcon Icon="info" Style="color: #3b82f6; margin-inline-end: 10px;" />
                                        <span style="font-size: 0.9rem; color: #64748b; font-weight: 700;">
                                            @(IsArabic 
                                                ? "تأكد من اختيار الدور المناسب للمستخدم لضمان حصوله على صلاحيات النظام الصحيحة." 
                                                : "Ensure you select the appropriate role to grant the user correct system permissions.")
                                        </span>
                                    </div>
                                </div>
                            </RadzenColumn>
                        </RadzenRow>

                        <div class="mt-5 text-center action-buttons">
                            <RadzenButton ButtonType="Radzen.ButtonType.Submit" Text="@(IsArabic ? "إنشاء مستخدم جديد" : "Create New User")" 
                                         Icon="person_add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" 
                                         BusyText="@(IsArabic ? "جاري الإنشاء..." : "Creating...")" IsBusy="@IsSaving" 
                                         Style="padding: 0 3rem; border-radius: 12px; font-weight: 900; height: 50px; font-size: 1.2rem;"/>
                            
                            <RadzenButton ButtonType="Radzen.ButtonType.Button" Text="@(IsArabic ? "إعادة تعيين" : "Reset Form")" 
                                         Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Large" Click="@ResetForm" 
                                         Class="ms-3" Style="border-radius: 12px; font-weight: 900; height: 50px;"/>
                        </div>
                    </RadzenTemplateForm>
                </div>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</div>

@code {
    private List<UserDto> AllUsers = new();
    private List<UserDto> FilteredUsers = new();
    private List<RoleToReturnDto> Roles = new();
    private RegisterDto RegisterModel = new();
    private bool IsLoading = true;
    private bool IsSaving = false;
    private RadzenDataGrid<UserDto>? usersGrid;

    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            ApplySearch();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            AllUsers = (await AccountService.GetUsersWithRoles()).ToList();
            FilteredUsers = AllUsers;
            Roles = (await AccountService.GetRoles()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add(IsArabic ? "فشل تحميل البيانات" : "Failed to load data", Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ApplySearch()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            FilteredUsers = AllUsers.ToList();
        }
        else
        {
            var term = _searchTerm.Trim();
            // Filter: only show users that match the term
            FilteredUsers = AllUsers.Where(u =>
                (u.UserName?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.ArabicName?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.DisplayName?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.PhoneNumber?.Contains(term) ?? false)
            ).OrderByDescending(u => 
                (u.UserName?.StartsWith(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.ArabicName?.StartsWith(term, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
        
        StateHasChanged();
        if (usersGrid != null) 
        {
            usersGrid.FirstPage();
            usersGrid.Reload();
        }
    }

    private void OnSearch(string term)
    {
        SearchTerm = term;
    }

    private async Task OnActionClick(RadzenSplitButtonItem args, UserDto user)
    {
        if (args == null || args.Value == null || args.Value.ToString() == "edit")
        {
            Console.WriteLine($"Opening edit dialog for user: {user.UserName}"); 
            await OpenEditDialog(user);
        }
        else if (args.Value.ToString() == "delete")
        {
            await ConfirmDelete(user);
        }
    }

    private async Task OpenEditDialog(UserDto user)
    {
        try 
        {
            if (user.Email == "string") user.Email = "";
            if (user.PhoneNumber == "string") user.PhoneNumber = "";
            if (user.ArabicName == "string") user.ArabicName = "";

            var parameters = new DialogParameters<EditUserDialog>
            {
                { x => x.User, user },
                { x => x.Roles, Roles },
                { x => x.IsArabic, IsArabic }
            };

            var options = new MudBlazor.DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
            
            var dialog = await DialogService.ShowAsync<EditUserDialog>(IsArabic ? "تعديل بيانات المستخدم" : "Edit User Data", parameters, options);
            var result = await dialog.Result;

            if (result != null && !result.Canceled)
            {
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Console.WriteLine(ex.ToString());
        }
    }

    private async Task ConfirmDelete(UserDto user)
    {
        var parameters = new DialogParameters<DeleteConfirmDialog>
        {
            { x => x.User, user },
            { x => x.IsArabic, IsArabic }
        };

        var options = new MudBlazor.DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeleteConfirmDialog>(IsArabic ? "تأكيد الحذف" : "Confirm Deletion", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var success = await AccountService.DeleteUser(user.UserId!);
            if (success)
            {
                Snackbar.Add(IsArabic ? "تم حذف المستخدم بنجاح" : "User deleted successfully", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add(IsArabic ? "فشل حذف المستخدم" : "Failed to delete user", Severity.Error);
            }
        }
    }

    private async Task OnSubmit()
    {
        IsSaving = true;
        try
        {
            RegisterModel.DisplayName = RegisterModel.ArabicName;
            var success = await AccountService.CreateUser(RegisterModel);
            if (success)
            {
                Snackbar.Add(IsArabic ? "تم إنشاء المستخدم بنجاح" : "User created successfully", Severity.Success);
                ResetForm();
                await LoadData();
            }
            else
            {
                Snackbar.Add(IsArabic ? "فشل إنشاء المستخدم" : "Failed to create user", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ResetForm()
    {
        RegisterModel = new RegisterDto();
    }

    private bool IsArabic => LocalizerService.GetCurrentLanguage() == "ar";
}
