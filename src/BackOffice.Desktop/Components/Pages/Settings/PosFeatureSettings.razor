@page "/settings/features"
@using POS.Contract.Dtos.OrderDto
@inject IPosFeatureSettingsService FeatureSettingsService
@inject ISnackbar Snackbar
@inject BlazorBase.Services.LocalizationService Localizer

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-10" dir="rtl">
    <MudText Typo="Typo.h4" GutterBottom="true" Style="font-weight: 900; color: #1e293b;" Align="Align.Right">
        <MudIcon Icon="@Icons.Material.Rounded.FeaturedPlayList" Class="mb-n2 ml-2" Size="Size.Large" Color="Color.Primary" />
        @(Localizer.GetCurrentLanguage() == "ar" ? "خصائص ومميزات النظام" : "System Feature Settings")
    </MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6 text-muted" Align="Align.Right">
        @(Localizer.GetCurrentLanguage() == "ar" ? "تخصيص الخصائص لكل جهاز: " : "Customize features per device: ")
        <span class="badge bg-primary text-white px-2 py-1 rounded">@Environment.MachineName</span>
    </MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var moduleGroup in _settings.GroupBy(s => s.ModuleName ?? "General"))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mt-4 mb-2" Style="font-weight: 800; color: #334155; text-transform: uppercase; border-right: 4px solid #3b82f6; padding-right: 12px;" Align="Align.Right">
                        @moduleGroup.Key
                    </MudText>
                </MudItem>

                @foreach (var screenGroup in moduleGroup.GroupBy(s => s.ScreenName ?? "Other"))
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="4" Style="border-radius: 20px; height: 100%; border: 1px solid #e2e8f0; background: #ffffff;">
                            <MudCardHeader Style="background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 12px 16px;">
                                <CardHeaderContent>
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@GetIconForScreen(screenGroup.Key)" Color="Color.Primary" Class="ml-2" Size="Size.Small" />
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@screenGroup.Key</MudText>
                                    </div>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-4">
                                <MudStack Spacing="1">
                                    @foreach (var setting in screenGroup)
                                    {
                                        <div class="d-flex align-center justify-space-between py-2 border-bottom-soft">
                                            <div class="d-flex flex-column text-right" style="flex-grow: 1;">
                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                    @(Localizer.GetCurrentLanguage() == "ar" ? setting.NameAr : setting.NameEn)
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem;">@setting.FeatureName</MudText>
                                            </div>
                                            <MudSwitch @bind-Value="setting.Value" Color="Color.Primary" UnCheckedColor="Color.Default" Class="ml-n2" />
                                        </div>
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            }
        </MudGrid>

        <div class="d-flex justify-start mt-10 mb-10">
            <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="SaveSettings" 
                       StartIcon="@Icons.Material.Rounded.Save" Style="border-radius: 12px; height: 55px; min-width: 220px; font-weight: 800; box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3);">
                @(Localizer.GetCurrentLanguage() == "ar" ? "حفظ التغييرات" : "Save Changes")
            </MudButton>
        </div>
    }
</MudContainer>

<style>
    .rounded { border-radius: 8px !important; }
    .bg-primary { background-color: #3b82f6 !important; }
    .badge { display: inline-block; font-size: 0.75rem; font-weight: 700; line-height: 1; text-align: center; white-space: nowrap; vertical-align: baseline; }
    .border-bottom-soft { border-bottom: 1px solid #f1f5f9; }
    .border-bottom-soft:last-child { border-bottom: none; }
</style>

@code {
    private List<PosFeatureSettingToReturnDto> _settings = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        _isLoading = true;
        try
        {
            _settings = await FeatureSettingsService.GetSettingsByComputerNameAsync(Environment.MachineName);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "فشل تحميل إعدادات الخصائص" : "Failed to load feature settings", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        var result = await FeatureSettingsService.UpdateSettingsAsync(Environment.MachineName, _settings);
        if (result)
        {
            Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "تم حفظ إعدادات الخصائص بنجاح" : "Feature settings saved successfully", Severity.Success);
        }
        else
        {
            Snackbar.Add(Localizer.GetCurrentLanguage() == "ar" ? "فشل حفظ الإعدادات" : "Failed to save settings", Severity.Error);
        }
    }

    private string GetIconForScreen(string screenName)
    {
        return screenName switch
        {
            "Dine-In Hall" => Icons.Material.Rounded.TableBar,
            "POS (Actions)" => Icons.Material.Rounded.AdsClick,
            "POS (Section 4)" => Icons.Material.Rounded.ShoppingBag,
            "POS Navbar" => Icons.Material.Rounded.Navigation,
            _ => Icons.Material.Rounded.Settings
        };
    }
}
