@page "/settings/branches"
@using Radzen
@using Radzen.Blazor
@using POS.Contract.Dtos.CompanyDtos
@using BlazorBase.ERPFrontServices.BranchServices
@inject IBranchService BranchService
@inject NotificationService NotificationService
@inject MudBlazor.IDialogService DialogService
@inject BlazorBase.Services.LocalizationService Localizer

<div class="branch-page-wrapper">
    <!-- Header -->
    <div class="branch-header d-flex justify-space-between align-center">
        <div>
            <RadzenText TextStyle="TextStyle.H5" Class="rz-m-0 premium-title">@Localizer["BranchManagement"]</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" Class="rz-m-0 text-muted">@Localizer["ManageBranchesDesc"]</RadzenText>
        </div>
        <RadzenButton Text="@Localizer["AddBranch"]" Icon="add_circle" ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Medium" Click="@(() => OpenBranchDialog())" Class="premium-add-btn" />
    </div>

    @if (_branches == null)
    {
        <div class="d-flex justify-center rz-mt-12">
            <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
        </div>
    }
    else if (!_branches.Any())
    {
        <div class="empty-state-card rz-text-align-center rz-p-12">
            <RadzenIcon Icon="storefront" Style="font-size:4rem; color:#94a3b8;" />
            <RadzenText TextStyle="TextStyle.H5" Class="rz-mt-4 text-muted">@Localizer["NoBranchesFound"]</RadzenText>
            <RadzenButton Text="@Localizer["AddBranch"]" Icon="add" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => OpenBranchDialog())" Class="rz-mt-6" />
        </div>
    }
    else
    {
        <div class="branches-grid">
            @foreach (var branch in _branches)
            {
                <div class="premium-branch-card">
                    <div class="branch-card-header">
                        <div class="branch-avatar">
                            <RadzenIcon Icon="store" IconColor="var(--rz-primary)" />
                        </div>
                        <div class="branch-card-title-group">
                            <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0 card-title">@branch.Name</RadzenText>
                            <RadzenBadge BadgeStyle="@(branch.Active ? BadgeStyle.Success : BadgeStyle.Danger)"
                                         IsPill="true" Text="@(branch.Active ? Localizer["Active"] : Localizer["Inactive"])"
                                         Class="rz-mt-1" />
                        </div>
                        <div class="d-flex gap-1">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Info" Variant="Radzen.Variant.Text" Size="ButtonSize.Small" 
                                         Click="@(() => OpenBranchDialog(branch))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Radzen.Variant.Text" Size="ButtonSize.Small" 
                                         Click="@(() => DeleteBranch(branch.Id))" />
                        </div>
                    </div>

                    <RadzenDivider Style="margin:0;" />

                    <div class="branch-card-body">
                        <div class="info-row">
                            <div class="info-icon bg-info-light">
                                <RadzenIcon Icon="phone" Style="color:#0ea5e9; font-size:16px;" />
                            </div>
                            <RadzenText TextStyle="TextStyle.Body2" Class="rz-m-0 info-text" Style="direction:ltr;">@branch.Phone1</RadzenText>
                        </div>

                        @if (!string.IsNullOrEmpty(branch.Phone2))
                        {
                            <div class="info-row">
                                <div class="info-icon bg-info-light">
                                    <RadzenIcon Icon="smartphone" Style="color:#0ea5e9; font-size:16px;" />
                                </div>
                                <RadzenText TextStyle="TextStyle.Body2" Class="rz-m-0 info-text" Style="direction:ltr;">@branch.Phone2</RadzenText>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(branch.Address))
                        {
                            <div class="info-row">
                                <div class="info-icon bg-secondary-light">
                                    <RadzenIcon Icon="location_on" Style="color:#f43f5e; font-size:16px;" />
                                </div>
                                <RadzenText TextStyle="TextStyle.Body2" Class="rz-m-0 info-text text-truncate-2">@branch.Address</RadzenText>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .branch-page-wrapper { padding: 16px 24px; height: 100%; overflow-y: auto; background: #f8fafc; }
    .branch-header { margin-bottom: 20px; }

    .premium-title {
        font-weight: 900;
        background: linear-gradient(135deg, #1e293b 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .text-muted { color: #64748b; }

    .premium-add-btn {
        border-radius: 14px !important;
        font-weight: 700;
        box-shadow: 0 4px 15px -3px rgba(59,130,246,0.4);
        transition: all 0.3s;
    }
    .premium-add-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px -4px rgba(59,130,246,0.6); }

    .branches-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
    }

    .premium-branch-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
        display: flex;
        flex-direction: column;
    }
    .premium-branch-card:hover { transform: translateY(-8px); box-shadow: 0 20px 30px rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.3); }

    .branch-card-header { display:flex; align-items:center; gap:10px; padding:12px 16px; }
    .branch-avatar { width:40px; height:40px; border-radius:12px; background:#eff6ff; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .branch-card-title-group { flex:1; }
    .card-title { color:#1e293b; font-weight:800; }

    .branch-card-body { padding:12px 16px; display:flex; flex-direction:column; gap:8px; }
    .info-row { display:flex; align-items:center; gap:12px; }
    .info-icon { width:32px; height:32px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .bg-info-light { background:#f0f9ff; }
    .bg-secondary-light { background:#fff1f2; }
    .info-text { color:#475569; font-weight:500; }
    .text-truncate-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }

    .empty-state-card { border:2px dashed #cbd5e1; background:#f8fafc; border-radius:20px; max-width:500px; margin:80px auto 0; }
</style>

@code {
    private List<BranchToReturnDto>? _branches;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var branches = await BranchService.GetBranches();
        _branches = branches.ToList();
    }

    private async Task OpenBranchDialog(BranchToReturnDto? branch = null)
    {
        var parameters = new DialogParameters();
        if (branch != null) parameters.Add("Branch", branch);

        var options = new MudBlazor.DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<BranchDialog>(branch == null ? Localizer["AddBranch"] : Localizer["EditBranch"], parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }

    private async Task DeleteBranch(int id)
    {
        var confirmed = await DialogService.ShowMessageBox(
            Localizer["Warning"], Localizer["DeleteBranchConfirm"],
            yesText: Localizer["Delete"], cancelText: Localizer["Cancel"]);

        if (confirmed == true)
        {
            var result = await BranchService.DeleteBranch(id);
            if (result)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = Localizer["SavedSuccessfully"] });
                await LoadData();
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = Localizer["ErrorSaving"] });
            }
        }
    }
}
