@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject CommonProperties _commonProperties
@inject LocalizationService Localizer
@inject BlazorBase.ERPFrontServices.PrintOrderServices.IPrintOrderService _printOrderService
@inject IReportingErpService ReportingService

<MudDialog Class="modern-staff-dialog" Style="direction: rtl; font-family: 'Tajawal', sans-serif; border-radius: 20px; max-height: 90vh;">
    <TitleContent>
        <div class="dialog-header-premium glass pa-4 border-b">
            <div class="d-flex align-center justify-space-between w-100 flex-wrap gap-2">
                <div class="d-flex align-center gap-4">
                    <div class="user-avatar-container shadow-sm">
                        <MudAvatar Color="Color.Primary" Variant="MudBlazor.Variant.Filled" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        </MudAvatar>
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 900; color: #1e3a5f;">@StaffName</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" /> @SelectedDate.ToString("yyyy-MM-dd") | 
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" /> @Orders.Count @Localizer["Orders"]
                        </MudText>
                    </div>
                </div>
                
                <div class="d-flex align-center gap-2">
                    <MudButton Variant="MudBlazor.Variant.Filled"
                               Color="Color.Info" 
                               StartIcon="@Icons.Material.Filled.ListAlt" 
                               OnClick="@(async () => await PrintStaffReport(true))" 
                               Class="rounded-pill px-4"
                               Style="height: 40px; font-weight: 700; font-size: 0.85rem;">
                        @(Localizer.GetCurrentLanguage() == "ar" ? "تقرير المبيعات" : "Sales Report")
                    </MudButton>

                    <MudButton Variant="MudBlazor.Variant.Filled"
                               Color="Color.Success" 
                               StartIcon="@Icons.Material.Filled.Assessment" 
                               OnClick="@(async () => await PrintStaffReport(false))" 
                               Class="rounded-pill px-4 shadow-sm"
                               Style="height: 40px; font-weight: 700; font-size: 0.85rem;">
                        @(Localizer.GetCurrentLanguage() == "ar" ? "ملخص المبيعات" : "Sales Summary")
                    </MudButton>
                </div>
            </div>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="staff-content-body d-flex flex-column" style="height: 58vh; overflow: hidden;">
            @if (_isLoading)
            {
                <div class="d-flex flex-column align-center justify-center flex-grow-1">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Class="mt-4" Typo="Typo.body1">@Localizer["LoadingData"]...</MudText>
                </div>
            }
            else
            {
                <div class="table-scroll-area flex-grow-1 overflow-auto mb-2 border rounded-lg">
                    <MudTable Items="@Orders" 
                                Hover="true" 
                                Dense="true" 
                                Elevation="0" 
                                Height="100%" 
                                FixedHeader="true" 
                                Breakpoint="Breakpoint.Sm"
                                Class="compact-table">
                        <HeaderContent>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["OrderID"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["Time"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["OrderType"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["PaymentMethod"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["Discount"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["Void"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["GrandTotal"]</MudTh>
                            <MudTh Style="background: #f8f9fa; font-weight: 800; text-align: center;">@Localizer["Actions"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localizer["OrderID"]" Style="text-align: center; font-weight: 700;">#@context.OrderId</MudTd>
                            <MudTd DataLabel="@Localizer["Time"]" Style="text-align: center;">@context.OrderDate?.ToString("HH:mm")</MudTd>
                            <MudTd DataLabel="@Localizer["OrderType"]" Style="text-align: center;">
                                <MudChip T="string" Color="@GetOrderTypeColor(context.OrderType)" Size="Size.Small" Variant="MudBlazor.Variant.Text">@context.OrderType</MudChip>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["PaymentMethod"]" Style="text-align: center;">
                                <MudIcon Icon="@(context.PaymentMethod == PaymentMethod.Cash ? Icons.Material.Filled.Payments : Icons.Material.Filled.CreditCard)" 
                                         Color="Color.Default" Size="Size.Small" Class="me-1" />
                                @context.PaymentMethod
                            </MudTd>
                            <MudTd DataLabel="@Localizer["Discount"]" Style="text-align: center;">
                                <MudText Typo="Typo.body2" Color="Color.Success">@context.TotalDiscount?.ToString("N2")</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["Void"]" Style="text-align: center;">
                                <MudText Typo="Typo.body2" Color="Color.Error">@context.VoidAmount?.ToString("N2")</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["GrandTotal"]" Style="text-align: center;">
                                <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight: 900;">@context.GrandTotal?.ToString("N2")</MudText>
                            </MudTd>
                            <MudTd Style="text-align: center;">
                                <MudTooltip Text="@Localizer["Print"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.LocalPrintshop" 
                                                   Color="Color.Default" 
                                                   Size="Size.Small" 
                                                   OnClick="@(() => OpenOrderReceipt(context))" 
                                                   Class="hover-btn" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
                
                <div class="summary-cards-section d-flex gap-2 mb-2 px-4">
                    <div class="summary-card gold flex-1 pa-2 rounded-lg d-flex flex-column align-center border shadow-sm" style="background: #fffcf0;">
                        <MudText Style="font-size: 0.7rem; font-weight: 800; color: #b8860b; text-transform: uppercase;">@Localizer["CashAmount"]</MudText>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 900; color: #b8860b;">@Orders.Where(o => o.PaymentMethod == PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0).ToString("N2")</MudText>
                    </div>
                    
                    <div class="summary-card blue flex-1 pa-2 rounded-lg d-flex flex-column align-center border shadow-sm" style="background: #f0f7ff;">
                        <MudText Style="font-size: 0.7rem; font-weight: 800; color: #1e88e5; text-transform: uppercase;">@Localizer["CreditAmount"]</MudText>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 900; color: #1e88e5;">@Orders.Where(o => o.PaymentMethod != PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0).ToString("N2")</MudText>
                    </div>
                    
                    <div class="summary-card green flex-1 pa-2 rounded-lg d-flex flex-column align-center highlight-total border shadow-sm" style="background: linear-gradient(135deg, #43a047 0%, #2e7d32 100%);">
                        <MudText Style="font-size: 0.7rem; font-weight: 800; color: white; text-transform: uppercase;">@Localizer["GrandTotal"]</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight: 900; color: white;">@Orders.Sum(o => o.GrandTotal ?? 0).ToString("N2")</MudText>
                        <div class="shine-effect"></div>
                    </div>
                </div>
            }
        </div>
    </DialogContent>

    <DialogActions>
        <div class="pa-4 w-100 border-t elevation-1">
            <MudButton Variant="MudBlazor.Variant.Filled"
                       Color="Color.Error" 
                       FullWidth="true" 
                       OnClick="Close" 
                       Class="rounded-xl py-3"
                       Style="font-weight: 900; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(244,67,54,0.3);">
                @Localizer["Close"]
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .modern-staff-dialog .mud-dialog-content { padding: 0 !important; overflow: hidden !important; }
    .user-avatar-container { border: 3px solid #fff; border-radius: 50%; padding: 2px; background: #eee; }
    .dialog-header-premium { background: #fdfdfd; }
    .glass { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); }
    .border-b { border-bottom: 2px solid #f0f2f5; }
    .text-muted { color: #8898aa; }
    
    .table-wrapper { background: white; display: flex; flex-direction: column; }
    .compact-table .mud-table-head { background: #f8f9fa ! IMPORTANT; }
    
    .summary-card { position: relative; overflow: hidden; border: 1px solid rgba(0,0,0,0.05); }
    .min-w-150 { min-width: 150px; }
    .summary-card.gold { background: #fffcf0; }
    .summary-card.blue { background: #f0f7ff; }
    .summary-card.green { background: linear-gradient(135deg, #43a047 0%, #2e7d32 100%); border: none; }
    .uppercase-bold { text-transform: uppercase; font-weight: 800; letter-spacing: 1px; color: #777; margin-bottom: 4px; }
    .highlight-total { box-shadow: 0 8px 20px rgba(46,125,50,0.3); transform: scale(1.02); }
    
    .shine-effect {
        position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        animation: shine 3s infinite;
    }
    
    @@keyframes shine {
        0% { left: -100%; }
        20% { left: 100%; }
        100% { left: 100%; }
    }
    
    @@keyframes pulse-b {
        0% { box-shadow: 0 0 0 0 rgba(33,150,243,0.4); }
        70% { box-shadow: 0 0 0 10px rgba(33,150,243,0); }
        100% { box-shadow: 0 0 0 0 rgba(33,150,243,0); }
    }
    .pulse-button { animation: pulse-b 2s infinite; }
    
    .hover-btn:hover { background: #eee; transform: translateY(-2px); transition: all 0.2s; }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string StaffId { get; set; } = "";
    [Parameter] public string StaffName { get; set; } = "";
    [Parameter] public string StaffType { get; set; } = "Cashier";
    [Parameter] public DateTime SelectedDate { get; set; }
    [Parameter] public List<OrderDto> Orders { get; set; } = new();

    private bool _isLoading = false;

    private void Close() => MudDialog.Close();

    private Color GetOrderTypeColor(string? type) => type switch {
        "DineIn" => Color.Primary,
        "Delivery" => Color.Warning,
        "TakeAway" => Color.Success,
        _ => Color.Default
    };

    private async Task OpenOrderReceipt(OrderDto order)
    {
        try 
        {
            var parameters = new MudBlazor.DialogParameters { ["Order"] = order, ["PreviewMode"] = "Customer" };
            var options = new MudBlazor.DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
            DialogService.Show<global::BackOffice.Desktop.Components.Pages.Transactions.OrderReceiptPreviewDialog>("", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["Error"] + ": " + ex.Message, Severity.Error);
        }
    }

    private async Task PrintStaffReport(bool showOrders = true)
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["ReportTitle"] = Localizer.GetCurrentLanguage() == "ar" ? $"تقرير مبيعات: {StaffName}" : $"Sales Report: {StaffName}",
                ["BranchName"] = _commonProperties.BranchDetails?.Name ?? "Main Branch",
                ["ReportDate"] = SelectedDate,
                ["InitialShowOrderDetails"] = showOrders,
                ["IsStaffReport"] = true,
                ["Items"] = Orders.SelectMany(o => o.OrderDetails ?? new List<TableItem>())
                                  .GroupBy(i => i.Name)
                                  .Select(g => new SalesItemSummaryDto 
                                  { 
                                      ItemName = g.Key ?? string.Empty,
                                      Quantity = g.Sum(x => x.Quantity),
                                      TotalAmount = g.Sum(x => (x.Price ?? 0) * x.Quantity)
                                  }).ToList(),
                ["SummaryData"] = new SalesSummaryDto
                {
                    PosDate = SelectedDate,
                    StaffName = StaffName,
                    DetailedOrders = Orders,
                    Overall = new OverallSummaryDto
                    {
                        TotalSales = Orders.Sum(o => o.GrandTotal ?? 0),
                        CashAmount = Orders.Where(o => o.PaymentMethod == PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0),
                        CreditAmount = Orders.Where(o => o.PaymentMethod != PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0),
                        TotalDiscount = Orders.Sum(o => o.TotalDiscount ?? 0),
                        VoidAmount = Orders.Sum(o => (o.VoidAmount ?? (o.OrderState == "Voided" ? o.GrandTotal : 0) ?? 0)),
                        VoidCount = Orders.Count(o => (o.VoidAmount ?? 0) > 0 || o.OrderState == "Voided"),
                        ModeDetails = Orders.GroupBy(o => o.OrderType).Select(g => new ModeDetails {
                            ModeTitle = g.Key ?? "N/A",
                            OrderCount = g.Count(),
                            Subtotal = g.Sum(x => x.SubTotal ?? (x.GrandTotal ?? 0)),
                            Discount = g.Sum(x => x.TotalDiscount ?? 0),
                            GrandTotal = g.Sum(x => x.GrandTotal ?? 0)
                        }).ToList()
                    },
                    CashierSummaries = new List<AccountSummaryDto> {
                        new AccountSummaryDto {
                            Name = StaffName,
                            OrderCount = Orders.Count,
                            CashAmount = Orders.Where(o => o.PaymentMethod == PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0),
                            CreditAmount = Orders.Where(o => o.PaymentMethod != PaymentMethod.Cash).Sum(o => o.GrandTotal ?? 0),
                            DiscountAmount = Orders.Sum(o => o.TotalDiscount ?? 0),
                            VoidAmount = Orders.Sum(o => (o.VoidAmount ?? (o.OrderState == "Voided" ? o.GrandTotal : 0) ?? 0))
                        }
                    }
                }
            };
            
            var options = new MudBlazor.DialogOptions { FullScreen = true, CloseButton = false, NoHeader = true };
            await DialogService.ShowAsync<ReportPreviewDialog>("", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error preparing preview: " + ex.Message, Severity.Error);
        }
    }
}
