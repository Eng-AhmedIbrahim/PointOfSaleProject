@inject LocalizationService Localizer
@inject IDialogService DialogService
@inject CommonProperties _commonProperties
@inject ISnackbar Snackbar

<MudDialog Class="modern-items-dialog pa-4" Style="direction: rtl; font-family: 'Tajawal', sans-serif; border-radius: 20px; max-height: 90vh;">
    <TitleContent>
        <div class="dialog-header-premium glass pa-4 border-b">
            <div class="d-flex align-center justify-space-between w-100 flex-wrap gap-2">
                <div class="d-flex align-center gap-4">
                    <div class="stats-icon-wrapper shadow-sm">
                        <MudAvatar Color="Color.Primary" Variant="MudBlazor.Variant.Filled" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                        </MudAvatar>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 900; color: #1e3a5f;">@Localizer["SalesItemsSummary"]</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">
                            <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Small" /> @_commonProperties.StoreName | 
                            <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" /> @Items.Count @Localizer["Items"]
                        </MudText>
                    </div>
                </div>
                
                <MudButton Variant="MudBlazor.Variant.Filled"
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Print" 
                           OnClick="PrintItemsReport" 
                           Class="rounded-pill px-6"
                           Style="height: 48px; font-weight: 800; font-size: 1rem; box-shadow: 0 4px 12px rgba(33,150,243,0.3);">
                    @(Localizer.GetCurrentLanguage() == "ar" ? "طباعة التقرير" : "Print Report")
                </MudButton>
            </div>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="items-content-body d-flex flex-column" style="height: 60vh; overflow: hidden; padding: 15px;">
            <div class="table-scroll-area flex-grow-1 overflow-auto border rounded-xl shadow-sm glass">
                <MudTable Items="@Items" 
                           Hover="true" 
                           Dense="true" 
                           Elevation="0" 
                           Height="100%" 
                           FixedHeader="true" 
                           Class="custom-items-table">
                    <HeaderContent>
                        <MudTh Style="background: #f8fafc; font-weight: 800; text-align: right; padding: 16px;">@Localizer["ItemName"]</MudTh>
                        <MudTh Style="background: #f8fafc; font-weight: 800; text-align: center; padding: 16px;">@Localizer["Quantity"]</MudTh>
                        <MudTh Style="background: #f8fafc; font-weight: 800; text-align: center; padding: 16px;">@Localizer["TotalAmount"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align: right; font-weight: 700; padding: 12px 16px;">@context.ItemName</MudTd>
                        <MudTd Style="text-align: center; padding: 12px 16px;">
                            <MudChip T="string" Color="Color.Info" Variant="MudBlazor.Variant.Text" Style="font-weight: 800;">@context.Quantity.ToString("0.##")</MudChip>
                        </MudTd>
                        <MudTd Style="text-align: center; padding: 12px 16px;">
                            <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight: 900;">@context.TotalAmount.ToString("0.##")</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="pa-6 w-100 border-t elevation-1">
            <MudButton Variant="MudBlazor.Variant.Filled"
                       Color="Color.Error" 
                       FullWidth="true" 
                       OnClick="Close" 
                       Class="rounded-xl py-4"
                       Style="font-weight: 900; font-size: 1.2rem; box-shadow: 0 6px 15px rgba(244,67,54,0.3);">
                @Localizer["Close"]
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .modern-items-dialog .mud-dialog-content { padding: 0 !important; overflow: hidden !important; background: #fdfdfd; }
    .dialog-header-premium { background: white; z-index: 10; position: relative; }
    .stats-icon-wrapper { background: #f0f7ff; padding: 2px; border-radius: 12px; border: 2px solid white; }
    .glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
    .border-b { border-bottom: 2px solid #f1f5f9; }
    .text-muted { color: #64748b; }
    
    .custom-items-table .mud-table-container { background: white !IMPORTANT; }
    .mud-table-row:hover { background-color: #f8fafc !important; }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<SalesItemSummaryDto> Items { get; set; } = new();

    private void Close() => MudDialog.Close();

    private async Task PrintItemsReport()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["ReportTitle"] = Localizer["SalesItemsSummary"],
                ["BranchName"] = _commonProperties.StoreName,
                ["ReportDate"] = DateTime.Today, // Should ideally pass from parent
                ["Items"] = Items
            };
            
            var options = new MudBlazor.DialogOptions { FullScreen = true, CloseButton = false, NoHeader = true };
            await DialogService.ShowAsync<ReportPreviewDialog>("", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error preparing preview: " + ex.Message, Severity.Error);
        }
    }
}
