@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject BlazorBase.Services.LocalizationService LocalizerService
@inject NavigationManager NavigationManager
@inject POS.Core.Services.Contract.PosFeatureServices.IPosFeatureSettingsService FeatureSettingsService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider
@using BackOffice.Desktop.Components.Transactions

<div class="top-nav-professional" dir="@(LocalizerService.GetCurrentLanguage() == "ar" ? "rtl" : "ltr")">
    <!-- Brand Section -->
    <div class="nav-brand">
        <div class="logo-container" @onclick='() => NavigateTo("/")' style="cursor: pointer;">
            <img src="images/Logo.png" alt="Logo" style="height: 50px; width: auto; object-fit: contain;" />
        </div>
    </div>

    <!-- Main Navigation Tabs -->
    <div class="nav-tabs-container">
        @if (_canViewDashboard)
        {
            <div class="tab-item @(ActiveTab == "dashboard" ? "active" : "")" @onclick='() => NavigateTo("/")'>
                <MudIcon Icon="@Icons.Material.Rounded.Dashboard" Size="Size.Small" Class="tab-icon" />
                <span class="tab-text">@LocalizerService["Dashboard"]</span>
            </div>
        }

        @if (_canManageSettings)
        {
            <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" ListClass="pa-2" PopoverClass="settings-menu-popover">
                <ActivatorContent>
                    <div class="tab-item @(ActiveTab == "settings" ? "active" : "")">
                        <MudIcon Icon="@Icons.Material.Rounded.Settings" Size="Size.Small" Class="tab-icon" />
                        <span class="tab-text">@LocalizerService["BasicSettings"]</span>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="dropdown-arrow" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    @if (_canManageCompany)
                    {
                        <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                            <ActivatorContent>
                                <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                    <div class="menu-item-content d-flex align-center gap-2">
                                        <span class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Rounded.Business" Size="Size.Small" /> 
                                            @LocalizerService["CompanySettings"]
                                        </span>
                                        <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                    </div>
                                </MudMenuItem>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem Href="/settings/company"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Domain" Size="Size.Small" /> @LocalizerService["CompanyManagement"]</div></MudMenuItem>
                                <MudMenuItem Href="/settings/branches"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Store" Size="Size.Small" /> @LocalizerService["Branches"]</div></MudMenuItem>
                            </ChildContent>
                        </MudMenu>
                    }
                    <MudDivider Class="my-2" />
                    @if (_canManageOrders)
                    {
                        <MudMenuItem Href="/settings/ordersettings"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Small" /> @LocalizerService["OrderSettings"]</div></MudMenuItem>
                    }
                    @if (_canManagePrinters)
                    {
                        <MudMenuItem Href="/settings/printersettings"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Print" Size="Size.Small" /> @LocalizerService["PrintSettings"]</div></MudMenuItem>
                    }
                    @if (_canManageSystem)
                    {
                        <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                            <ActivatorContent>
                                <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                    <div class="menu-item-content d-flex align-center gap-2">
                                        <span class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Rounded.SettingsApplications" Size="Size.Small" /> 
                                            @(LocalizerService.GetCurrentLanguage() == "ar" ? "إعدادات النظام" : "System Settings")
                                        </span>
                                        <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                    </div>
                                </MudMenuItem>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem Href="/settings/features"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.FeaturedPlayList" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "خصائص ومميزات السيستم" : "System Feature Settings")</div></MudMenuItem>
                            </ChildContent>
                        </MudMenu>
                    }
                    <MudDivider Class="my-2" />
                    @if (_canManageGeneralSettings)
                    {
                        <MudMenuItem><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Tune" Size="Size.Small" /> @LocalizerService["GeneralSettings"]</div></MudMenuItem>
                    }
                    @if (_canManagePosSettings)
                    {
                        <MudMenuItem><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.PointOfSale" Size="Size.Small" /> @LocalizerService["POSSettings"]</div></MudMenuItem>
                    }
                    <MudDivider Class="my-2" />

                    @if (_canSyncData)
                    {
                        <MudMenuItem Href="/settings/datasync"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Sync" Size="Size.Small" /> @LocalizerService["DataUpdate"]</div></MudMenuItem>
                    }

                    <MudDivider Class="my-2" />

                    @if (_canManageLanguageSettings)
                    {
                        <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                            <ActivatorContent>
                                <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                    <div class="menu-item-content d-flex align-center gap-2">
                                        <span class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Rounded.Language" Size="Size.Small" /> 
                                            @LocalizerService["Language"]
                                        </span>
                                        <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                    </div>
                                </MudMenuItem>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick='() => SetLanguage("ar")'><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Language" Size="Size.Small" /> العربية</div></MudMenuItem>
                                <MudMenuItem OnClick='() => SetLanguage("en")'><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Language" Size="Size.Small" /> English</div></MudMenuItem>
                            </ChildContent>
                        </MudMenu>
                    }
                </ChildContent>
            </MudMenu>
        }
        
        @if (_canManageBasicData)
        {
            <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" ListClass="pa-2" PopoverClass="settings-menu-popover">
                <ActivatorContent>
                    <div class="tab-item">
                        <MudIcon Icon="@Icons.Material.Rounded.Badge" Size="Size.Small" Class="tab-icon" />
                        <span class="tab-text">@LocalizerService["BasicData"]</span>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="dropdown-arrow" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                        <ActivatorContent>
                            <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                <div class="menu-item-content d-flex align-center gap-2">
                                    <span class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Rounded.Security" Size="Size.Small" /> 
                                        @LocalizerService["SecurityPermissions"]
                                    </span>
                                    <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                </div>
                            </MudMenuItem>
                        </ActivatorContent>
                        <ChildContent>
                            @if (_canManageUsers) { <MudMenuItem Href="/basicdata/users"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Small" /> @LocalizerService["Users"]</div></MudMenuItem> }
                            @if (_canManageRoles) { <MudMenuItem Href="/basicdata/roles"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.AdminPanelSettings" Size="Size.Small" /> @LocalizerService["Roles"]</div></MudMenuItem> }
                            @if (_canManagePermissions) { <MudMenuItem Href="/basicdata/permissions"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Policy" Size="Size.Small" /> @LocalizerService["Polices"]</div></MudMenuItem> }
                        </ChildContent>
                    </MudMenu>

                    @if (_canManageUsers) {
                        <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                            <ActivatorContent>
                                <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                    <div class="menu-item-content d-flex align-center gap-2">
                                        <span class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Rounded.Fastfood" Size="Size.Small" /> 
                                            @LocalizerService["WorkersMeals"]
                                        </span>
                                        <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                    </div>
                                </MudMenuItem>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem Href="/settings/workers-meals"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Settings" Size="Size.Small" /> @LocalizerService["WorkersMealsManagement"]</div></MudMenuItem>
                                <MudMenuItem Href="/basicdata/workers-meals-groups"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Category" Size="Size.Small" /> @LocalizerService["StaffMealGroups"]</div></MudMenuItem>
                            </ChildContent>
                        </MudMenu>
                        <MudDivider Class="my-2" />
                    }

                    <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.TopRight" ListClass="pa-2" PopoverClass="settings-menu-popover">
                        <ActivatorContent>
                            <MudMenuItem Class="px-3" Style="border-radius:12px;">
                                <div class="menu-item-content d-flex align-center gap-2">
                                    <span class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Rounded.ShoppingBasket" Size="Size.Small" /> 
                                        @LocalizerService["ItemsSettings"]
                                    </span>
                                    <MudIcon Icon="@(LocalizerService.GetCurrentLanguage() == "ar" ? Icons.Material.Rounded.ChevronLeft : Icons.Material.Rounded.ChevronRight)" Size="Size.Small" Class="text-muted" />
                                </div>
                            </MudMenuItem>
                        </ActivatorContent>
                        <ChildContent>
                            @if (_canManageItems) {
                                <MudMenuItem Href="/basicdata/classifications"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Class" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "أقسام الفئات" : "Category Classifications")</div></MudMenuItem>
                                <MudMenuItem Href="/basicdata/categories"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Category" Size="Size.Small" /> @LocalizerService["Categories"]</div></MudMenuItem>
                                <MudMenuItem Href="/basicdata/items"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.ShoppingBag" Size="Size.Small" /> @LocalizerService["SalesItems"]</div></MudMenuItem>
                                <MudMenuItem Href="/basicdata/attributes"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.ListAlt" Size="Size.Small" /> @LocalizerService["AttributesManagement"]</div></MudMenuItem>
                                <MudMenuItem Href="/basicdata/attribute/assignment"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Link" Size="Size.Small" /> @LocalizerService["AttributeAssignment"]</div></MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                    <MudDivider Class="my-2" />
                    @if (_canManageItems) {
                        <MudMenuItem Href="/basicdata/item/printerassignment"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Print" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "إعداد طباعة الأصناف" : "Item Printer Assignment")</div></MudMenuItem>
                        <MudMenuItem Href="/basicdata/category/printerassignment"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Print" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "إعداد طباعة الفئات" : "Category Printer Assignment")</div></MudMenuItem>
                    }
                    <MudDivider Class="my-2" />
                    @if (_canManageDelivery) {
                        <MudMenuItem Href="/basicdata/zones"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Map" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "مناطق التوصيل" : "Delivery Zones")</div></MudMenuItem>
                        <MudMenuItem Href="/basicdata/complaints"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.SupportAgent" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "شكاوى الكول سنتر" : "Call Center Complaints")</div></MudMenuItem>
                    }
                    <MudDivider Class="my-2" />
                    @if (_canManageTables) {
                        <MudMenuItem Href="/basicdata/tablegroups"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Layers" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "مجموعات الطاولات" : "Table Groups")</div></MudMenuItem>
                        <MudMenuItem Href="/basicdata/tables"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.TableBar" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "الطاولات" : "Tables")</div></MudMenuItem>
                    }
                    <MudDivider Class="my-2" />
                    
                    @if (_canManagePaymentMethods)
                    {
                        <MudMenuItem Href="/basicdata/paymentmethods"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.AccountBalanceWallet" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "طرق الدفع" : "Payment Methods")</div></MudMenuItem>
                    }
                    <MudMenuItem><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.MoreHoriz" Size="Size.Small" /> @LocalizerService["Miscellaneous"]</div></MudMenuItem>
                </ChildContent>
            </MudMenu>
        }

        @if (IsInventoryEnabled && _canManageInventory)
        {
            <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" ListClass="pa-2" PopoverClass="settings-menu-popover">
                <ActivatorContent>
                    <div class="tab-item @(ActiveTab == "inventory" ? "active" : "")">
                        <MudIcon Icon="@Icons.Material.Rounded.Warehouse" Size="Size.Small" Class="tab-icon" />
                        <span class="tab-text">@(LocalizerService.GetCurrentLanguage() == "ar" ? "المخازن" : "Inventory")</span>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="dropdown-arrow" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/basicdata/inventory"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Inventory" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "رصيد المخزن العام" : "General Stock")</div></MudMenuItem>
                    <MudDivider Class="my-2" />
                    @if (_canManageRawMaterials)
                    {
                        <MudMenuItem Href="/inventory/raw-materials"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Kitchen" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "إدارة المواد الخام" : "Raw Materials")</div></MudMenuItem>
                    }
                    @if (_canManageSemiFinished)
                    {
                        <MudMenuItem Href="/inventory/semi-finished"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Science" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "أصناف نصف مصنعة" : "Semi-Finished Items")</div></MudMenuItem>
                    }
                    @if (_canManageRecipes)
                    {
                        <MudMenuItem Href="/inventory/recipes"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.MenuBook" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "إدارة الريسيبي (BOM)" : "Recipe Management")</div></MudMenuItem>
                    }
                    <MudDivider Class="my-2" />
                    @if (_canManageUnits)
                    {
                        <MudMenuItem Href="/basicdata/units"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Straighten" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "تعريف الوحدات" : "Units Definition")</div></MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
        }

        @if (_canViewTransactions)
        {
            <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" ListClass="pa-2" PopoverClass="settings-menu-popover">
                <ActivatorContent>
                    <div class="tab-item @(ActiveTab == "transactions" ? "active" : "")">
                        <MudIcon Icon="@Icons.Material.Rounded.SwapHoriz" Size="Size.Small" Class="tab-icon" />
                        <span class="tab-text">@LocalizerService["Transactions"]</span>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="dropdown-arrow" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/transactions/accounts"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.AccountBalance" Size="Size.Small" /> @LocalizerService["Accounts"]</div></MudMenuItem>
                    <MudMenuItem Href="/transactions/expenses"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.Payments" Size="Size.Small" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "المصروفات والمدفوعات" : "Expenses & Payouts")</div></MudMenuItem>
                    <MudMenuItem Href="/transactions/summary"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.BarChart" Size="Size.Small" /> @LocalizerService["Summary"]</div></MudMenuItem>
                    <MudMenuItem Href="/transactions/all-orders"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.ListAlt" Size="Size.Small" /> @LocalizerService["AllOrders"]</div></MudMenuItem>
                    <MudDivider Class="my-2" />
                    <MudMenuItem OnClick="OpenEndOfDay"><div class="menu-item-content"><MudIcon Icon="@Icons.Material.Rounded.EventBusy" Size="Size.Small" Color="Color.Error" /> @(LocalizerService.GetCurrentLanguage() == "ar" ? "إنهاء يوم عمل مبيعات" : "Sales End Of Day")</div></MudMenuItem>
                </ChildContent>
            </MudMenu>
        }


        @if (_canViewReports)
        {
            <div class="tab-item @(ActiveTab == "reports" ? "active" : "")" @onclick='() => NavigateTo("/reports/overview")'>
                <MudIcon Icon="@Icons.Material.Rounded.Assessment" Size="Size.Small" Class="tab-icon" />
                <span class="tab-text">@LocalizerService["Reports"]</span>
            </div>
        }

        @if (_canViewRegistration)
        {
            <div class="tab-item">
                <MudIcon Icon="@Icons.Material.Rounded.AppRegistration" Size="Size.Small" Class="tab-icon" />
                <span class="tab-text">@LocalizerService["Registration"]</span>
            </div>
        }

        @if (_canViewClosing)
        {
            <div class="tab-item" @onclick="() => System.Environment.Exit(0)">
                <MudIcon Icon="@Icons.Material.Rounded.Lock" Size="Size.Small" Class="tab-icon" />
                <span class="tab-text">@LocalizerService["Closing"]</span>
            </div>
        }
    </div>

    <!-- User & Exit Section -->
    <div class="nav-actions">

        <div class="user-pill">
            <div class="user-avatar">@_userInitials</div>
            <span class="user-name">@_userName</span>
        </div>
        
        <div class="logout-action" @onclick="Logout" title="@(LocalizerService.GetCurrentLanguage() == "ar" ? "تسجيل الخروج" : "Logout")">
            <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Medium" />
        </div>
    </div>
</div>

@code {
    private string _userName = "";
    private string _userInitials = "AD";
    private string ActiveTab = "dashboard";
    private bool IsInventoryEnabled = false;
    private bool _canViewDashboard;
    private bool _canManageSettings;
    private bool _canManageCompany;
    private bool _canManageOrders;
    private bool _canManagePrinters;
    private bool _canManageSystem;
    private bool _canSyncData;
    private bool _canManageGeneralSettings;
    private bool _canManagePosSettings;
    private bool _canManageLanguageSettings;
    private bool _canManageBasicData;
    private bool _canManageUsers;
    private bool _canManageRoles;
    private bool _canManagePermissions;
    private bool _canManageItems;
    private bool _canManageDelivery;
    private bool _canManageTables;
    private bool _canManagePaymentMethods;
    private bool _canManageInventory;
    private bool _canManageRawMaterials;
    private bool _canManageSemiFinished;
    private bool _canManageRecipes;
    private bool _canManageUnits;
    private bool _canViewTransactions;
    private bool _canViewReports;
    private bool _canViewQueries;
    private bool _canViewRegistration;
    private bool _canViewClosing;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            _userName = user.Identity.Name ?? user.FindFirst("unique_name")?.Value ?? user.FindFirst("name")?.Value ?? (LocalizerService.GetCurrentLanguage() == "ar" ? "المدير العام" : "General Manager");
            
            try 
            {
                var parts = _userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 1)
                {
                    _userInitials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
                }
                else if (parts.Length == 1)
                {
                    _userInitials = parts[0].Length >= 2 ? parts[0].Substring(0, 2).ToUpper() : parts[0].ToUpper();
                }
            }
            catch { _userInitials = "AD"; }

            _canViewDashboard    = (await AuthorizationService.AuthorizeAsync(user, "CanViewDashboardAtBackOffice")).Succeeded;
            _canManageCompany     = (await AuthorizationService.AuthorizeAsync(user, "CanManageCompanySettingsAtBackOffice")).Succeeded;
            _canManageOrders      = (await AuthorizationService.AuthorizeAsync(user, "CanManageOrderSettingsAtBackOffice")).Succeeded;
            _canManagePrinters    = (await AuthorizationService.AuthorizeAsync(user, "CanManagePrinterSettingsAtBackOffice")).Succeeded;
            _canManageSystem      = (await AuthorizationService.AuthorizeAsync(user, "CanManageSystemFeaturesAtBackOffice")).Succeeded;
            _canSyncData          = (await AuthorizationService.AuthorizeAsync(user, "CanSyncDataAtBackOffice")).Succeeded;
            _canManageGeneralSettings = (await AuthorizationService.AuthorizeAsync(user, "CanManageGeneralSettingsAtBackOffice")).Succeeded;
            _canManagePosSettings      = (await AuthorizationService.AuthorizeAsync(user, "CanManagePosSettingsAtBackOffice")).Succeeded;
            _canManageLanguageSettings = (await AuthorizationService.AuthorizeAsync(user, "CanManageLanguageSettingsAtBackOffice")).Succeeded;

            _canManageUsers       = (await AuthorizationService.AuthorizeAsync(user, "CanManageUsersAtBackOffice")).Succeeded;
            _canManageRoles       = (await AuthorizationService.AuthorizeAsync(user, "CanManageRolesAtBackOffice")).Succeeded;
            _canManagePermissions = (await AuthorizationService.AuthorizeAsync(user, "CanManagePermissionsAtBackOffice")).Succeeded;
            _canManageItems       = (await AuthorizationService.AuthorizeAsync(user, "CanManageItemsAtBackOffice")).Succeeded;
            _canManageDelivery    = (await AuthorizationService.AuthorizeAsync(user, "CanManageZonesAtBackOffice")).Succeeded;
            _canManageTables      = (await AuthorizationService.AuthorizeAsync(user, "CanManageTablesAtBackOffice")).Succeeded;
            _canManagePaymentMethods = (await AuthorizationService.AuthorizeAsync(user, "CanManagePaymentMethodsAtBackOffice")).Succeeded;

            _canManageInventory   = (await AuthorizationService.AuthorizeAsync(user, "CanManageInventoryAtBackOffice")).Succeeded;
            _canManageRawMaterials = (await AuthorizationService.AuthorizeAsync(user, "CanManageRawMaterialsAtBackOffice")).Succeeded;
            _canManageSemiFinished = (await AuthorizationService.AuthorizeAsync(user, "CanManageSemiFinishedItemsAtBackOffice")).Succeeded;
            _canManageRecipes      = (await AuthorizationService.AuthorizeAsync(user, "CanManageRecipesAtBackOffice")).Succeeded;
            _canManageUnits        = (await AuthorizationService.AuthorizeAsync(user, "CanManageUnitsAtBackOffice")).Succeeded;

            _canViewTransactions  = (await AuthorizationService.AuthorizeAsync(user, "CanViewBackOfficeTransactionsAtBackOffice")).Succeeded;
            _canViewReports       = (await AuthorizationService.AuthorizeAsync(user, "CanViewBackOfficeReportsAtBackOffice")).Succeeded;
            _canViewQueries       = (await AuthorizationService.AuthorizeAsync(user, "CanViewQueriesAtBackOffice")).Succeeded;
            _canViewRegistration  = (await AuthorizationService.AuthorizeAsync(user, "CanViewRegistrationAtBackOffice")).Succeeded;
            _canViewClosing       = (await AuthorizationService.AuthorizeAsync(user, "CanViewClosingAtBackOffice")).Succeeded;

            _canManageSettings = _canManageCompany || _canManageOrders || _canManagePrinters || _canManageSystem || _canSyncData || _canManageGeneralSettings || _canManagePosSettings || _canManageLanguageSettings;
            _canManageBasicData = _canManageUsers || _canManageRoles || _canManagePermissions || _canManageItems || _canManageDelivery || _canManageTables || _canManagePaymentMethods;
        }

        IsInventoryEnabled = await FeatureSettingsService.IsFeatureEnabledAsync("EnableInventoryTracking");
        UpdateActiveTab();
        NavigationManager.LocationChanged += (s, e) => {
            UpdateActiveTab();
            InvokeAsync(StateHasChanged);
        };
    }

    private void UpdateActiveTab()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (string.IsNullOrEmpty(uri) || uri == "/") ActiveTab = "dashboard";
        else if (uri.Contains("settings")) ActiveTab = "settings";
        else if (uri.Contains("inventory") || uri.Contains("units")) ActiveTab = "inventory";
        else if (uri.Contains("transactions")) ActiveTab = "transactions";
        else if (uri.Contains("reports")) ActiveTab = "reports";
        else ActiveTab = "";
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo(path);
    }

    private async Task OpenEndOfDay()
    {
        var options = new MudBlazor.DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SalesEndOfDayDialog>(
            LocalizerService.GetCurrentLanguage() == "ar" ? "إنهاء يوم العمل" : "End Of Day", 
            options);
        
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            Snackbar.Add(LocalizerService["OperationSuccessful"], Severity.Success);
            NavigationManager.NavigateTo("/", true); // Force reload to refresh data/date
        }
    }

    private async Task Logout()
    {
        if (AuthStateProvider is BackOffice.Desktop.Auth.CustomAuthenticationStateProvider customAuthStateProvider)
        {
            await customAuthStateProvider.NotifyUserLogout();
        }
        
        await LocalStorage.RemoveItemAsync("authToken");
        await LocalStorage.RemoveItemAsync("AppSettingDTOList");
        await LocalStorage.RemoveItemAsync("CurrentUser");
        
        NavigationManager.NavigateTo("/login");
    }

    private async Task SetLanguage(string language)
    {
        if (LocalizerService.GetCurrentLanguage() == language) return;
        await LocalizerService.SetLanguage(language);
        NavigationManager.NavigateTo(NavigationManager.Uri, true);
    }

    private async Task ToggleLanguage()
    {
        var current = LocalizerService.GetCurrentLanguage();
        var newLang = current == "ar" ? "en" : "ar";
        await SetLanguage(newLang);
    }
}
