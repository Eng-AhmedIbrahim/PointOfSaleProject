@using Radzen
@using Radzen.Blazor
@using MudBlazor

<MudDialog Class="premium-mud-dialog">
    <DialogContent>
        <div class="premium-confirm-container" dir="@(IsArabic ? "rtl" : "ltr")">
            <div class="confirm-icon-section mb-6">
                <div class="pulse-ring"></div>
                <div class="icon-circle @StyleClass">
                    <RadzenIcon Icon="@Icon" />
                </div>
            </div>

            <div class="confirm-content px-6 text-center">
                <h2 class="confirm-title mb-2">@Title</h2>
                <p class="confirm-message">@Message</p>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="confirm-actions d-flex justify-content-center gap-3 mt-4 mb-6 w-100">
            <RadzenButton Click="@(() => MudDialog.Cancel())" 
                          Text="@CancelText" 
                          ButtonStyle="ButtonStyle.Light" 
                          Class="confirm-btn cancel" />
            
            <RadzenButton Click="@(() => MudDialog.Close(DialogResult.Ok(true)))" 
                          Text="@ConfirmText" 
                          ButtonStyle="ButtonStyle.Primary" 
                          Class="@($"confirm-btn confirm {StyleClass}")" />
        </div>
    </DialogActions>
</MudDialog>

<style>
    .premium-mud-dialog .mud-dialog-title { display: none; }
    .premium-mud-dialog .mud-dialog-content { padding: 0 !important; }
    
    .premium-confirm-container {
        padding: 3rem 1rem 1rem 1rem;
        background: white;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .confirm-icon-section {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 120px;
    }

    .icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        z-index: 2;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .icon-circle.info { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); color: white; }
    .icon-circle.danger { background: linear-gradient(135deg, #f43f5e 0%, #fb7185 100%); color: white; }
    .icon-circle.warning { background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%); color: white; }
    .icon-circle.success { background: linear-gradient(135deg, #10b981 0%, #34d399 100%); color: white; }

    .pulse-ring {
        position: absolute;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: currentColor;
        opacity: 0.2;
        animation: pulse-ring 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        z-index: 1;
    }

    .info .pulse-ring { background: #6366f1; }
    .danger .pulse-ring { background: #f43f5e; }
    .warning .pulse-ring { background: #f59e0b; }
    .success .pulse-ring { background: #10b981; }

    @@keyframes pulse-ring {
        0% { transform: scale(0.7); opacity: 0.5; }
        100% { transform: scale(1.3); opacity: 0; }
    }

    .confirm-title {
        font-weight: 800;
        color: #1e293b;
        font-size: 1.5rem;
        font-family: 'Outfit', 'Noto Sans Arabic', sans-serif;
    }

    .confirm-message {
        color: #64748b;
        font-size: 1.1rem;
        line-height: 1.5;
        max-width: 400px;
        font-family: 'Outfit', 'Noto Sans Arabic', sans-serif;
    }

    .confirm-btn {
        border-radius: 14px !important;
        height: 50px !important;
        min-width: 140px !important;
        font-weight: 700 !important;
        text-transform: none !important;
        font-size: 1rem !important;
        font-family: 'Outfit', 'Noto Sans Arabic', sans-serif;
    }

    .confirm-btn.confirm.info { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%) !important; border: none !important; color: white !important; }
    .confirm-btn.confirm.danger { background: linear-gradient(135deg, #f43f5e 0%, #fb7185 100%) !important; border: none !important; color: white !important; }
    .confirm-btn.confirm.warning { background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%) !important; border: none !important; color: white !important; }
    .confirm-btn.confirm.success { background: linear-gradient(135deg, #10b981 0%, #34d399 100%) !important; border: none !important; color: white !important; }

    .confirm-btn.cancel {
        background: #f1f5f9 !important;
        color: #475569 !important;
        border: 1px solid #e2e8f0 !important;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "تأكيد";
    [Parameter] public string Message { get; set; } = "هل أنت متأكد؟";
    [Parameter] public string ConfirmText { get; set; } = "نعم";
    [Parameter] public string CancelText { get; set; } = "إلغاء";
    [Parameter] public string Icon { get; set; } = "help_outline";
    [Parameter] public string StyleClass { get; set; } = "info"; // info, danger, warning, success
    [Parameter] public bool IsArabic { get; set; } = true;
}
