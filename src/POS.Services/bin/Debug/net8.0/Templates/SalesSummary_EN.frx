      <TextObject Name="InfoPrintDate" Left="450" Top="102" Width="258" Height="20" Text="Print Time: [DateTime.Now]" Format="Date" Format.Format="dd/MM/yyyy HH:mm" HorzAlign="Right" Font="Arial, 9pt"/>
    </ReportTitleBand>
    <DataBand Name="MainData" Top="143.2" Width="718.2" Height="580" DataSource="Summary">
