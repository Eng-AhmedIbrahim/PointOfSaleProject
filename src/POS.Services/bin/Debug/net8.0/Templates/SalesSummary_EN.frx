      <TextObject Name="TV2" Left="254" Top="58" Width="210" Height="20" Text="Net: [Summary.TakeAwayTotal]" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Center" Font="Arial, 11pt, style=Bold"/>
      <TextObject Name="BoxDel" Left="488" Top="10" Width="230" Height="80" Border.Lines="All" Fill.Color="240, 240, 240" Font="Arial, 10pt"/>
