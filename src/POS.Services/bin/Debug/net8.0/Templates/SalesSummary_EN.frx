      <TextObject Name="DelV2" Left="498" Top="58" Width="210" Height="20" Text="Net: [Summary.DeliveryTotal]" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Center" Font="Arial, 11pt, style=Bold"/>
      <TextObject Name="Sec1T" Left="159" Top="110" Width="400" Height="25" Border.Lines="All" Fill.Color="Black" Text="General Financial Summary" HorzAlign="Center" Font="Arial, 12pt, style=Bold" TextFill.Color="White"/>
      <TableObject Name="TblAccounting" Left="159" Top="135" Width="400" Height="150" Border.Lines="All">
        <TableColumn Width="200"/>
        <TableColumn Width="200"/>
        <TableRow Height="25">
          <TableCell Border.Lines="Bottom" Text="Gross Sales (Before Discount)" Padding="5, 0, 0, 5" HorzAlign="Left" Font="Arial, 10pt"/>
          <TableCell Border.Lines="Bottom" Text="[Summary.GrossSales]" Padding="0, 0, 10, 0" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Right" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Height="25">
          <TableCell Border.Lines="Bottom" Text="Total Discounts" Padding="5, 0, 0, 5" HorzAlign="Left" Font="Arial, 10pt"/>
          <TableCell Border.Lines="Bottom" Text="[Summary.TotalDiscount]" Padding="0, 0, 10, 0" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Right" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Height="25">
          <TableCell Border.Lines="Bottom" Text="Expenses" Padding="5, 0, 0, 5" HorzAlign="Left" Font="Arial, 10pt"/>
          <TableCell Border.Lines="Bottom" Text="[Summary.Expenses]" Padding="0, 0, 10, 0" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Right" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Height="25">
          <TableCell Border.Lines="Bottom" Text="Returns" Padding="5, 0, 0, 5" HorzAlign="Left" Font="Arial, 10pt"/>
          <TableCell Border.Lines="Bottom" Text="([Summary.SalesReturn])" Padding="0, 0, 10, 0" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Right" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Height="50">
          <TableCell Fill.Color="224, 224, 224" Text="Net Cash Revenue" Padding="5, 0, 0, 5" HorzAlign="Left" Font="Arial, 14pt, style=Bold"/>
          <TableCell Fill.Color="224, 224, 224" Text="[Summary.NetTotal]" Padding="0, 0, 10, 0" Format="Number" Format.UseLocale="true" Format.DecimalDigits="2" HorzAlign="Right" Font="Arial, 16pt, style=Bold"/>
        </TableRow>
      </TableObject>
      <TextObject Name="SecStat" Left="159" Top="300" Width="400" Height="25" Border.Lines="All" Fill.Color="Black" Text="Operational Statistics" HorzAlign="Center" Font="Arial, 11pt, style=Bold" TextFill.Color="White"/>
