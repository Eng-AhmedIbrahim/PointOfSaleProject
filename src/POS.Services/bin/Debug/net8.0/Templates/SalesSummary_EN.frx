    </TableDataSource>
    <Parameter Name="FromDate" DataType="System.String" AsString=""/>
    <Parameter Name="ToDate" DataType="System.String" AsString=""/>
    <Parameter Name="ReportTitle" DataType="System.String" AsString=""/>
    <Parameter Name="BranchName" DataType="System.String" AsString=""/>
    <Parameter Name="TotalItemsValue" DataType="System.String" AsString=""/>
  </Dictionary>
  <ReportPage Name="Page1" Watermark.Font="Arial, 60pt" LeftMargin="10" RightMargin="10" TopMargin="10" BottomMargin="10" FirstPageSource="15">
    <ReportTitleBand Name="HeaderBand" Width="718.2" Height="140">
