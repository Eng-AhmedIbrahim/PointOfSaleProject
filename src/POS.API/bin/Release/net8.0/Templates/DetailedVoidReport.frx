      <TextObject Name="B1" Left="518.2" Width="200" Height="35" Text="[VoidedItems.ItemName]" Padding="5, 0, 5, 0" VertAlign="Center" Font="Arial, 10.5pt, style=Bold" Border.Lines="All" Border.Color="Silver" RTL="true" HorzAlign="Right"/>
