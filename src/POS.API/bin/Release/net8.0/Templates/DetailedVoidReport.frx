      <TextObject Name="H5" Left="138.2" Width="100" Height="40" Text="بواسطة" HorzAlign="Center" VertAlign="Center" Font="Arial, 11pt, style=Bold" TextFill.Color="White" Border.Lines="All" Border.Color="White"/>
