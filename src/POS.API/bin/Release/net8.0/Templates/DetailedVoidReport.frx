<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="03/15/2026" ReportInfo.Modified="03/16/2026" ReportInfo.CreatorVersion="2024.2.0.0">
  <Dictionary>
    <TableDataSource Name="VoidedItems" ReferenceName="ReportData.VoidedItems" DataType="System.Int32" Enabled="true">
      <Column Name="OrderId" DataType="System.String"/>
      <Column Name="ItemName" DataType="System.String"/>
      <Column Name="Qty" DataType="System.Decimal"/>
      <Column Name="Total" DataType="System.Decimal"/>
      <Column Name="VoidReason" DataType="System.String"/>
      <Column Name="VoidByName" DataType="System.String"/>
      <Column Name="VoidTime" DataType="System.DateTime"/>
    </TableDataSource>
    <Parameter Name="FromDate" DataType="System.String"/>
    <Parameter Name="ToDate" DataType="System.String"/>
    <Parameter Name="BranchName" DataType="System.String"/>
  </Dictionary>
  <ReportPage Name="Page1" Watermark.Font="Arial, 60pt" RightToLeft="true">
    <ReportTitleBand Name="ReportTitleBand1" Width="718.2" Height="100">
      <TextObject Name="Text1" Width="718.2" Height="45" Text="تقرير المحذوفات (Void) التفصيلي للأصناف" HorzAlign="Center" VertAlign="Center" Font="Arial, 22pt, style=Bold" TextFill.Color="Maroon"/>
