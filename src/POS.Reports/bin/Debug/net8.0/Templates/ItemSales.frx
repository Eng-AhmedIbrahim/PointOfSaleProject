<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="03/12/2026" ReportInfo.Modified="03/14/2026 00:20:00" ReportInfo.CreatorVersion="2026.1.0.0">
  <Dictionary>
    <TableDataSource Name="ItemSales" ReferenceName="ReportData.ItemSales" DataType="System.Int32" Enabled="true">
      <Column Name="ItemId" DataType="System.Int32"/>
      <Column Name="ItemTitle" DataType="System.String"/>
      <Column Name="Category" DataType="System.String"/>
      <Column Name="Qty" DataType="System.Decimal"/>
      <Column Name="Price" DataType="System.Decimal"/>
      <Column Name="Total" DataType="System.Decimal"/>
      <Column Name="Unit" DataType="System.String"/>
    </TableDataSource>
    <Parameter Name="FromDate" DataType="System.String"/>
    <Parameter Name="ToDate" DataType="System.String"/>
    <Parameter Name="BranchName" DataType="System.String"/>
    <Total Name="TotalSales" Expression="[ItemSales.Total]" Evaluator="Data1" PrintOn="Summary1"/>
  </Dictionary>
  <ReportPage Name="Page1" Watermark.Font="Arial, 60pt" RightMargin="5" LeftMargin="5">
    <!-- HEADER -->
    <ReportTitleBand Name="HeaderBand" Width="756" Height="150">
      <!-- Title on the Left -->
      <TextObject Name="TBranch" Left="30" Top="20" Width="350" Height="25" Text="[BranchName]" Font="Arial, 14pt, style=Bold" HorzAlign="Center" VertAlign="Center"/>
      <TextObject Name="TTitle" Left="30" Top="50" Width="350" Height="40" Text="مبيعات الأصناف" Font="Arial, 22pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="Top, Bottom" Border.Width="1.5"/>
      
      <!-- Info Table on the Right -->
      <!-- Row 1 -->
      <TextObject Name="VBranchInfo" Left="456" Top="20" Width="200" Height="25" Text="[BranchName]" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="LBranchInfo" Left="656" Top="20" Width="100" Height="25" Text="إسم الفرع" Font="Arial, 11pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" RTL="true"/>
      <!-- Row 2 -->
      <TextObject Name="VDate" Left="456" Top="45" Width="200" Height="25" Text="[DateTime.Now]" Format="Date" Format.Format="dd/MM/yyyy hh:mm tt" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="LDate" Left="656" Top="45" Width="100" Height="25" Text="تاريخ الطباعة" Font="Arial, 11pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" RTL="true"/>
      <!-- Row 3 -->
      <TextObject Name="VFrom" Left="456" Top="70" Width="200" Height="25" Text="[FromDate]" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="LFrom" Left="656" Top="70" Width="100" Height="25" Text="من تاريخ" Font="Arial, 11pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" RTL="true"/>
      <!-- Row 4 -->
      <TextObject Name="VTo" Left="456" Top="95" Width="200" Height="25" Text="[ToDate]" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="LTo" Left="656" Top="95" Width="100" Height="25" Text="إلي تاريخ" Font="Arial, 11pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" RTL="true"/>
    </ReportTitleBand>

    <!-- TABLE HEADER -->
    <PageHeaderBand Name="PageHeader1" Top="155" Width="756" Height="30">
      <TextObject Name="HTotal"   Left="0" Top="0" Width="150" Height="30" Text="الإجمالي" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray"/>
      <TextObject Name="HQty"     Left="150" Top="0" Width="100" Height="30" Text="كمية" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray"/>
      <TextObject Name="HPrice"   Left="250" Top="0" Width="100" Height="30" Text="سعر الوحدة" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray"/>
      <TextObject Name="HName"    Left="350" Top="0" Width="336" Height="30" Text="إسم الصنف" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray" RTL="true"/>
      <TextObject Name="HID"      Left="686" Top="0" Width="70" Height="30" Text="رقم" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray"/>
    </PageHeaderBand>

    <!-- DATA -->
    <DataBand Name="Data1" Top="190" Width="756" Height="30" DataSource="ItemSales">
      <TextObject Name="VTotal"   Left="0" Top="0" Width="150" Height="30" Text="[ItemSales.Total]" Format="Custom" Format.Format="0.##" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="VQty"     Left="150" Top="0" Width="100" Height="30" Text="[ItemSales.Qty]" Format="Custom" Format.Format="0.##" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="VPrice"   Left="250" Top="0" Width="100" Height="30" Text="[ItemSales.Price]" Format="Custom" Format.Format="0.##" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
      <TextObject Name="VName"    Left="350" Top="0" Width="336" Height="30" Text="[ItemSales.ItemTitle]" Font="Arial, 11pt" HorzAlign="Right" VertAlign="Center" Padding="0,5,0,0" RTL="true" Border.Lines="All"/>
      <TextObject Name="VID"      Left="686" Top="0" Width="70" Height="30" Text="[ItemSales.ItemId]" Font="Arial, 11pt" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
    </DataBand>

    <!-- SUMMARY -->
    <ReportSummaryBand Name="Summary1" Top="225" Width="756" Height="40">
       <TextObject Name="VSum" Left="0" Top="0" Width="150" Height="30" Text="[TotalSales]" Format="Custom" Format.Format="0.##" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All"/>
       <TextObject Name="LSum" Left="150" Top="0" Width="100" Height="30" Text="الإجمالي" Font="Arial, 12pt, style=Bold" HorzAlign="Center" VertAlign="Center" Border.Lines="All" Fill.Color="LightGray"/>
    </ReportSummaryBand>

    <!-- FOOTER -->
    <PageFooterBand Name="PageFooterBand1" Top="270" Width="756" Height="35">
      <TextObject Name="TFoo" Left="0" Top="8" Width="756" Height="20" Text="تم استخراج التقرير بواسطة نظام إدارة المطاعم الذكي - صفحة [Page] من [TotalPages#]" Font="Arial, 9pt" HorzAlign="Center" RTL="true"/>
    </PageFooterBand>
  </ReportPage>
</Report>
