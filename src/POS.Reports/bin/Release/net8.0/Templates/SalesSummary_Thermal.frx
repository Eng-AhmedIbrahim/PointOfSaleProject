    <!-- ===== SOLD ITEMS ===== -->
    <DataHeaderBand Name="ItemsHeader" Top="870" Width="264.6" Height="45">
      <TextObject Name="HITitle" Left="0" Top="5" Width="264.6" Height="20"
                  Text="الأصناف المباعة" Font="Arial, 10pt, style=Bold" HorzAlign="Center"
                  Fill.Color="30,30,30" TextFill.Color="White" RTL="true"/>
      <TableObject Name="TbItmH" Left="0" Top="25" Width="264.6" Height="20" Border.Lines="All">
        <TableColumn Width="134.6"/> <!-- Item -->
        <TableColumn Width="50"/>   <!-- Qty -->
        <TableColumn Width="80"/>   <!-- Total -->
        <TableRow Height="20">
          <TableCell Text="الصنف" Font="Arial, 8pt, style=Bold" HorzAlign="Center" VertAlign="Center" Fill.Color="224,224,224" RTL="true"/>
          <TableCell Text="كمية" Font="Arial, 8pt, style=Bold" HorzAlign="Center" VertAlign="Center" Fill.Color="224,224,224" RTL="true"/>
          <TableCell Text="إجمالي" Font="Arial, 8pt, style=Bold" HorzAlign="Center" VertAlign="Center" Fill.Color="224,224,224" RTL="true"/>
