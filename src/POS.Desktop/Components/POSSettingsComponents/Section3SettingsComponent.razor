@inject IJSRuntime Js

<MudButton OnClick="OnExpandCollapseClick"
           Class="settings-section-btn"
           EndIcon="@(_expanded ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)">
    <MudText Class="section-btn-label">Section 3 (Actions)</MudText>
</MudButton>
<MudCollapse Class="pa-4" Expanded="_expanded">
    <MudStack Spacing="3">
        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Small" Color="Color.Primary" />
                <MudText Class="settings-group-title">Resize Keypad</MudText>
            </MudStack>
            <div class="settings-button-group">
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               OnClick="() => IncreaseSize(SpecialKeypadButton)"
                               Class="settings-control-btn" />
                <MudDivider Vertical="true" FlexItem="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                               OnClick="() => DecreaseSize(SpecialKeypadButton)"
                               Class="settings-control-btn" />
            </div>
        </div>

        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Small" Color="Color.Primary" />
                <MudText Class="settings-group-title">Resize Icons</MudText>
            </MudStack>
            <div class="settings-button-group">
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               OnClick="() => IncreaseSize(SpecialIconBtn)"
                               Class="settings-control-btn" />
                <MudDivider Vertical="true" FlexItem="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                               OnClick="() => DecreaseSize(SpecialIconBtn)"
                               Class="settings-control-btn" />
            </div>
        </div>

        <MudButton StartIcon="@Icons.Material.Filled.RestartAlt"
                   OnClick="Reset"
                   Variant="Variant.Outlined"
                   Class="settings-reset-btn">
            إعادة ضبط الافتراضات
        </MudButton>
    </MudStack>
</MudCollapse>


@code {
    bool _expanded = false;

    private void OnExpandCollapseClick()
    {
        _expanded = !_expanded;
    }

}


