@inject LocalizationService Localizer
@inject CommonProperties _commonProperties
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager _navigationManager
@inject ISnackbar _snackbar
@inject Section4ButtonsServices _section4ButtonsServices
@inject CartService _cartService

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="px-3 py-1">
    <div class="logo-container">
        <img src="/images/Logo.png" alt="Logo" class="navbar-logo" />
    </div>

    <MudStack Row="true" Spacing="2" Class="flex-grow-1">
        @if (canAccessTables)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.TableRestaurant"
                       Class="@( _commonProperties.CurrentPosMode == "DineIn" ? "btn-active" : "btn-nav")"
                       OnClick='() => SetMode(PosModes.DineIn.ToString())'>
                @Localizer["Tables"]
            </MudButton>
        }

        @if (canAccessDelivery)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.DeliveryDining"
                       Class="@( _commonProperties.CurrentPosMode == "Delivery" ? "btn-active" : "btn-nav")"
                       OnClick='() => SetMode(PosModes.Delivery.ToString())'>
                @Localizer["Delivery"]
            </MudButton>
        }

        @if (canAccessTakeAway)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.DirectionsRun"
                       Class="@( _commonProperties.CurrentPosMode == "TakeAway" ? "btn-active" : "btn-nav")"
                       OnClick='() => SetMode(PosModes.TakeAway.ToString())'>
                @Localizer["TakeAway"]
            </MudButton>
        }
    </MudStack>

    <MudSpacer />

    <MudStack Row="true" Spacing="2">
        @if (canAccessAccounts)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.AttachMoney"
                       Class="btn-nav">
                @Localizer["Accounts"]
            </MudButton>
        }

        @if (canAccessSummary)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.AreaChart"
                       Class="btn-nav">
                @Localizer["Summary"]
            </MudButton>
        }

        @if (canAccessDistribution)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.PushPin"
                       Class="btn-nav">
                @Localizer["Distribution"]
            </MudButton>
        }

        @if (canAccessOrders)
        {
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Checklist"
                       Class="btn-nav">
                @Localizer["AllOrders"]
            </MudButton>
        }

        <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" 
                       Variant="Variant.Filled"
                       Class="btn-exit"
                       OnClick="ExitApp" 
                       title="@Localizer["ExitApp"]" />
    </MudStack>
</MudStack>

<style>
    .navbar-logo {
        width: 45px;
        height: 45px;
        filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
        transition: transform 0.3s ease;
    }

    .navbar-logo:hover {
        transform: scale(1.1);
    }

    .btn-nav {
        background: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        text-transform: none !important;
        transition: all 0.3s ease !important;
    }

    .btn-nav:hover {
        background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%) !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(30, 136, 229, 0.3) !important;
    }

    .btn-active {
        background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%) !important;
        color: white !important;
        border-radius: 10px !important;
        font-weight: 700 !important;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
    }

    .btn-exit {
        background: rgba(229, 57, 53, 0.2) !important;
        color: #ffcdd2 !important;
        border: 1px solid rgba(229, 57, 53, 0.3) !important;
        border-radius: 10px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .btn-exit:hover {
        background: #e53935 !important;
        color: white !important;
        transform: rotate(90deg) scale(1.1);
        box-shadow: 0 0 15px rgba(229, 57, 53, 0.5) !important;
    }
</style>
