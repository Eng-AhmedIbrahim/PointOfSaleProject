@inject NavigationManager Navigation
@inject ICustomizationSettingsService CustomizationSettingsService

<MudDrawer @bind-Open="@Open" Anchor="@Anchor" Elevation="4" Variant="@DrawerVariant.Temporary"
           OverlayAutoClose="@OverlayAutoClose">
    <div class="settings-drawer-content" style="width: 350px; display: flex; flex-direction: column; height: 100%;">
        <MudDrawerHeader>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" />
                <MudText Typo="Typo.h6">@Title</MudText>
            </MudStack>
        </MudDrawerHeader>
        <div class="px-0 flex-grow-1 overflow-y-auto">
            <div class="pa-4 bg-light border-b mb-3">
                <MudText Typo="Typo.subtitle2" Class="mb-1 grey-text">Drawer Position</MudText>
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" FullWidth="true" Size="Size.Small">
                    <MudButton OnClick="() => SetAnchor(Anchor.Start)">Start</MudButton>
                    <MudButton OnClick="() => SetAnchor(Anchor.End)">End</MudButton>
                    <MudButton OnClick="() => SetAnchor(Anchor.Top)">Top</MudButton>
                    <MudButton OnClick="() => SetAnchor(Anchor.Bottom)">Bottom</MudButton>
                </MudButtonGroup>
            </div>

            <LocalizationSettingsComponent />

            @if (CurrentPageName.Equals(PagesNames.POS))
            {
                <Section3SettingsComponent/>
                <FinanceSettingsComponent/>
            }
        </div>

        <MudSpacer />
        <MudNavMenu>
            <MudNavLink OnClick="@CloseDrawer" Icon="@Icons.Material.Filled.Close" Class="close-drawer-link">إغلاق الإعدادات</MudNavLink>
        </MudNavMenu>
    </div>
</MudDrawer>



