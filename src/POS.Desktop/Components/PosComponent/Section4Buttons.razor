@inject LocalizationService Localizer
@using BlazorBase.ERPFrontServices.DineInOrderServices
@using BlazorBase.ERPFrontServices.OrderTrackServices
@using BlazorBase.ERPFrontServices.PrintOrderServices
@using POS.Desktop.Components.PosDialog
@inject CommonProperties _commonProperties
@inject Section4ButtonsServices _services
@inject NavigationManager _navigationManager
@inject ISnackbar _snackbar
@inject CartService _cartService
@inject AppDateService _appDateService
@inject IPrintOrderService _printOrderService
@inject IDialogService _dialogService
@inject IDineInOrderFrontService _dineInOrderService
@inject IOrderTrackFrontService _orderTrackService

<MudGrid Spacing="0" Justify="Justify.Center" Class="action-buttons-grid">
    <MudItem xs="4">
        <MudButton Variant="Variant.Filled"
                   FullWidth="true"
                   Class="action-btn cancel-btn special-sec4-button"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Cancel"
                   OnClick="()=>_services.RemoveAllItems(_commonProperties?.TableItems??[])">
            @Localizer["Cancel"]
        </MudButton>
    </MudItem>
    <MudItem xs="4">
        <MudButton Variant="Variant.Filled"
                   FullWidth="true"
                   Class="action-btn waiting-btn special-sec4-button"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.HourglassTop"
                   OnClick="AddOrderToWaitingQueue">
            @Localizer["Waiting"]
        </MudButton>
    </MudItem>
    <MudItem xs="4">
        <MudButton Variant="Variant.Filled"
                   FullWidth="true"
                   Class="action-btn print-btn special-sec4-button"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Print"
                   OnClick="PrintOrder">
            @Localizer["Print"]
        </MudButton>
    </MudItem>
    @* <MudItem xs="3">
        <MudButton Variant="Variant.Filled"
                   FullWidth="true"
                   Class="action-btn print-btn special-sec4-button"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.History"
                   OnClick="ReprintOrder">
            @Localizer["Reprint"]
        </MudButton>
    </MudItem> *@
</MudGrid>