@using BlazorBase.Services
@inject LocalizationService Localizer
@inject CommonProperties _commonProperties

<MudStack Spacing="4" Class="pa-4">
    <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #64748b;">@Localizer["Language"]</MudText>
    
    <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" FullWidth="true" Size="Size.Medium" Class="language-selector">
        <MudButton OnClick="@(() => ChangeLanguage("ar"))" 
                   Variant="@(_commonProperties.Language == "ar" ? Variant.Filled : Variant.Outlined)"
                   Class="lang-btn">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" />
                <MudText>@Localizer["Arabic"]</MudText>
            </MudStack>
        </MudButton>
        <MudButton OnClick="@(() => ChangeLanguage("en"))" 
                   Variant="@(_commonProperties.Language == "en" ? Variant.Filled : Variant.Outlined)"
                   Class="lang-btn">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" />
                <MudText>@Localizer["English"]</MudText>
            </MudStack>
        </MudButton>
    </MudButtonGroup>

    <MudDivider Class="my-3" />

    <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #64748b;">@Localizer["LayoutDirection"]</MudText>
    
    <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" FullWidth="true" Size="Size.Medium" Class="direction-selector">
        <MudButton OnClick="@(() => ChangeDirection(true))" 
                   Variant="@(_commonProperties.IsRtl ? Variant.Filled : Variant.Outlined)"
                   Class="dir-btn">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FormatTextdirectionRToL" Size="Size.Small" />
                <MudText>@Localizer["RightToLeft"]</MudText>
            </MudStack>
        </MudButton>
        <MudButton OnClick="@(() => ChangeDirection(false))" 
                   Variant="@(!_commonProperties.IsRtl ? Variant.Filled : Variant.Outlined)"
                   Class="dir-btn">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FormatTextdirectionLToR" Size="Size.Small" />
                <MudText>@Localizer["LeftToRight"]</MudText>
            </MudStack>
        </MudButton>
    </MudButtonGroup>
</MudStack>

<style>
    .language-selector, .direction-selector {
        border-radius: 12px;
        overflow: hidden;
    }

    .lang-btn, .dir-btn {
        text-transform: none !important;
        font-weight: 600;
        padding: 12px 16px;
    }
</style>

@code {
    private async Task ChangeLanguage(string language)
    {
        await Localizer.SetLanguage(language);
        _commonProperties.Language = language;
        StateHasChanged();
    }

    private void ChangeDirection(bool isRtl)
    {
        _commonProperties.IsRtl = isRtl;
        StateHasChanged();
    }
}
