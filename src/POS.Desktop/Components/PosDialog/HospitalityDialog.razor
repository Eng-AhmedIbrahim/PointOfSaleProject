@using MudBlazor
@using BlazorBase.ERPFrontServices.AccountServices
@using POS.Contract.Dtos.AccountDtos
@inject IAccountService AccountService
@inject LocalizationService Localizer

<MudDialog Class="hd-modern-container">
    <TitleContent>
        <div class="hd-header">
            <div class="hd-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Large" />
            </div>
            <div class="hd-title-text">
                <MudText Typo="Typo.h5" Class="hd-main-title">@Localizer["ConfirmHospitality"]</MudText>
                <MudText Typo="Typo.caption" Class="hd-subtitle">@Localizer["HospitalityInstructions"]</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="hd-content">
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <div class="hd-input-group">
                    <div class="hd-field-wrapper">
                        <MudAutocomplete T="UserDto" 
                                   Label="@Localizer["ResponsiblePerson"]"
                                   Value="_selectedUser" 
                                   SearchFunc="SearchUsers"
                                   Required="true"
                                   RequiredError="@Localizer["ResponsibleRequired"]"
                                   ToStringFunc="@(u => u?.ArabicName ?? u?.UserName ?? "")"
                                   Variant="Variant.Outlined"
                                   ResetValueOnEmptyText="true"
                                   ValueChanged="OnUserSelected"
                                   Adornment="Adornment.End"
                                   AdornmentIcon="@Icons.Material.Filled.Person"
                                   PopOverClass="hd-autocomplete-popover"
                                   Class="hd-input" />
                    </div>
                    
                    <div class="hd-field-wrapper mt-4">
                        <MudTextField @bind-Value="_reason" 
                                     Label="@Localizer["HospitalityReason"]" 
                                     Variant="Variant.Outlined" 
                                     Lines="3" 
                                     Required="true"
                                     RequiredError="@Localizer["ReasonRequired"]"
                                     Placeholder="@Localizer["EnterReasonPlaceholder"]"
                                     Class="hd-input" />
                    </div>
                </div>
            </MudForm>

            @if (_showError)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-4 hd-alert">
                    @Localizer["PleaseCheckInputData"]
                </MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="hd-actions">
            <MudButton OnClick="Cancel" 
                       Variant="Variant.Outlined" 
                       Class="hd-btn-secondary">
                @Localizer["Cancel"]
            </MudButton>
            <MudButton OnClick="Confirm" 
                       Color="Color.Primary" 
                       Variant="Variant.Filled" 
                       Class="hd-btn-primary">
                @Localizer["Confirm"]
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .hd-modern-container {
        border-radius: 24px !important;
        overflow: hidden;
    }

    .hd-header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 24px;
        background: linear-gradient(135deg, #4f46e5 0%, #3730a3 100%);
        color: white;
    }

    .hd-icon-box {
        width: 56px;
        height: 56px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
    }

    .hd-main-title {
        font-weight: 800 !important;
        letter-spacing: -0.5px;
    }

    .hd-subtitle {
        opacity: 0.9;
        font-weight: 500;
    }

    .hd-content {
        padding: 16px 24px;
        direction: rtl;
    }

    .hd-input {
        background: #f8fafc;
        border-radius: 12px;
    }

    .hd-input .mud-input-outlined-border {
        border-width: 2px !important;
        border-color: #e2e8f0 !important;
    }

    .hd-input.mud-input-focus .mud-input-outlined-border {
        border-color: #4f46e5 !important;
    }

    .hd-alert {
        border-radius: 12px !important;
    }

    .hd-actions {
        display: flex;
        gap: 12px;
        padding: 0 24px 24px 24px;
        width: 100%;
    }

    .hd-btn-primary {
        flex: 2;
        height: 52px !important;
        border-radius: 14px !important;
        font-weight: 700 !important;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2) !important;
    }

    .hd-btn-secondary {
        flex: 1;
        height: 52px !important;
        border-radius: 14px !important;
        font-weight: 600 !important;
        border-width: 2px !important;
    }

    .hd-autocomplete-popover {
        direction: rtl !important;
    }

    .hd-autocomplete-popover .mud-list-item-text {
        text-align: right !important;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private UserDto? _selectedUser;
    private string? _reason;
    private bool _showError = false;
    private List<UserDto> _users = new();
    private MudForm _form = default!;
    private bool _isValid;

    protected override async Task OnInitializedAsync()
    {
        _users = (await AccountService.GetUsers()).ToList();
    }

    private void OnUserSelected(UserDto user)
    {
        _selectedUser = user;
        _showError = false;
    }

    private async Task<IEnumerable<UserDto>> SearchUsers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _users;
        return _users.Where(u => 
            (u.UserName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.ArabicName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Confirm()
    {
        await _form.Validate();
        if (!_isValid || _selectedUser == null || string.IsNullOrWhiteSpace(_reason))
        {
            _showError = true;
            return;
        }

        MudDialog.Close(DialogResult.Ok((_selectedUser, _reason)));
    }
}
