@inject LocalizationService Localizer
@using MudBlazor
@inject CommonProperties _commonProperties

<MudDialog FullWidth="true" MaxWidth="MaxWidth.Small" Class="customer-info-dialog">
    <TitleContent>
        <div class="cid-header">
            <div class="cid-header-icon">
                <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:1.5rem; color:#fff;" />
            </div>
            <div>
                <div class="cid-header-title">@Localizer["CustomerData"]</div>
                <div class="cid-header-sub">@Localizer["FillCustomerInfo"]</div>
            </div>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="cid-body">
            <div class="cid-field-card">
                <div class="cid-field-icon" style="background: linear-gradient(135deg,#42a5f5,#1e88e5);">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Style="color:#fff; font-size:1.1rem;" />
                </div>
                <MudTextField @bind-Value="_commonProperties.CustomerName"
                              Label="@Localizer["CustomerName"]"
                              Variant="Variant.Text"
                              FullWidth="true"
                              Class="cid-textfield"
                              Immediate="true" />
            </div>

            <div class="cid-field-card">
                <div class="cid-field-icon" style="background: linear-gradient(135deg,#66bb6a,#43a047);">
                    <MudIcon Icon="@Icons.Material.Filled.Phone" Style="color:#fff; font-size:1.1rem;" />
                </div>
                <MudTextField @bind-Value="_commonProperties.CustomerPhone"
                              Label="@Localizer["PhoneNumber"]"
                              Variant="Variant.Text"
                              FullWidth="true"
                              Class="cid-textfield"
                              InputType="InputType.Telephone"
                              Immediate="true" />
            </div>

            <div class="cid-field-card">
                <div class="cid-field-icon" style="background: linear-gradient(135deg,#ffa726,#fb8c00);">
                    <MudIcon Icon="@Icons.Material.Filled.Notes" Style="color:#fff; font-size:1.1rem;" />
                </div>
                <MudTextField @bind-Value="_commonProperties.OrderNote"
                              Label="@Localizer["OrderNote"]"
                              Variant="Variant.Text"
                              FullWidth="true"
                              Class="cid-textfield"
                              Lines="2"
                              Immediate="true" />
            </div>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="cid-actions">
            <MudButton OnClick="Clear"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.ClearAll"
                       Class="cid-btn-clear">
                @Localizer["Clear"]
            </MudButton>
            <MudButton OnClick="Submit"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Class="cid-btn-save">
                @Localizer["Save"]
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    /* ─── Header ─── */
    .cid-header {
        display: flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, #1565c0, #1e88e5);
        margin: -16px -24px 0;
        padding: 18px 20px;
        border-radius: 4px 4px 0 0;
    }
    .cid-header-icon {
        width: 42px; height: 42px;
        background: rgba(255,255,255,0.18);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .cid-header-title {
        color: #fff;
        font-size: 1.05rem;
        font-weight: 700;
    }
    .cid-header-sub {
        color: rgba(255,255,255,0.75);
        font-size: 0.75rem;
    }

    /* ─── Body ─── */
    .cid-body {
        padding: 16px 4px 4px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .cid-field-card {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        background: #f8f9ff;
        border: 1px solid #e3e8ff;
        border-radius: 12px;
        padding: 10px 14px;
        transition: box-shadow 0.18s;
    }
    .cid-field-card:hover {
        box-shadow: 0 2px 10px rgba(30,136,229,0.12);
    }
    .cid-field-icon {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        margin-top: 4px;
    }
    .cid-textfield { flex: 1; }

    /* ─── Actions ─── */
    .cid-actions {
        display: flex;
        gap: 10px;
        padding: 8px 4px 4px;
        width: 100%;
    }
    .cid-btn-clear {
        border-radius: 10px !important;
        color: #757575 !important;
        border-color: #bdbdbd !important;
        flex: 1;
        height: 44px;
    }
    .cid-btn-save {
        background: linear-gradient(135deg, #1565c0, #1e88e5) !important;
        color: #fff !important;
        border-radius: 10px !important;
        font-weight: 700 !important;
        flex: 2;
        height: 44px;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private void Clear()
    {
        _commonProperties.CustomerName = string.Empty;
        _commonProperties.CustomerPhone = string.Empty;
        _commonProperties.OrderNote = string.Empty;
    }

    private void Submit()
        => _commonProperties.CustomerInfoDialogReference?.Close(DialogResult.Ok(true));
}
