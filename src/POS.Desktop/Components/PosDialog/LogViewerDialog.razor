@using POS.Desktop
@using MudBlazor
@using Microsoft.AspNetCore.Components

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-3 mb-n1"/>
            Debug Terminal (Real-time Logs)
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="background-color: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 8px; font-family: 'Consolas', monospace; height: 500px; overflow-y: auto; font-size: 0.85rem;">
            @foreach (var log in global::POS.Desktop.App.InMemoryLogs.AsEnumerable().Reverse())
            {
                <div style="margin-bottom: 4px; border-bottom: 1px solid #333; padding-bottom: 2px;">
                    <span style="color: #569cd6;">@(log.Length >= 10 ? log.Substring(0, 10) : log)</span>
                    <span style="color: @(log.Contains("EX:") ? "#f44336" : "#ce9178")">@(log.Length >= 10 ? log.Substring(10) : "")</span>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="ClearLogs" Color="Color.Warning" Variant="Variant.Outlined">Clear</MudButton>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private void Close() => MudDialog.Close();

    private void ClearLogs()
    {
        lock (global::POS.Desktop.App.InMemoryLogs)
        {
            global::POS.Desktop.App.InMemoryLogs.Clear();
        }
        StateHasChanged();
    }
}
