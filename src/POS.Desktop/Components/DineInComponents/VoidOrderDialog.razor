@using MudBlazor
@using BlazorBase.ERPFrontServices.DineInOrderServices
@using POS.Contract.Dtos.DineIn
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IDineInOrderFrontService DineInOrderFrontService

<MudDialog DisableSidePadding="true">
    <DialogContent>
        <MudGrid Class="pa-2" Style="height: 600px; overflow-y: hidden;">
            <!-- Left Side: Order Items Table -->
            <MudItem xs="6">
                <MudTable T="VoidItemModel" Items="@Items" Dense="true" Hover="true" Bordered="true" Striped="true" 
                          FixedHeader="true" Height="500px" 
                          @bind-SelectedItem="SelectedItem" OnRowClick="@((args) => OnRowClick(args))">
                    <HeaderContent>
                        <MudTh>Qty</MudTh>
                        <MudTh>Item Name</MudTh>
                        <MudTh>Price</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh>Void Qty</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Qty">@context.OriginalQuantity</MudTd>
                        <MudTd DataLabel="Item Name">@context.ItemName</MudTd>
                        <MudTd DataLabel="Price">@context.UnitPrice.ToString("F2")</MudTd>
                        <MudTd DataLabel="Total">@context.TotalAmount.ToString("F2")</MudTd>
                        <MudTd DataLabel="Void Qty" Style="@(context.QuantityToVoid > 0 ? "background-color: #ffcccc;" : "")">
                            @context.QuantityToVoid
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>

            <!-- Right Side: Numpad & Actions -->
            <MudItem xs="6">
                 <MudGrid>
                     <!-- Totals Display -->
                     <MudItem xs="12" Class="d-flex justify-center align-center flex-column pa-4">
                         <MudText Typo="Typo.h5" Color="Color.Error">Void Amount</MudText>
                         <MudText Typo="Typo.h3" Color="Color.Error">@TotalVoidAmount.ToString("F2")</MudText>
                     </MudItem>

                     <!-- Void All Button -->
                     <MudItem xs="12">
                         <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="VoidAll" Class="py-3">
                             Void All
                         </MudButton>
                     </MudItem>

                    <!-- Numpad -->
                    <MudItem xs="12">
                         <MudGrid Spacing="1">
                             @foreach (var key in new[] { "7", "8", "9", "4", "5", "6", "1", "2", "3", "0", "." })
                             {
                                 var keyLabel = key;
                                 <MudItem xs="4">
                                     <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true" Class="py-4"
                                                OnClick="@(() => OnNumpadClick(keyLabel))">
                                         @keyLabel
                                     </MudButton>
                                 </MudItem>
                             }
                             <MudItem xs="4">
                                 <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" Class="py-4" OnClick="Backspace">
                                     <MudIcon Icon="@Icons.Material.Filled.Backspace" />
                                 </MudButton>
                             </MudItem>
                         </MudGrid>
                    </MudItem>

                    <!-- Reason Input -->
                     <MudItem xs="12" Class="mt-2">
                         <MudTextField @bind-Value="Reason" Label="Reason (Required)" Variant="Variant.Outlined" Required="true" RequiredError="Reason is required!" />
                     </MudItem>

                     <!-- Action Buttons -->
                     <MudItem xs="6" Class="mt-2">
                         <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick="Save" StartIcon="@Icons.Material.Filled.Check">
                             Save
                         </MudButton>
                     </MudItem>
                     <MudItem xs="6" Class="mt-2">
                         <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" OnClick="Cancel" StartIcon="@Icons.Material.Filled.Close">
                             Close
                         </MudButton>
                     </MudItem>
                 </MudGrid>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>
