@using MudBlazor
@using BlazorBase.ERPFrontServices.DineInOrderServices
@inject ISnackbar _snackbar
@inject CommonProperties _commonProperties
@inject IDineInOrderFrontService _dineInOrderService
@inject LocalizationService Localizer

<MudDialog FullWidth="true" MaxWidth="MaxWidth.Small">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["VoidItems"] - @(IsDineIn ? OrderToVoid?.RelatedTableName : "Items")</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTable Items="@TargetItems" Hover="true" Dense="true" MaxHeight="300px" FixedHeader="true">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh>Void Qty</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.Quantity</MudTd>
                        <MudTd>
                            <MudNumericField T="int" Value="@GetVoidQuantity(GetVoidKey(context))" 
                                            ValueChanged="@(val => SetVoidQuantity(GetVoidKey(context), val))"
                                            Min="0" Max="@context.Quantity" Margin="Margin.Dense" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string" Label="@Localizer["VoidReason"]" @bind-Value="VoidReason" 
                             Required="true" RequiredError="@Localizer["ReasonRequired"]"
                             Lines="2" Variant="Variant.Outlined" Class="mt-2" />
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CloseDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="PerformVoid" 
                   Disabled="@(!CanVoid)" Size="Size.Large">
            @Localizer["VoidSelected"]
        </MudButton>
    </DialogActions>
</MudDialog>
