@using POS.Desktop.Components.DineInComponents

<MudDialog DisableSidePadding="true" Class="void-dialog-custom">
    <DialogContent>
        <MudGrid Class="pa-2 fill-height" Spacing="2" Style="height: 600px; background-color: #f1f5f9;">
            <!-- Left Side: Order Items Table -->
            <MudItem xs="8" Class="d-flex flex-column h-100">
                <div class="void-table-container elevation-2 rounded-lg bg-white flex-grow-1 d-flex flex-column overflow-hidden">
                    <div class="table-header-custom pa-2 d-flex align-center shrink-0">
                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="font-weight-bold">@_localizer["ItemsToVoid"]</MudText>
                    </div>
                    <MudTable T="VoidItemModel" Items="@Items" Dense="true" Hover="true" FixedHeader="true"
                              @bind-SelectedItem="SelectedItem" OnRowClick="OnRowClick"
                              Class="void-mud-table flex-grow-1 overflow-auto" Height="100%">
                        <HeaderContent>
                            <MudTh>@_localizer["Qty"]</MudTh>
                            <MudTh>@_localizer["ItemName"]</MudTh>
                            <MudTh>@_localizer["Price"]</MudTh>
                            <MudTh>@_localizer["Total"]</MudTh>
                            <MudTh Style="text-align: center;">@_localizer["VoidQty"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                             <MudTd DataLabel="@_localizer["Qty"]">@context.OriginalQuantity</MudTd>
                             <MudTd DataLabel="@_localizer["ItemName"]">@context.ItemName</MudTd>
                             <MudTd DataLabel="@_localizer["Price"]">@context.UnitPrice.ToString("N2")</MudTd>
                             <MudTd DataLabel="@_localizer["Total"]" Class="font-weight-bold">@context.TotalAmount.ToString("N2")</MudTd>
                             <MudTd DataLabel="@_localizer["VoidQty"]" Style="text-align: center;">
                                 <div class="@(context.QuantityToVoid > 0 ? "void-qty-badge active" : "void-qty-badge")">
                                     @context.QuantityToVoid
                                 </div>
                             </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudItem>

            <!-- Right Side: Numpad & Actions -->
            <MudItem xs="4" Class="d-flex flex-column h-100">
                
                <!-- Summary Section (Top) -->
                <div class="summary-area pa-2 rounded-lg bg-white elevation-2 mb-2 d-flex flex-column shrink-0">
                    <div class="d-flex justify-space-between align-center">
                         <MudText Typo="Typo.subtitle2" Class="opacity-75">@_localizer["SelectedToVoid"]</MudText>
                         <MudText Typo="Typo.h5" Color="Color.Error" Class="font-weight-black">@TotalVoidAmount.ToString("N2")</MudText>
                    </div>
                     <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" OnClick="VoidAll" 
                                Class="mt-1 py-1 rounded-pill font-weight-bold" StartIcon="@Icons.Material.Filled.DeleteForever" Size="Size.Small">
                        @_localizer["VoidAllItems"]
                    </MudButton>
                </div>

                <!-- Numpad Section (Middle - Grows) -->
                <div class="numpad-control pa-2 rounded-lg bg-white elevation-2 mb-2 flex-grow-1 d-flex flex-column justify-center">
                    <MudGrid Spacing="1" Class="flex-grow-1">
                        @{
                            var keys = new[] { "7", "8", "9", "4", "5", "6", "1", "2", "3", "0", ".", "C" };
                        }
                        @foreach (var key in keys)
                        {
                             <MudItem xs="4" Class="d-flex">
                                @if (key == "C")
                                {
                                     <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true" Class="numpad-btn" OnClick="ClearQuantity">
                                        <MudIcon Icon="@Icons.Material.Filled.Clear" />
                                    </MudButton>
                                }
                                else if (key == ".") // Using . as placeholder for Backspace based on original code structure logic
                                {
                                     <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" Class="numpad-btn" OnClick="Backspace">
                                        <MudIcon Icon="@Icons.Material.Filled.Backspace" />
                                    </MudButton>
                                }
                                else
                                {
                                    var k = key;
                                    <MudButton Variant="Variant.Filled" Color="Color.Default" FullWidth="true" Class="numpad-btn font-weight-bold title"
                                               OnClick="@(() => OnNumpadClick(k))">
                                        @k
                                    </MudButton>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                </div>

                <!-- Footer Actions (Bottom) -->
                <div class="reason-area rounded-lg bg-white pa-2 elevation-2 shrink-0">
                    <MudSelect T="string" Label="@_localizer["SelectReason"]" @bind-Value="SelectedReason" Variant="Variant.Outlined" Dense="true" Class="mb-2" Margin="Margin.Dense">
                        <MudSelectItem Value="@("MISTAKE")">@_localizer["MistakeOrder"]</MudSelectItem>
                        <MudSelectItem Value="@("CUSTOMER_CANCEL")">@_localizer["CustomerCanceled"]</MudSelectItem>
                        <MudSelectItem Value="@("KITCHEN_ISSUE")">@_localizer["KitchenIssue"]</MudSelectItem>
                        <MudSelectItem Value="@("OTHER")">@_localizer["Other"]</MudSelectItem>
                    </MudSelect>

                    @if (SelectedReason == "OTHER")
                    {
                        <MudTextField @bind-Value="CustomReason" Label="@_localizer["Reason"]" Variant="Variant.Outlined" FullWidth="true" Class="mb-2" Margin="Margin.Dense"/>
                    }
                    
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick="Save" 
                                   StartIcon="@Icons.Material.Filled.Check" Class="py-2 font-weight-bold rounded-lg action-btn" Size="Size.Small">
                            @_localizer["ConfirmVoid"]
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Default" FullWidth="true" OnClick="Cancel" 
                                   StartIcon="@Icons.Material.Filled.Close" Class="py-2 font-weight-bold rounded-lg action-btn" Size="Size.Small">
                            @_localizer["Cancel"]
                        </MudButton>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>

<style>
    .void-dialog-custom .mud-dialog-width-sm {
        max-width: 900px !important; 
        width: 100%;
        max-height: 90vh;
        overflow: hidden; 
    }
    
    .void-dialog-custom .mud-dialog-content {
        padding: 0 !important;
        overflow: hidden !important;
    }

    .table-header-custom {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
    }

    .void-qty-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        font-weight: 800;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
    }

    .void-qty-badge.active {
        background: #fee2e2;
        color: #ef4444;
        border-color: #fecaca;
        transform: scale(1.1);
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .numpad-btn {
        height: 100% !important;
        min-height: 48px;
        font-size: 1.2rem !important;
        font-weight: 700 !important;
        background: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 8px !important;
        box-shadow: none !important;
        color: #1e293b !important;
    }

    .numpad-btn:hover {
        background: #f1f5f9 !important;
        border-color: #3b82f6 !important;
    }

    .summary-area {
        border-left: 4px solid #ef4444;
    }

    .action-btn {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .void-mud-table {
        border: none !important;
    }

    .void-mud-table .mud-table-head {
        background: #f8fafc !important;
    }
    
    .shrink-0 {
        flex-shrink: 0;
    }
</style>
