@using MudBlazor
@inject ISnackbar _snackbar
@inject CommonProperties _commonProperties
@inject IDialogService _dialogService
@inject NavigationManager _navigationManager
@inject Section4ButtonsServices _section4ButtonsServices
@inject LocalizationService Localizer

<MudDialog FullWidth="true" MaxWidth="MaxWidth.Small" Style="direction: rtl; font-family: 'Tajawal', sans-serif;">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["MergeTables"]</MudText>
    </TitleContent>

    <DialogContent>
        <div style="max-height: 400px; overflow-y: auto; padding: 10px;">
            <MudText>@Localizer["SelectAtLeastTwoTablesToMerge"]</MudText>
            <MudGrid Spacing="2">
                @foreach (var table in _tables ?? new())
                {
                    <MudItem xs="6" sm="4">
                        <MudButton Size="Size.Large"
                                   Variant="Variant.Outlined"
                                   Class="@GetButtonClass(table)"
                                   Style="width: 100%; height: 80px; display: flex; flex-direction: column; align-items: center; justify-content: center;"
                                   OnClick="() => ToggleTableSelection(table)">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Filled.TableBar" Size="Size.Medium" Color="@(table.IsMigrated ? Color.Success : Color.Default)" />
                                <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@table.RelatedTableName</MudText>
                                <MudText Typo="Typo.caption">@Localizer["Total"]: @table.BasicOrderDetails!.Total?.ToString("N2")</MudText>
                            </MudStack>
                        </MudButton>
                    </MudItem>
                }
            </MudGrid>
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Outlined">@Localizer["Cancel"]</MudButton>
        <MudButton OnClick="MergeSelectedTables"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@IsMergeDisabled">
            @Localizer["Apply"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IDineInOrderFrontService _dineInOrderServiceFront { get; set; }
    private List<DineInOrderDetails> _tables = new();
    private HashSet<int> SelectedTableIds = new();
    public List<DineInOrderDetails> TablesToMigrates = new();

    protected override Task OnInitializedAsync()
    {
        if (_commonProperties.DineInOrdersDetails != null)
        {
            _tables = _commonProperties.DineInOrdersDetails.Values
                .SelectMany(x => x)
                .Where(x => !string.IsNullOrEmpty(x.RelatedTableName))
                .ToList();
        }
        return base.OnInitializedAsync();
    }

    private void ToggleTableSelection(DineInOrderDetails table)
    {
        if (table == null) return;

        if (SelectedTableIds.Contains(table.DatabaseId))
        {
            SelectedTableIds.Remove(table.DatabaseId);
            TablesToMigrates.Remove(table);
            table.IsMigrated = false;
        }
        else
        {
            SelectedTableIds.Add(table.DatabaseId);
            TablesToMigrates.Add(table);
            table.IsMigrated = true;
        }

        StateHasChanged();
    }

    private async Task MergeSelectedTables()
    {
        if (TablesToMigrates.Count < 2)
        {
            _snackbar.Add(Localizer["SelectAtLeastTwoTablesToMerge"], Severity.Warning);
            return;
        }

        // Primary is the one with the lowest DatabaseId (oldest)
        var primaryOrder = TablesToMigrates.OrderBy(o => o.DatabaseId).First();
        var secondaryOrders = TablesToMigrates.Where(o => o.DatabaseId != primaryOrder.DatabaseId).ToList();
        var secondaryOrderIds = secondaryOrders.Select(o => o.DatabaseId).ToList();

        var success = await _dineInOrderServiceFront.MergeDineInOrdersAsync(primaryOrder.DatabaseId, secondaryOrderIds);

        if (success)
        {
            _snackbar.Add(Localizer["TablesMergedSuccessfully"], Severity.Success);
            
            // Clear in-memory state to force refresh
            _commonProperties.CurrentDineInOrder = null;
            _commonProperties.TableId = 0;
            
            CloseDialog();
            _section4ButtonsServices.NotifyStateChanged();
            await SafeNavigateAsync("/dineIn");
        }
        else
        {
            _snackbar.Add(Localizer["ActionFailed"], Severity.Error);
        }
    }

    private async Task SafeNavigateAsync(string uri)
    {
        int maxRetries = 5;
        int currentRetry = 0;
        int delayMs = 50;

        while (currentRetry < maxRetries)
        {
            try
            {
                await Task.Delay(delayMs);
                if (_navigationManager != null && !string.IsNullOrEmpty(_navigationManager.Uri))
                {
                    await InvokeAsync(() => _navigationManager.NavigateTo(uri, forceLoad: false));
                    return;
                }
                else
                {
                    throw new InvalidOperationException("NavigationManager not yet initialized");
                }
            }
            catch (Exception ex)
            {
                currentRetry++;
                if (currentRetry >= maxRetries) 
                {
                    _snackbar.Add($"Navigation failed: {ex.Message}", Severity.Error);
                    return;
                }
                delayMs *= 2;
            }
        }
    }

    private bool IsMergeDisabled => SelectedTableIds.Count < 2;

    private string GetButtonClass(DineInOrderDetails table)
    {
        if (table == null)
            return "order-button";

        if (table.IsMigrated)
        {
            return "order-button merged";
        }

        return "order-button";
    }

    private void CloseDialog()
    {
        _commonProperties.DialogReference?.Close();
    }
}


<style>
    .merged {
        background-color: #ffcc00 !important;
        color: black !important;
        font-weight: bold;
    }

</style>