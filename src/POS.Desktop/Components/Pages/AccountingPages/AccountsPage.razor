@page "/accounts"
@layout MainLayout
@inject IReportingErpService ReportingService
@inject IAppDateService AppDateService
@inject LocalizationService Localizer
@inject CommonProperties _commonProperties
@inject ISnackbar Snackbar
@inject NavigationManager _navigationManager
@namespace POS.Desktop.Components.Pages.AccountingPages

<div class="accounts-container">
    <div class="accounts-header fade-in">
        <div class="title-section">
            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Class="mr-2" />
            <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer["AccountsSummary"]</MudText>
        </div>
        
        <div class="filter-section">
            <MudToggleGroup T="string" @bind-Value="_staffType" Outline="true" Delimiters="true" Dense="true" Rounded="true" Color="Color.Primary" SelectionMode="SelectionMode.SingleSelection" CheckMark="false">
                <MudToggleItem Value="@("Cashier")">@Localizer["Cashier"]</MudToggleItem>
                <MudToggleItem Value="@("Waiter")">@Localizer["Waiter"]</MudToggleItem>
                <MudToggleItem Value="@("Driver")">@Localizer["Driver"]</MudToggleItem>
            </MudToggleGroup>
            
            <MudDatePicker @bind-Date="_selectedDate" Label="@Localizer["SelectDate"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="ml-4" Style="width: 150px;" />
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadData" Class="ml-2">@Localizer["Refresh"]</MudButton>
        </div>
    </div>

    <div class="accounts-content glass fade-in">
        <MudTable Items="@_accounts" Hover="true" Dense="true" Loading="@_isLoading" Elevation="0" Height="calc(100vh - 280px)" FixedHeader="true" Class="custom-table" RowClassFunc="@((item, idx) => "table-row")">
            <HeaderContent>
                <MudTh>@Localizer["ID"]</MudTh>
                <MudTh>@Localizer["Name"]</MudTh>
                <MudTh>@Localizer["OrderCount"]</MudTh>
                <MudTh>@Localizer["Cash"]</MudTh>
                <MudTh>@Localizer["Credit"]</MudTh>
                <MudTh>@Localizer["OnAccount"]</MudTh>
                <MudTh>@Localizer["Total"]</MudTh>
                <MudTh>@Localizer["Actions"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Id</MudTd>
                <MudTd><b>@context.Name</b></MudTd>
                <MudTd>@context.OrderCount</MudTd>
                <MudTd Class="text-green">@context.CashAmount.ToString("N2")</MudTd>
                <MudTd Class="text-blue">@context.CreditAmount.ToString("N2")</MudTd>
                <MudTd Class="text-orange">@context.OnAccountAmount.ToString("N2")</MudTd>
                <MudTd><MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@context.TotalAmount.ToString("N2")</MudChip></MudTd>
                <MudTd>
                    @if (_canViewAccountDetails)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Info" Size="Size.Small" />
                    }
                    @if (_canPrintAccountReport)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Default" Size="Size.Small" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity:0.3" />
                    <MudText>@Localizer["NoDataFound"]</MudText>
                </div>
            </NoRecordsContent>
        </MudTable>
    </div>

    <div class="accounts-footer fade-in">
        <div class="footer-stat">
            <span class="label">@Localizer["TotalCash"]</span>
            <span class="value text-green">@_accounts.Sum(a => a.CashAmount).ToString("N2")</span>
        </div>
        <div class="footer-stat">
            <span class="label">@Localizer["TotalCredit"]</span>
            <span class="value text-blue">@_accounts.Sum(a => a.CreditAmount).ToString("N2")</span>
        </div>
        <div class="footer-stat">
            <span class="label">@Localizer["TotalOnAccount"]</span>
            <span class="value text-orange">@_accounts.Sum(a => a.OnAccountAmount).ToString("N2")</span>
        </div>
        <div class="footer-stat">
            <span class="label">@Localizer["GrandTotal"]</span>
            <span class="value">@_accounts.Sum(a => a.TotalAmount).ToString("N2")</span>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" OnClick="GoBack">@Localizer["Close"]</MudButton>
    </div>
</div>




