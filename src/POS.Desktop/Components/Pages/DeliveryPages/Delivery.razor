@page "/delivery"
@layout MainLayout
@inject CommonProperties _commonProperties
@inject IHttpClientFactory _httpClientFactory
@inject NavigationManager _navigationManager
@inject IDeliveryServices _deliveryServices
@inject IBranchService _branchService
@inject ISnackbar _snackbar
@inject IDialogService _dialogService
@inject HandelDeliveryInvocation _handelDeliveryInvocation
@inject LocalizationService Localizer

<link href="delivery.css" rel="stylesheet" />

<div dir="@_pageDirection" class="delivery-container fade-in" style="height: 100vh; overflow: hidden;">
<MudGrid Spacing="0" Class="delivery-grid" Style="height: 100%; display: flex; flex-wrap: nowrap;">
    <MudItem xs="12" sm="6" md="6" Class="d-flex flex-column border-r border-solid custom-border-color" Style="height: 100%;">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["CustomerDetails"]</MudText>
        <MudPaper Elevation="0" Class="rounded-0 p-4 overflow-y-auto overflow-x-hidden flex-grow-1" Style="height: 100%;">
            <MudGrid Spacing="2" Class="h-100">
                <!-- Row 1: Phone Numbers -->
                <MudItem xs="6">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.FirstPhoneNumber"
                                   Label="@Localizer["PrimaryPhone"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Phone"
                                   Class="premium-input"
                                   Immediate="true"
                                   FullWidth="true"
                                   @onkeydown="HandleKeyDown" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.SecondPhoneNumber"
                                   Label="@Localizer["SecondaryPhone"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Smartphone"
                                   Class="premium-input"
                                   Immediate="true"
                                   FullWidth="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudAutocomplete T="string"
                                     Label="@Localizer["Title"]"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.PersonAddAlt"
                                     Class="premium-input"
                                     PopoverClass="premium-popover"
                                     FullWidth="true"
                                     @bind-Value="_commonProperties!.CustomerDetails!.ClientTitle"
                                     SearchFunc="SearchTitles"
                                     Immediate="true"
                                     ResetValueOnEmptyText="true"
                                     Required="true"
                                     Strict="true" />
                </MudItem>

                <MudItem xs="6">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.CustomerName"
                                   Label="@Localizer["CustomerName"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Person"
                                   Class="premium-input"
                                   Immediate="true"
                                   FullWidth="true" />
                </MudItem>

                <MudItem xs="6">
                    <MudAutocomplete T="DeliveryZonesToReturnDto"
                                     Label="@Localizer["Zone"]"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Map"
                                     Class="premium-input"
                                     PopoverClass="premium-popover"
                                     FullWidth="true"
                                     Value="SelectedZone"
                                     ValueChanged="OnZoneChanged"
                                     SearchFunc="SearchZones"
                                     ToStringFunc="@(z => z?.ZoneName ?? "")"
                                     Immediate="true"
                                     ResetValueOnEmptyText="true"
                                     Required="true"
                                     Strict="false" />
                </MudItem>

                <!-- Row 4: Address -->
                <MudItem xs="12">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.ClientAddress"
                                   Label="@Localizer["Address"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.LocationCity"
                                   Class="premium-input"
                                   FullWidth="true"
                                   Lines="1">
                    </MudTextField>
                </MudItem>

                <!-- Row 5: Home, Floor, Flat -->
                <MudItem xs="4">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.HomeNumber"
                                   Label="@Localizer["HomeNumber"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Home"
                                   Class="premium-input"
                                   FullWidth="true" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.FloorNumber"
                                   Label="@Localizer["FloorNumber"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Stairs"
                                   Class="premium-input"
                                   FullWidth="true" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.FlatNumber"
                                   Label="@Localizer["FlatNumber"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Apartment"
                                   Class="premium-input"
                                   FullWidth="true" />
                </MudItem>

                <!-- Row 6: Notes -->
                <MudItem xs="12">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.AddressNote"
                                   Label="@Localizer["AddressNote"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.LocationSearching"
                                   Class="premium-input"
                                   FullWidth="true"
                                   Lines="1">
                    </MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.KitchenNote"
                                   Label="@Localizer["KitchenNote"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Kitchen"
                                   Class="premium-input"
                                   FullWidth="true"
                                   Lines="1">
                    </MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_commonProperties!.CustomerDetails!.ClientNote"
                                   Label="@Localizer["ClientNote"]"
                                   Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.NoteAdd"
                                   Class="premium-input"
                                   FullWidth="true"
                                   Lines="1">
                    </MudTextField>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Stats Footer Section - Moved below fields -->
        <!-- Stats Footer Section -->
        <div class="delivery-stats-footer" dir="rtl">
            <!-- Right Column (Dates & Receiver) -->
            <div class="stats-column">
                <div class="stat-item">
                    <span class="stat-label">@Localizer["FirstOrderDate"]</span>
                    <span class="stat-value">@(ToArabicNumerals(CustomerStats?.FirstOrderDate?.ToString("dd/MM/yyyy") ?? "-"))</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">@Localizer["LastOrderDate"]</span>
                    <span class="stat-value">@(ToArabicNumerals(CustomerStats?.LastOrderDate?.ToString("dd/MM/yyyy") ?? "-"))</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">@Localizer["LastReceiverName"]</span>
                    <span class="stat-value">@(CustomerStats?.LastReceiverName ?? "-")</span>
                </div>
            </div>
            
            <!-- Left Column (Counts & Averages) -->
            <div class="stats-column">
                <div class="stat-item">
                    <span class="stat-label">@Localizer["OrderCount"]</span>
                    <span class="stat-value">@(ToArabicNumerals((CustomerStats?.OrderCount ?? 0).ToString()))</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">@Localizer["OrderAverage"]</span>
                    <span class="stat-value">@(ToArabicNumerals((CustomerStats?.AverageOrderValue ?? 0).ToString("0.00")))</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">@Localizer["TotalOrdersAmount"]</span>
                    <span class="stat-value">@(ToArabicNumerals((CustomerStats?.TotalOrdersAmount ?? 0).ToString("0.00")))</span>
                </div>
            </div>
        </div>
    </MudItem>


    <!-- Section 2 -->

    <MudItem xs="12" sm="5" md="5" Class="d-flex flex-column border-r border-solid custom-border-color" Style="height: 100%;">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["Last10Orders"]</MudText>
        <MudPaper Elevation="0" Class="premium-card rounded-0 overflow-y-auto custom-scrollbar overflow-x-hidden flex-grow-1" Style="height: 100%;">
            @if (_orders == null || !_orders.Any())
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="empty-state-icon" />
                    <MudText Class="empty-state-text">@Localizer["NoOrdersFound"]</MudText>
                </div>
            }
            else
            {
                <MudTable T="CustomerOrder" Items="_orders" Hover="true" Dense="true" Class="modern-table" Elevation="0">
                    <HeaderContent>
                        <MudTh>@Localizer["OrderId"]</MudTh>
                        <MudTh>@Localizer["Date"]</MudTh>
                        <MudTh>@Localizer["Total"]</MudTh>
                        <MudTh>@Localizer["Status"]</MudTh>
                    </HeaderContent>

                    <RowTemplate Context="order">
                        <MudTd DataLabel="@Localizer["OrderId"]">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">#@order.OrderId</MudText>
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Date"]">
                            <MudText Typo="Typo.body2">@order.OrderDate.ToString("dd/MM/yyyy")</MudText>
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Total"]">
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #447cad;">@order.Total.ToString("0.00")</MudText>
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Status"]">
                            <span class="status-badge @GetStatusClass(order.Status)">
                                @Localizer[order.Status]
                            </span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>

    <!-- Section 3 -->
    <MudItem xs="12" sm="1" md="1" Class="d-flex flex-column" Style="height: 100%;">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["Actions"]</MudText>
        <MudPaper Elevation="0" Class="rounded-0 overflow-hidden flex-grow-1" Style="height: 100%;">
            <DeliveryButtons />
        </MudPaper>
    </MudItem>


</MudGrid>
</div>

<style>
    .full-height {
        height: calc(100vh - 41.59px) !important;
        max-height: calc(100vh - 41.59px) !important;
        box-sizing: border-box;
    }

    .full-width {
        width: 100%;
    }


    .total-field {
        font-weight: bold;
        color: #374151;
        background: #E5E7EB;
    }

    .full-height-Section2 {
        height: 100%;
        overflow: hidden;
    }


    .mud-input-label {
        font-size: 17px !important;
        font-weight: bold !important;
    }

</style>


@code {
    private List<string> ClientTitles = new List<string> { "Mr.", "Mrs.", "Ms.", "Dr." };

    // Customer Order Model
    public class CustomerOrder
    {
        public int Id { get; set; } // Database ID
        public int OrderId { get; set; } // Sequence number for display
        public DateTime OrderDate { get; set; }
        public decimal Total { get; set; }
        public string Status { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string? PhoneNumber { get; set; }
    }

    private List<CustomerOrder>? _orders = new();

    // Helper method to get status badge class
    private string GetStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "badge-pending",
            "completed" => "badge-completed",
            "cancelled" => "badge-cancelled",
            _ => "badge-pending"
        };
    }

    private Task<IEnumerable<string>> SearchTitles(string value, CancellationToken token)
    {
        if (CustomerTitles == null)
            return Task.FromResult(Enumerable.Empty<string>());

        var result = string.IsNullOrEmpty(value)
            ? CustomerTitles.Select(x => x.TitleName ?? string.Empty)
            : CustomerTitles.Where(x => x.TitleName != null && x.TitleName.Contains(value, StringComparison.OrdinalIgnoreCase))
                            .Select(x => x.TitleName ?? string.Empty);

        return Task.FromResult(result);
    }

    private Task<IEnumerable<DeliveryZonesToReturnDto>> SearchZones(string value, CancellationToken token)
    {
        var result = string.IsNullOrEmpty(value)
            ? Zones
            : Zones.Where(x => x.ZoneName != null && x.ZoneName.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(result);
    }

 
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (string.IsNullOrWhiteSpace(_commonProperties.CustomerDetails?.FirstPhoneNumber))
                return;

            // Show loading
            _snackbar.Add(Localizer["LoadingCustomerData"], Severity.Info);

            try
            {
                var client = await _deliveryServices.GetClientByPhoneNumberAsync(_commonProperties.CustomerDetails.FirstPhoneNumber);
                
                if (client == null || client.Id == 0)
                {
                    ClearCustomerDataExceptPhone();
                    CustomerStats = null;
                    _orders = new();
                    _snackbar.Add(Localizer["CustomerNotFound"], Severity.Warning);
                    return;
                }

                // Update UI with basic customer info first
                CustomerStats = client;
                
                // Set initial zone from the first address if available
                var firstAddr = client.CustomerAddresses?.FirstOrDefault();
                if (firstAddr != null)
                {
                    // Sync with latest data from master Zones list
                    var zoneSync = Zones?.FirstOrDefault(z => z.Id == firstAddr.DeliveryZoneId);
                    
                    SelectedZone = zoneSync ?? new DeliveryZonesToReturnDto
                    {
                        Id = firstAddr.DeliveryZoneId,
                        ZoneName = firstAddr.ZoneName,
                        DeliveryFee = firstAddr.DeliveryFee,
                        BranchId = firstAddr.BranchId,
                        ZoneBonus = firstAddr.ZoneBonus
                    };
                    
                    _commonProperties.CustomerDetails!.ZoneID = firstAddr.DeliveryZoneId;
                    _commonProperties.CustomerDetails.BranchId = firstAddr.BranchId;
                    _commonProperties.CustomerDetails.ZoneName = firstAddr.ZoneName;
                    _commonProperties.CustomerDetails.ZoneFees = zoneSync?.DeliveryFee ?? firstAddr.DeliveryFee;
                    _commonProperties.CustomerDetails.BranchName = firstAddr.BranchName;
                    _commonProperties.CustomerDetails.ZoneBonus = zoneSync?.ZoneBonus ?? firstAddr.ZoneBonus;
                }

                // Populate Last 10 Orders
                if (client.Last10Orders != null)
                {
                    _orders = client.Last10Orders.Select(o => new CustomerOrder
                    {
                        Id = o.Id,
                        OrderId = o.OrderId,
                        OrderDate = o.OrderDate ?? DateTime.MinValue,
                        Total = o.GrandTotal ?? 0,
                        Status = o.OrderState ?? "Pending",
                        CustomerName = o.CustomerName ?? "",
                        PhoneNumber = o.CustomerPhone
                    }).ToList();
                }
                else
                    _orders = new();

                await InvokeAsync(StateHasChanged);

                // Check for Active Order FIRST (if exists, show dialog before address selection)
                if (client.ActiveOrder != null)
                {
                    var parameters = new DialogParameters
                    {
                        { "ActiveOrder", client.ActiveOrder }
                    };

                    var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
                    var dialog = await _dialogService.ShowAsync<ActiveOrderDialog>(Localizer["ActiveOrderFound"], parameters, options);
                    var result = await dialog.Result;

                    if (!result!.Canceled && result.Data is bool shouldEdit && shouldEdit)
                    {
                        _snackbar.Add(Localizer["LoadingActiveOrder"], Severity.Info);
                        
                        // Load items into cart
                        if (client.ActiveOrder?.OrderDetails != null)
                        {
                            _commonProperties.TableItems = client.ActiveOrder.OrderDetails.Select(item => 
                            {
                                var cloned = item.Clone();
                                cloned.IsReadOnly = true;
                                return cloned;
                            }).ToList();

                            // Also sync AppendedItems to be empty initially
                            _commonProperties.AppendedTableItems?.Clear();
                            _commonProperties.VoidedTableItems?.Clear();
                        }
                        
                        // Set customer info
                        BackupCustomerDetails(client);
                        
                        // Set update mode
                        _commonProperties.OrderDto = client.ActiveOrder;
                        _commonProperties.UpdateDeliveryOrder = true;
                        _commonProperties.UpdateDineInOrder = false;
                        _commonProperties.CurrentPosMode = "Delivery";
                        
                        // Navigate to POS
                        _navigationManager.NavigateTo("/pos");
                        return;
                    }
                }

                // Then handle address selection
                if (client.CustomerAddresses?.Count > 1)
                {
                    var parameters = new DialogParameters
                    {
                        { "CustomerName", client.CustomerName },
                        { "PhoneNumber", _commonProperties.CustomerDetails.FirstPhoneNumber },
                        { "Addresses", client.CustomerAddresses.ToList() }
                    };

                    var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
                    _commonProperties.DialogReference = await _dialogService.ShowAsync<SelectAddressDialog>("Select Address", parameters, options);
                }
                else
                {
                    BackupCustomerDetails(client);
                }
            }
            catch (Exception ex)
            {
                _snackbar.Add($"{Localizer["Error"]}: {ex.Message}", Severity.Error);
                Console.WriteLine($"Error loading customer: {ex}");
            }
        }
    }

    private void ClearCustomerDataExceptPhone()
    {
        // Preserve current zone info if available
        var currentZoneId = _commonProperties.CustomerDetails?.ZoneID ?? 0;
        var currentZoneName = _commonProperties.CustomerDetails?.ZoneName;
        var currentZoneFees = _commonProperties.CustomerDetails?.ZoneFees ?? 0;
        var currentBranchId = _commonProperties.CustomerDetails?.BranchId ?? 0;
        var currentBranchName = _commonProperties.CustomerDetails?.BranchName;

        var phone = _commonProperties.CustomerDetails?.FirstPhoneNumber;
        _commonProperties.CustomerDetails = new BlazorBase.Models.DeliveryModels.CustomerDetails
        {
            FirstPhoneNumber = phone,
            ZoneID = currentZoneId,
            ZoneName = currentZoneName,
            ZoneFees = currentZoneFees,
            BranchId = currentBranchId,
            BranchName = currentBranchName
        };

        // Maintain SelectedZone UI state
        if (currentZoneId > 0)
        {
            SelectedZone = Zones.FirstOrDefault(z => z.Id == currentZoneId) ?? new DeliveryZonesToReturnDto
            {
                Id = currentZoneId,
                ZoneName = currentZoneName,
                DeliveryFee = currentZoneFees,
                BranchId = currentBranchId
            };
        }
        else
        {
            SelectedZone = null;
        }
    }

    private void BackupCustomerDetails(DeliveryCustomerToReturnDto client)
    {
        var clientAddress = client!.CustomerAddresses!.FirstOrDefault();
        if (clientAddress == null) return;

        _commonProperties.CustomerDetails!.FirstPhoneNumber = client.FirstPhoneNumber;
        _commonProperties.CustomerDetails.SecondPhoneNumber = client.SecondPhoneNumber;
        _commonProperties.CustomerDetails.CustomerName = client.CustomerName;
        _commonProperties.CustomerDetails.ClientTitle = client.ClientTitle;
        _commonProperties.CustomerDetails.FloorNumber = clientAddress.FloorNumber;
        _commonProperties.CustomerDetails.FlatNumber = clientAddress.FlatNumber;
        _commonProperties.CustomerDetails.HomeNumber = clientAddress.HomeNumber;
        _commonProperties.CustomerDetails.ClientAddress = clientAddress.ClientAddress;
        _commonProperties.CustomerDetails.AddressNote = clientAddress.AddressNote;
        _commonProperties.CustomerDetails.BranchName = clientAddress.BranchName;
        _commonProperties.CustomerDetails.ZoneName = clientAddress.ZoneName;
        _commonProperties.CustomerDetails.CustomerAddressId = clientAddress.Id;
        _commonProperties.CustomerDetails.ZoneID = clientAddress.DeliveryZoneId;
        _commonProperties.CustomerDetails.Id = clientAddress.DeliveryCustomerId;
        _commonProperties.CustomerDetails.BranchId = clientAddress.BranchId;
        
        // Use fee from address, but sync with current Zones list for latest price and bonus if possible
        _commonProperties.CustomerDetails.ZoneFees = clientAddress.DeliveryFee;
        _commonProperties.CustomerDetails.ZoneBonus = clientAddress.ZoneBonus;
        
        var zoneSync = Zones?.FirstOrDefault(z => z.Id == clientAddress.DeliveryZoneId);
        if (zoneSync != null)
        {
            if (zoneSync.DeliveryFee.HasValue)
                _commonProperties.CustomerDetails.ZoneFees = zoneSync.DeliveryFee.Value;
            
            if (zoneSync.ZoneBonus.HasValue)
                _commonProperties.CustomerDetails.ZoneBonus = zoneSync.ZoneBonus.Value;
        }

        SafeAddressSelected();
    }

    private string ToArabicNumerals(string input)
    {
        if (string.IsNullOrEmpty(input)) return input;
        return input.Replace('0', '٠').Replace('1', '١').Replace('2', '٢').Replace('3', '٣')
                    .Replace('4', '٤').Replace('5', '٥').Replace('6', '٦').Replace('7', '٧')
                    .Replace('8', '٨').Replace('9', '٩');
    }
}