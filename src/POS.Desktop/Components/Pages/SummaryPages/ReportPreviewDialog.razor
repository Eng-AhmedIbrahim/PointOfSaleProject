@code {
    [Parameter] public string ReportTitle { get; set; } = "";
    [Parameter] public string BranchName  { get; set; } = "";
    [Parameter] public DateTime ReportDate { get; set; } = DateTime.Today;
    [Parameter] public List<SalesItemSummaryDto> Items { get; set; } = new();
    [Parameter] public SalesSummaryDto SummaryData { get; set; } = new();
    [Parameter] public bool IsStaffReport { get; set; } = false;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private List<string> _printers = new();
    private bool _useA4 = false;
    private bool _isArabic = true;
    private bool _showOrderDetails = true;
    private bool _onlyVoidDiscount = false;
    private bool _showStaffDetails = false;
    private bool _showVoidDiscountDetails = true;

    // Fallback: if Overall totals are 0, sum from detailed orders
    private decimal ActualVoidTotal =>
        SummaryData.Overall.VoidAmount > 0
            ? SummaryData.Overall.VoidAmount
            : (SummaryData.DetailedOrders?.Sum(o => o.VoidAmount ?? 0) ?? 0);

    private decimal ActualDiscountTotal =>
        SummaryData.Overall.TotalDiscount > 0
            ? SummaryData.Overall.TotalDiscount
            : (SummaryData.DetailedOrders?.Sum(o => o.TotalDiscount ?? 0) ?? 0);

    private IEnumerable<OrderDto> GetFilteredOrders() {
        if (SummaryData.DetailedOrders == null) return Enumerable.Empty<OrderDto>();
        var o = SummaryData.DetailedOrders.AsEnumerable();
        if (_onlyVoidDiscount) o = o.Where(x => (x.VoidAmount ?? 0) > 0 || (x.TotalDiscount ?? 0) > 0);
        return o;
    }

    [Parameter] public bool InitialShowOrderDetails { get; set; } = true;
    [Parameter] public bool InitialUseA4 { get; set; } = false;
    [Parameter] public bool InitialShowStaffDetails { get; set; } = false;
    
    protected override async Task OnInitializedAsync() {
        _isArabic = Localizer.GetCurrentLanguage() == "ar";
        _showOrderDetails = InitialShowOrderDetails;
        _useA4 = InitialUseA4;
        _showStaffDetails = InitialShowStaffDetails;
        _printers = await PrinterServices.GetInstalledPrinters();
    }

    private string GetPaperClass() => _useA4 ? "report-paper-a4" : "report-paper-cashier";
    private void Cancel() => MudDialog.Cancel();
    private async Task QuickPrint() => await PrintTo(null);
    private async Task PrintTo(string? p) {
        try {
            var d = new SalesSummaryDto { 
                PosDate = SummaryData.PosDate, 
                StaffName = SummaryData.StaffName, 
                StaffId = SummaryData.StaffId,
                Overall = SummaryData.Overall, 
                DineIn = SummaryData.DineIn,
                TakeAway = SummaryData.TakeAway,
                Delivery = SummaryData.Delivery,
                VoidEvents = SummaryData.VoidEvents,
                CashierSummaries = SummaryData.CashierSummaries,
                DetailedOrders = _showOrderDetails ? GetFilteredOrders().ToList() : new() 
            };
            if (IsStaffReport)
            {
                await PrintOrderService.PrintStaffPerformanceAsync(d, p, _useA4, _isArabic, _showOrderDetails, SummaryData.StaffId);
            }
            else
            {
                await PrintOrderService.PrintSalesSummaryAsync(d, Items, p, _useA4, _isArabic);
            }
            Snackbar.Add(_isArabic ? "تم الإرسال" : "Sent", Severity.Success);
            MudDialog.Close();
        } catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private List<VoidEventDto> GetExtractedVoids()
    {
        var extractedVoids = new List<VoidEventDto>();
        if (SummaryData.DetailedOrders != null)
        {
            foreach (var o in SummaryData.DetailedOrders)
            {
                var itemVoids = (o.OrderDetails ?? new List<global::POS.Contract.Models.TableItem>())
                                .Where(i => (i.VoidAmount ?? 0) > 0 || i.IsVoided).ToList();
                
                decimal sumItemVoids = 0;
                foreach (var iv in itemVoids)
                {
                    var amt = iv.VoidAmount ?? iv.Total ?? 0;
                    sumItemVoids += amt;
                    
                    var userName = !string.IsNullOrEmpty(iv.VoidByName) ? iv.VoidByName : (!string.IsNullOrEmpty(o.VoidByName) ? o.VoidByName : "System");
                    var reason = !string.IsNullOrEmpty(iv.VoidReason) ? iv.VoidReason : (!string.IsNullOrEmpty(o.VoidReason) ? o.VoidReason : "N/A");
                    
                    extractedVoids.Add(new VoidEventDto {
                        OrderId = o.OrderId,
                        OrderType = o.OrderType ?? "-",
                        VoidedByName = userName,
                        Reason = reason,
                        TotalVoidedAmount = amt
                    });
                }

                var orderVoidAmt = o.VoidAmount ?? (o.OrderState == "Voided" ? o.GrandTotal ?? 0 : 0);
                if (orderVoidAmt > sumItemVoids + 0.05m)
                {
                    extractedVoids.Add(new VoidEventDto {
                        OrderId = o.OrderId,
                        OrderType = o.OrderType ?? "-",
                        VoidedByName = !string.IsNullOrEmpty(o.VoidByName) ? o.VoidByName : "System",
                        Reason = !string.IsNullOrEmpty(o.VoidReason) ? o.VoidReason : "N/A",
                        TotalVoidedAmount = orderVoidAmt - sumItemVoids
                    });
                }
            }
        }

        return extractedVoids
            .GroupBy(v => v.OrderId)
            .Select(g => new VoidEventDto
            {
                OrderId = g.Key,
                OrderType = g.First().OrderType,
                VoidedByName = string.Join(" | ", g.Select(x => x.VoidedByName).Where(n => !string.IsNullOrEmpty(n) && n != "System").Distinct()),
                Reason = string.Join(" | ", g.Select(x => x.Reason).Where(r => !string.IsNullOrEmpty(r) && r != "N/A")),
                TotalVoidedAmount = g.Sum(x => x.TotalVoidedAmount)
            }).ToList();
    }
}
