    }
    .toolbar-left  { display: flex; align-items: center; gap: 10px; flex-wrap: nowrap; overflow-x: auto; }
    .toolbar-center { flex: 1; text-align: center; }
    .toolbar-right  { display: flex; align-items: center; }
    .toolbar-title  { font-size: 16px; font-weight: 800; color: #fff; white-space: nowrap; }
    .tb-btn { height: 36px !important; font-size: 13px !important; }
    .v-sep  { width: 1px; height: 28px; background: rgba(255,255,255,.25); margin: 0 4px; flex-shrink: 0; }
    .tg-wrap { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .tg-lbl  { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.75); white-space: nowrap; }

    /* ── Viewport ── */
    .report-viewport { flex: 1; overflow: hidden; position: relative; }
    .report-canvas-scroll {
        position: absolute; inset: 0;
        overflow-y: auto; padding: 36px 20px;
        display: flex; flex-direction: column; align-items: center;
        background: #37474f;
    }
    .shadow-2xl { box-shadow: 0 20px 60px rgba(0,0,0,.55); }

