@using BlazorBase.ERPFrontServices.PrintOrderServices
@inject IPrintOrderService PrintOrderService
@inject IPrinterServices PrinterServices
@inject ISnackbar Snackbar
@inject LocalizationService Localizer
@inject CommonProperties _commonProperties

@* dir is always LTR on the outer shell (toolbar items), paper content gets its own dir *@
<MudDialog Class="report-preview-dialog-container" Style="max-width:1200px;width:100vw;height:100vh;display:flex;flex-direction:column;overflow:hidden;">
    <DialogContent>
        <div class="preview-layout" dir="ltr">

            @* ══════════════ PREMIUM TOOLBAR ══════════════ *@
            <div class="premium-toolbar" dir="ltr">
                <div class="toolbar-content">
                    <div class="toolbar-section left">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="QuickPrint"
                                   StartIcon="@Icons.Material.Filled.FlashOn" Class="action-pill-btn shadow-glow">
                            @(_isArabic ? "طباعة سريعة" : "Quick Print")
                        </MudButton>

                        <MudMenu Label="@(_isArabic ? "اختر طابعة" : "Printer")"
                                 EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                 Color="Color.Info" Variant="Variant.Outlined" Class="action-pill-btn printer-selector">
                            @if (_printers.Any())
                            {
                                @foreach (var p in _printers)
                                {
                                    <MudMenuItem OnClick="@(() => PrintTo(p))">@p</MudMenuItem>
                                }
                            }
                            else
                            {
                                <MudMenuItem Disabled="true">@Localizer["NoPrintersFound"]</MudMenuItem>
                            }
                        </MudMenu>

                        <div class="toolbar-divider"></div>

                        <div class="settings-group">
                            <div class="setting-item">
                                <span class="setting-label">@(_isArabic ? "مقاس:" : "Size:")</span>
                                <MudToggleGroup T="bool" @bind-Value="_useA4" SelectionMode="SelectionMode.SingleSelection"
                                                Color="Color.Primary" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                    <MudToggleItem Value="false">80mm</MudToggleItem>
                                    <MudToggleItem Value="true">A4</MudToggleItem>
                                </MudToggleGroup>
                            </div>

                            <div class="setting-item">
                                <span class="setting-label">@(_isArabic ? "أوردرات:" : "Orders:")</span>
                                <MudToggleGroup T="bool" @bind-Value="_showOrderDetails" SelectionMode="SelectionMode.SingleSelection"
                                                Color="Color.Info" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                    <MudToggleItem Value="true">@(_isArabic ? "نعم" : "Yes")</MudToggleItem>
                                    <MudToggleItem Value="false">@(_isArabic ? "لا" : "No")</MudToggleItem>
                                </MudToggleGroup>
                            </div>

                            @if (_showOrderDetails)
                            {
                                <div class="setting-item">
                                    <span class="setting-label">@(_isArabic ? "فلتر:" : "Filter:")</span>
                                    <MudToggleGroup T="bool" @bind-Value="_onlyVoidDiscount" SelectionMode="SelectionMode.SingleSelection"
                                                    Color="Color.Warning" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                        <MudToggleItem Value="false">@(_isArabic ? "الكل" : "All")</MudToggleItem>
                                        <MudToggleItem Value="true">@(_isArabic ? "فويد/خصم" : "Void/Disc")</MudToggleItem>
                                    </MudToggleGroup>
                                </div>

                                <div class="setting-item">
                                    <span class="setting-label">@(_isArabic ? "الأسباب:" : "Reasons:")</span>
                                    <MudToggleGroup T="bool" @bind-Value="_showVoidDiscountDetails" SelectionMode="SelectionMode.SingleSelection"
                                                    Color="Color.Error" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                        <MudToggleItem Value="true">@(_isArabic ? "نعم" : "Yes")</MudToggleItem>
                                        <MudToggleItem Value="false">@(_isArabic ? "لا" : "No")</MudToggleItem>
                                    </MudToggleGroup>
                                </div>
                            }

                            <div class="setting-item">
                                <span class="setting-label">@(_isArabic ? "تفاصيل الموظفين:" : "Staff Details:")</span>
                                <MudToggleGroup T="bool" @bind-Value="_showStaffDetails" SelectionMode="SelectionMode.SingleSelection"
                                                Color="Color.Secondary" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                    <MudToggleItem Value="true">@(_isArabic ? "نعم" : "Yes")</MudToggleItem>
                                    <MudToggleItem Value="false">@(_isArabic ? "لا" : "No")</MudToggleItem>
                                </MudToggleGroup>
                            </div>

                            <div class="setting-item">
                                <span class="setting-label">@(_isArabic ? "اللغة:" : "Lang:")</span>
                                <MudToggleGroup T="bool" @bind-Value="_isArabic" SelectionMode="SelectionMode.SingleSelection"
                                                Color="Color.Secondary" Size="Size.Small" CheckMark="false" Class="pill-toggle-group">
                                    <MudToggleItem Value="true">AR</MudToggleItem>
                                    <MudToggleItem Value="false">EN</MudToggleItem>
                                </MudToggleGroup>
                            </div>
                        </div>
                    </div>

                    <div class="toolbar-section center">
                        <div class="report-main-title">@ReportTitle</div>
                        <div class="report-sub-title">@BranchName</div>
                    </div>

                    <div class="toolbar-section right">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Cancel"
                                       Color="Color.Error" Variant="Variant.Filled" Size="Size.Medium" Class="close-btn" />
                    </div>
                </div>
            </div>

            @* ══════════════ PAPER CANVAS ══════════════ *@
            <div class="report-viewport">
                <div class="report-canvas-scroll">
                    <div class="@(GetPaperClass()) shadow-2xl" dir="@(_isArabic ? "rtl" : "ltr")">

                        @{
                            // ── Shared data used in both Cashier and A4 ──
                            var modeDetails = SummaryData.Overall != null && SummaryData.Overall.ModeDetails != null
                                ? SummaryData.Overall.ModeDetails
                                : new List<ModeDetails>();
                            
                            var filteredOrders = (_showOrderDetails && SummaryData.DetailedOrders != null)
                                ? GetFilteredOrders().ToList()
                                : new List<global::POS.Contract.Dtos.OrderDtos.OrderDto>();
                            
                            var extractedVoids = _showVoidDiscountDetails 
                                ? GetExtractedVoids() 
                                : new List<VoidEventDto>();
                            
                            var discountOrders = (_showVoidDiscountDetails && SummaryData.DetailedOrders != null)
                                ? SummaryData.DetailedOrders.Where(o => (o.TotalDiscount ?? 0) > 0 || (o.TotalOrderDiscount ?? 0) > 0 || (o.DiscountedItems ?? 0) > 0).ToList()
                                : new List<global::POS.Contract.Dtos.OrderDtos.OrderDto>();
                        }

                        @if (_useA4 == false)
                        {
                            @* ── Cashier (Thermal 80mm) ── *@
                            <div class="cashier-receipt">

                                @* Title *@
                                <div class="rpt-title">@(_isArabic ? "ملخص المبيعات" : "Sales Summary")</div>

                                @* Branch / Date *@
                                <table class="rpt-tbl">
                                    <tr><td class="rpt-lbl">@(_isArabic ? "اسم الفرع" : "Branch")</td><td class="rpt-val">@BranchName</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "التاريخ" : "Date")</td><td class="rpt-val">@ReportDate.ToString("yyyy-MM-dd")</td></tr>
                                </table>

                                @* 1. Net Revenue *@
                                <div class="rpt-sec">@(_isArabic ? "صافي الإيراد" : "Net Revenue")</div>
                                <table class="rpt-tbl">
                                    <tr><td class="rpt-lbl rpt-bold">@(_isArabic ? "صافي المبيعات" : "Net Sales")</td><td class="rpt-val rpt-bold">@SummaryData.Overall.TotalSales.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "نقدي" : "Cash")</td><td class="rpt-val">@SummaryData.Overall.CashAmount.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "فيزا " : "Visa")</td><td class="rpt-val">@SummaryData.Overall.CreditAmount.ToString("0.##")</td></tr>
                                </table>

                                @* Staff Performance Summary (New) *@
                                @if (IsStaffReport && SummaryData.CashierSummaries != null && SummaryData.CashierSummaries.Any())
                                {
                                    <div class="rpt-sec">@(_isArabic ? "أداء الموظفين" : "Staff Performance")</div>
                                    <table class="rpt-tbl staff-table">
                                        <thead>
                                            <tr>
                                                <th>@(_isArabic ? "الموظف" : "Staff")</th>
                                                <th>@(_isArabic ? "العدد" : "Qty")</th>
                                                <th>@(_isArabic ? "فويد/خصم" : "V/D")</th>
                                                <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var s in SummaryData.CashierSummaries)
                                            {
                                                <tr>
                                                    <td>@s.Name</td>
                                                    <td class="rpt-center">@s.OrderCount</td>
                                                    <td class="rpt-center">@((s.VoidAmount + s.DiscountAmount).ToString("0.##"))</td>
                                                    <td class="rpt-center rpt-bold">@s.TotalAmount.ToString("0.##")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }

                                @* 2. Sales Distribution *@
                                <div class="rpt-sec">@(_isArabic ? "توزيع المبيعات" : "Sales Distribution")</div>
                                <table class="rpt-tbl">
                                    <thead><tr>
                                        <th>@(_isArabic ? "النوع" : "Type")</th>
                                        <th>@(_isArabic ? "العدد" : "Qty")</th>
                                        <th>@(_isArabic ? "الخصم" : "Disc")</th>
                                        <th>@(_isArabic ? "الفويد" : "Void")</th>
                                        <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                    </tr></thead>
                                    <tbody>
                                        @foreach (var m in modeDetails)
                                        {
                                            var vEvts = SummaryData.VoidEvents ?? new List<VoidEventDto>();
                                            var mVoid = vEvts.Where(v => v.OrderType.Equals(
                                                m.ModeTitle.Contains("صالة") || m.ModeTitle.Contains("Dine") ? "DineIn" :
                                                m.ModeTitle.Contains("تيك") || m.ModeTitle.Contains("Take") ? "TakeAway" : "Delivery",
                                                StringComparison.OrdinalIgnoreCase)).Sum(v => v.TotalVoidedAmount);
                                            <tr>
                                                <td>@m.ModeTitle</td>
                                                <td class="rpt-center">@m.OrderCount</td>
                                                <td class="rpt-center">@m.Discount.ToString("0.##")</td>
                                                <td class="rpt-center">@mVoid.ToString("0.##")</td>
                                                <td class="rpt-center">@m.GrandTotal.ToString("0.##")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                @* 3. Discounts & Voids Summary *@
                                <div class="rpt-sec">@(_isArabic ? "الخصومات والفويد" : "Discounts & Voids")</div>
                                <table class="rpt-tbl">
                                    <tr><td class="rpt-lbl">@(_isArabic ? "إجمالي الخصم" : "Total Discount")</td><td class="rpt-val">@ActualDiscountTotal.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "إجمالي الفويد" : "Total Void")</td><td class="rpt-val">@ActualVoidTotal.ToString("0.##")</td></tr>
                                </table>

                                @* 4. Order Details *@
                                @if (_showOrderDetails && filteredOrders.Any())
                                {
                                    <div class="rpt-sec">@(_isArabic ? "تفاصيل الأوردرات" : "Order Details")</div>
                                    <table class="rpt-tbl">
                                        <thead><tr>
                                            <th>@(_isArabic ? "رقم" : "No.")</th>
                                            <th>@(_isArabic ? "النوع" : "Type")</th>
                                            <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var o in filteredOrders)
                                        {
                                            <tr>
                                                <td class="rpt-center">#@o.OrderId</td>
                                                <td class="rpt-center">@o.OrderType</td>
                                                <td class="rpt-center">@o.GrandTotal?.ToString("0.##")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                }

                                @* Staff Summary *@
                                @if (SummaryData.CashierSummaries != null && SummaryData.CashierSummaries.Any())
                                {
                                    if (_showStaffDetails)
                                    {
                                        foreach (var s in SummaryData.CashierSummaries)
                                        {
                                            <div class="rpt-sec rpt-sec-blue" style="background:#1e88e5;">@(s.Name)</div>
                                            <table class="rpt-tbl" style="margin-bottom:8px; border:1px solid #1e88e5;">
                                                <tr><td class="rpt-lbl">@(_isArabic ? "العدد" : "Qty")</td><td class="rpt-val">@s.OrderCount</td></tr>
                                                <tr><td class="rpt-lbl" style="color:#c62828;">@(_isArabic ? "إجمالي الفويد" : "Total Void")</td><td class="rpt-val" style="color:#c62828;">@s.VoidAmount.ToString("0.##")</td></tr>
                                                <tr><td class="rpt-lbl" style="color:#2e7d32;">@(_isArabic ? "إجمالي الخصم" : "Total Discount")</td><td class="rpt-val" style="color:#2e7d32;">@s.DiscountAmount.ToString("0.##")</td></tr>
                                                <tr><td class="rpt-lbl rpt-bold">@(_isArabic ? "الإجمالي" : "Total")</td><td class="rpt-val rpt-bold">@s.TotalAmount.ToString("0.##")</td></tr>
                                            </table>
                                            
                                            var staffOrders = SummaryData.DetailedOrders?.Where(o => o.CashierId == s.Id || o.CashierName == s.Name).ToList() ?? new();
                                            var staffItems = staffOrders.SelectMany(o => o.OrderDetails ?? new List<global::POS.Contract.Models.TableItem>())
                                                .GroupBy(i => i.Name)
                                                .Select(g => new { Name = g.Key, Qty = g.Sum(x => x.Quantity), Total = g.Sum(x => x.Total ?? ((x.Price ?? 0) * x.Quantity)) })
                                                .ToList();
                                            
                                            if (staffItems.Any())
                                            {
                                                <div style="font-size:11px; font-weight:800; background:#eee; padding:4px; text-align:center; border:1px solid #ccc; margin-top:10px;">@(_isArabic?"ملخص الأصناف المباعة":"Sold Items Summary")</div>
                                                <table class="rpt-tbl" style="margin-bottom:10px;">
                                                    <thead><tr><th>@(_isArabic?"كم":"Qty")</th><th>@(_isArabic?"الصنف":"Item")</th><th>@(_isArabic?"الإجمالي":"Total")</th></tr></thead>
                                                    <tbody>
                                                        @foreach(var si in staffItems) {
                                                            <tr><td class="rpt-center">@si.Qty.ToString("0.##")</td><td>@si.Name</td><td class="rpt-center">@si.Total.ToString("0.##")</td></tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }

                                            if (_showOrderDetails && staffOrders.Any())
                                            {
                                                <div style="font-size:11px; font-weight:800; background:#eee; padding:4px; text-align:center; border:1px solid #ccc; margin-top:10px;">@(_isArabic?"قائمة الأوردرات":"Orders List")</div>
                                                <table class="rpt-tbl" style="border:1px dashed #ccc; margin-top:2px; margin-bottom:20px;">
                                                    <thead><tr><th>@(_isArabic?"رقم":"No.")</th><th>@(_isArabic?"النوع":"Type")</th><th>@(_isArabic?"الإجمالي":"Total")</th></tr></thead>
                                                    @foreach(var so in staffOrders) {
                                                        <tr><td class="rpt-center">#@so.OrderId</td><td>@so.OrderType</td><td class="rpt-center">@so.GrandTotal?.ToString("0.##")</td></tr>
                                                    }
                                                </table>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <div class="rpt-sec">@(_isArabic ? "ملخص حسابات الموظفين" : "Staff Accounts Summary")</div>
                                        <table class="rpt-tbl">
                                            <thead>
                                                <tr>
                                                    <th>@(_isArabic ? "الموظف" : "Staff")</th>
                                                    <th>@(_isArabic ? "العدد" : "Qty")</th>
                                                    <th>@(_isArabic ? "فويد/خصم" : "V/D")</th>
                                                    <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var s in SummaryData.CashierSummaries)
                                                {
                                                    <tr>
                                                        <td>@s.Name</td>
                                                        <td class="rpt-center">@s.OrderCount</td>
                                                        <td class="rpt-center">@s.VoidAmount.ToString("0.##") / @s.DiscountAmount.ToString("0.##")</td>
                                                        <td class="rpt-center rpt-bold">@s.TotalAmount.ToString("0.##")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                }
                                
                                @* Overall Details only shown if _showOrderDetails is true *@
                                @if (_showOrderDetails)
                                {
                                    @* 5. Item Details *@
                                    <div class="rpt-sec">@(_isArabic ? "تفاصيل الأصناف" : "Item Sales")</div>
                                    <table class="rpt-tbl">
                                        <thead><tr>
                                            <th>@(_isArabic ? "كم" : "Qty")</th>
                                            <th>@(_isArabic ? "الصنف" : "Item")</th>
                                            <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var item in Items)
                                        {
                                            <tr>
                                                <td class="rpt-center">@item.Quantity.ToString("0.##")</td>
                                                <td>@item.ItemName</td>
                                                <td class="rpt-center">@item.TotalAmount.ToString("0.##")</td>
                                            </tr>
                                        }
                                        </tbody>
                                        <tfoot>
                                            <tr class="rpt-grand">
                                                <td colspan="2" class="rpt-bold">@(_isArabic ? "الإجمالي الكلي" : "Grand Total")</td>
                                                <td class="rpt-center rpt-bold">@Items.Sum(x => x.TotalAmount).ToString("0.##")</td>
                                            </tr>
                                        </tfoot>
                                    </table>

                                    @* 6. Discount Details *@
                                    @if (discountOrders.Any())
                                    {
                                        <div class="rpt-sec rpt-sec-green">@(_isArabic ? "تفاصيل الخصومات" : "Discount Details")</div>
                                        <table class="rpt-tbl" style="background:#f0fff4;">
                                            <thead><tr>
                                                <th>@(_isArabic ? "رقم" : "No.")</th>
                                                <th>@(_isArabic ? "النوع" : "Type")</th>
                                                <th>@(_isArabic ? "المستخدم" : "User")</th>
                                                <th>@(_isArabic ? "السبب" : "Reason")</th>
                                                <th>@(_isArabic ? "القيمة" : "Amount")</th>
                                            </tr></thead>
                                            <tbody>
                                            @foreach (var o in discountOrders)
                                            {
                                                var dAmt = (o.TotalOrderDiscount ?? 0) > 0 ? o.TotalOrderDiscount
                                                           : ((o.TotalDiscount ?? 0) > 0 ? o.TotalDiscount : o.DiscountedItems);
                                                <tr>
                                                    <td class="rpt-center">#@o.OrderId</td>
                                                    <td class="rpt-center">@o.OrderType</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(o.DiscountByName) ? (o.CashierName ?? "-") : o.DiscountByName)</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(o.DiscountReason) ? "-" : o.DiscountReason)</td>
                                                    <td class="rpt-center">@dAmt?.ToString("0.##")</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    }

                                    @* 7. Void Details *@
                                    @if (extractedVoids.Any())
                                    {
                                        <div class="rpt-sec rpt-sec-red">@(_isArabic ? "تفاصيل الفويدات" : "Void Details")</div>
                                        <table class="rpt-tbl" style="background:#fff5f5;">
                                            <thead><tr>
                                                <th>@(_isArabic ? "رقم" : "No.")</th>
                                                <th>@(_isArabic ? "النوع" : "Type")</th>
                                                <th>@(_isArabic ? "المستخدم" : "User")</th>
                                                <th>@(_isArabic ? "السبب" : "Reason")</th>
                                                <th>@(_isArabic ? "القيمة" : "Amount")</th>
                                            </tr></thead>
                                            <tbody>
                                            @foreach (var v in extractedVoids)
                                            {
                                                <tr>
                                                    <td class="rpt-center">#@v.OrderId</td>
                                                    <td class="rpt-center">@v.OrderType</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(v.VoidedByName) ? "-" : v.VoidedByName)</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(v.Reason) ? "-" : v.Reason)</td>
                                                    <td class="rpt-center">@v.TotalVoidedAmount.ToString("0.##")</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    }
                                }

                                <div class="rpt-footer">@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                        }
                        else
                        {
                            @* ── A4 ── *@
                            <div class="a4-content">

                                @* Title + Branch *@
                                <div class="rpt-title" style="font-size:20px; margin-bottom:10px;">@(_isArabic ? "ملخص المبيعات" : "Sales Summary")</div>
                                <table class="rpt-tbl" style="margin-bottom:10px;">
                                    <tr><td class="rpt-lbl rpt-bold">@(_isArabic ? "اسم الفرع" : "Branch")</td><td class="rpt-val">@BranchName</td></tr>
                                    <tr><td class="rpt-lbl rpt-bold">@(_isArabic ? "التاريخ" : "Date")</td><td class="rpt-val">@ReportDate.ToString("yyyy-MM-dd")</td></tr>
                                </table>

                                @* 1. Net Revenue *@
                                <div class="rpt-sec">@(_isArabic ? "صافي الإيراد" : "Net Revenue")</div>
                                <table class="rpt-tbl">
                                    <tr><td class="rpt-lbl rpt-bold">@(_isArabic ? "صافي المبيعات" : "Net Sales")</td><td class="rpt-val rpt-bold">@SummaryData.Overall.TotalSales.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "نقدي" : "Cash")</td><td class="rpt-val">@SummaryData.Overall.CashAmount.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "فيزا / بطاقة" : "Visa / Card")</td><td class="rpt-val">@SummaryData.Overall.CreditAmount.ToString("0.##")</td></tr>
                                </table>

                                @* 2. Sales Distribution *@
                                <div class="rpt-sec">@(_isArabic ? "توزيع المبيعات" : "Sales Distribution")</div>
                                <table class="rpt-tbl">
                                    <thead><tr>
                                        <th>@(_isArabic ? "النوع" : "Type")</th>
                                        <th>@(_isArabic ? "العدد" : "Qty")</th>
                                        <th>@(_isArabic ? "الخصم" : "Discount")</th>
                                        <th>@(_isArabic ? "الفويد" : "Void")</th>
                                        <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                    </tr></thead>
                                    <tbody>
                                    @foreach (var m in modeDetails)
                                    {
                                        var vEvts = SummaryData.VoidEvents ?? new List<VoidEventDto>();
                                        var mVoid = vEvts.Where(v => v.OrderType.Equals(
                                            m.ModeTitle.Contains("صالة") || m.ModeTitle.Contains("Dine") ? "DineIn" :
                                            m.ModeTitle.Contains("تيك") || m.ModeTitle.Contains("Take") ? "TakeAway" : "Delivery",
                                            StringComparison.OrdinalIgnoreCase)).Sum(v => v.TotalVoidedAmount);
                                        <tr>
                                            <td class="rpt-center">@m.ModeTitle</td>
                                            <td class="rpt-center">@m.OrderCount</td>
                                            <td class="rpt-center">@m.Discount.ToString("0.##")</td>
                                            <td class="rpt-center">@mVoid.ToString("0.##")</td>
                                            <td class="rpt-center">@m.GrandTotal.ToString("0.##")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>

                                @* 3. Discounts & Voids Summary *@
                                <div class="rpt-sec">@(_isArabic ? "الخصومات والفويد" : "Discounts & Voids")</div>
                                <table class="rpt-tbl">
                                    <tr><td class="rpt-lbl">@(_isArabic ? "إجمالي الخصم" : "Total Discount")</td><td class="rpt-val">@ActualDiscountTotal.ToString("0.##")</td></tr>
                                    <tr><td class="rpt-lbl">@(_isArabic ? "إجمالي الفويد" : "Total Void")</td><td class="rpt-val">@ActualVoidTotal.ToString("0.##")</td></tr>
                                </table>

                                @* 4. Order Details *@
                                @if (_showOrderDetails && filteredOrders.Any())
                                {
                                    <div class="rpt-sec">@(_isArabic ? "تفاصيل الأوردرات" : "Order Details")</div>
                                    <table class="rpt-tbl">
                                        <thead><tr>
                                            <th>@(_isArabic ? "رقم" : "No.")</th>
                                            <th>@(_isArabic ? "النوع" : "Type")</th>
                                            <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var o in filteredOrders)
                                        {
                                            <tr>
                                                <td class="rpt-center">#@o.OrderId</td>
                                                <td class="rpt-center">@o.OrderType</td>
                                                <td class="rpt-center">@o.GrandTotal?.ToString("0.##")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                }

                                @* Staff Accounts Section *@
                                @if (SummaryData.CashierSummaries != null && SummaryData.CashierSummaries.Any())
                                {
                                    if (_showStaffDetails)
                                    {
                                        foreach (var s in SummaryData.CashierSummaries)
                                        {
                                            <div class="rpt-sec" style="background:#1e88e5; margin-top:15px; font-size:13px; padding:6px; text-align:right;">@(s.Name)</div>
                                            <table class="rpt-tbl" style="background:#f1f8fe; margin-bottom:5px;">
                                                <thead><tr>
                                                    <th>@(_isArabic?"العدد":"Orders")</th>
                                                    <th>@(_isArabic?"الخصم":"Disc")</th>
                                                    <th>@(_isArabic?"الفويد":"Void")</th>
                                                    <th>@(_isArabic?"الإجمالي":"Total")</th>
                                                </tr></thead>
                                                <tr>
                                                    <td class="rpt-center">@s.OrderCount</td>
                                                    <td class="rpt-center">@s.DiscountAmount.ToString("0.##")</td>
                                                    <td class="rpt-center">@s.VoidAmount.ToString("0.##")</td>
                                                    <td class="rpt-center rpt-bold">@s.TotalAmount.ToString("0.##")</td>
                                                </tr>
                                            </table>
                                            
                                            var staffOrders = SummaryData.DetailedOrders?.Where(o => o.CashierId == s.Id || o.CashierName == s.Name).ToList() ?? new();
                                            var staffItems = staffOrders.SelectMany(o => o.OrderDetails ?? new List<global::POS.Contract.Models.TableItem>())
                                                .GroupBy(i => i.Name)
                                                .Select(g => new { Name = g.Key, Qty = g.Sum(x => x.Quantity), Total = g.Sum(x => x.Total ?? ((x.Price ?? 0) * x.Quantity)) })
                                                .ToList();
                                            
                                            if (staffItems.Any())
                                            {
                                                <div style="font-size:11px; font-weight:bold; margin-top:5px; margin-bottom:2px; color:#1e88e5;">@(_isArabic?"ملخص المبيعات:":"Sales Summary:")</div>
                                                <table class="rpt-tbl" style="margin-bottom:8px;">
                                                    <thead><tr style="background:#eee;"><th>@(_isArabic?"الكمية":"Qty")</th><th>@(_isArabic?"الصنف":"Item")</th><th>@(_isArabic?"الإجمالي":"Total")</th></tr></thead>
                                                    <tbody>
                                                        @foreach(var si in staffItems) {
                                                            <tr><td class="rpt-center">@si.Qty.ToString("0.##")</td><td>@si.Name</td><td class="rpt-center">@si.Total.ToString("0.##")</td></tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }

                                            if (_showOrderDetails && staffOrders.Any())
                                            {
                                                <div style="font-size:11px; font-weight:bold; margin-top:5px; margin-bottom:2px; color:#1e88e5;">@(_isArabic?"الأوردرات:":"Orders:")</div>
                                                <table class="rpt-tbl" style="margin-bottom:15px;">
                                                    <thead><tr style="background:#f5f5f5;"><th>@(_isArabic?"رقم":"No.")</th><th>@(_isArabic?"النوع":"Type")</th><th>@(_isArabic?"الإجمالي":"Total")</th></tr></thead>
                                                    @foreach(var so in staffOrders) {
                                                        <tr><td class="rpt-center">#@so.OrderId</td><td class="rpt-center">@so.OrderType</td><td class="rpt-center">@so.GrandTotal?.ToString("0.##")</td></tr>
                                                    }
                                                </table>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <div class="rpt-sec">@(_isArabic ? "ملخص حسابات الموظفين" : "Staff Accounts Summary")</div>
                                        <table class="rpt-tbl">
                                            <thead>
                                                <tr>
                                                    @if (_isArabic)
                                                    {
                                                        <th>إسم الموظف</th>
                                                        <th>عدد الطلبات</th>
                                                        <th>إجمالي الخصم</th>
                                                        <th>إجمالي الفويد</th>
                                                        <th>الإجمالي</th>
                                                    }
                                                    else
                                                    {
                                                        <th>Staff Name</th>
                                                        <th>Orders</th>
                                                        <th>Discount</th>
                                                        <th>Void</th>
                                                        <th>Total</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var s in SummaryData.CashierSummaries)
                                                {
                                                    <tr>
                                                        @if (_isArabic)
                                                        {
                                                            <td>@s.Name</td>
                                                            <td class="rpt-center">@s.OrderCount</td>
                                                            <td class="rpt-center" style="color:#2e7d32;">@s.DiscountAmount.ToString("0.##")</td>
                                                            <td class="rpt-center" style="color:#c62828;">@s.VoidAmount.ToString("0.##")</td>
                                                            <td class="rpt-center rpt-bold">@s.TotalAmount.ToString("0.##")</td>
                                                        }
                                                        else
                                                        {
                                                            <td>@s.Name</td>
                                                            <td class="rpt-center">@s.OrderCount</td>
                                                            <td class="rpt-center" style="color:#2e7d32;">@s.DiscountAmount.ToString("0.##")</td>
                                                            <td class="rpt-center" style="color:#c62828;">@s.VoidAmount.ToString("0.##")</td>
                                                            <td class="rpt-center rpt-bold">@s.TotalAmount.ToString("0.##")</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot>
                                                <tr class="rpt-grand">
                                                    @if (_isArabic)
                                                    {
                                                        <td class="rpt-center rpt-bold">@SummaryData.CashierSummaries.Sum(x => x.TotalAmount).ToString("0.##")</td>
                                                        <td colspan="4" class="rpt-bold">@("الإجمالي الكلي")</td>
                                                    }
                                                    else
                                                    {
                                                        <td colspan="4" class="rpt-bold">@("Grand Total")</td>
                                                        <td class="rpt-center rpt-bold">@SummaryData.CashierSummaries.Sum(x => x.TotalAmount).ToString("0.##")</td>
                                                    }
                                                </tr>
                                            </tfoot>
                                        </table>
                                    }
                                }

                                @* Overall Details only shown if _showOrderDetails is true *@
                                @if (_showOrderDetails)
                                {
                                    @* 5. Item Details *@
                                    <div class="rpt-sec">@(_isArabic ? "تفاصيل الأصناف" : "Item Sales")</div>
                                    <table class="rpt-tbl">
                                        <thead><tr>
                                            <th>@(_isArabic ? "كم" : "Qty")</th>
                                            <th>@(_isArabic ? "الصنف" : "Item")</th>
                                            <th>@(_isArabic ? "الإجمالي" : "Total")</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var item in Items)
                                        {
                                            <tr>
                                                <td class="rpt-center">@item.Quantity.ToString("0.##")</td>
                                                <td>@item.ItemName</td>
                                                <td class="rpt-center">@item.TotalAmount.ToString("0.##")</td>
                                            </tr>
                                        }
                                        </tbody>
                                        <tfoot>
                                            <tr class="rpt-grand">
                                                <td colspan="2" class="rpt-bold">@(_isArabic ? "الإجمالي الكلي" : "Grand Total")</td>
                                                <td class="rpt-center rpt-bold">@Items.Sum(x => x.TotalAmount).ToString("0.##")</td>
                                            </tr>
                                        </tfoot>
                                    </table>

                                    @* 6. Discount Details *@
                                    @if (discountOrders.Any())
                                    {
                                        <div class="rpt-sec rpt-sec-green">@(_isArabic ? "تفاصيل الخصومات" : "Discount Details")</div>
                                        <table class="rpt-tbl" style="background:#f0fff4;">
                                            <thead><tr>
                                                <th>@(_isArabic ? "رقم" : "No.")</th>
                                                <th>@(_isArabic ? "النوع" : "Type")</th>
                                                <th>@(_isArabic ? "المستخدم" : "User")</th>
                                                <th>@(_isArabic ? "السبب" : "Reason")</th>
                                                <th>@(_isArabic ? "القيمة" : "Amount")</th>
                                            </tr></thead>
                                            <tbody>
                                            @foreach (var o in discountOrders)
                                            {
                                                var dAmt = (o.TotalOrderDiscount ?? 0) > 0 ? o.TotalOrderDiscount
                                                           : ((o.TotalDiscount ?? 0) > 0 ? o.TotalDiscount : o.DiscountedItems);
                                                <tr>
                                                    <td class="rpt-center">#@o.OrderId</td>
                                                    <td class="rpt-center">@o.OrderType</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(o.DiscountByName) ? (o.CashierName ?? "-") : o.DiscountByName)</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(o.DiscountReason) ? "-" : o.DiscountReason)</td>
                                                    <td class="rpt-center">@dAmt?.ToString("0.##")</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    }

                                    @* 7. Void Details *@
                                    @if (extractedVoids.Any())
                                    {
                                        <div class="rpt-sec rpt-sec-red">@(_isArabic ? "تفاصيل الفويدات" : "Void Details")</div>
                                        <table class="rpt-tbl" style="background:#fff5f5;">
                                            <thead><tr>
                                                <th>@(_isArabic ? "رقم" : "No.")</th>
                                                <th>@(_isArabic ? "النوع" : "Type")</th>
                                                <th>@(_isArabic ? "المستخدم" : "User")</th>
                                                <th>@(_isArabic ? "السبب" : "Reason")</th>
                                                <th>@(_isArabic ? "القيمة" : "Amount")</th>
                                            </tr></thead>
                                            <tbody>
                                            @foreach (var v in extractedVoids)
                                            {
                                                <tr>
                                                    <td class="rpt-center">#@v.OrderId</td>
                                                    <td class="rpt-center">@v.OrderType</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(v.VoidedByName) ? "-" : v.VoidedByName)</td>
                                                    <td class="rpt-center">@(string.IsNullOrEmpty(v.Reason) ? "-" : v.Reason)</td>
                                                    <td class="rpt-center">@v.TotalVoidedAmount.ToString("0.##")</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    }
                                }

                                <div class="rpt-footer">@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                        }

                    </div>
                </div>
            </div>

        </div>
    </DialogContent>
</MudDialog>


