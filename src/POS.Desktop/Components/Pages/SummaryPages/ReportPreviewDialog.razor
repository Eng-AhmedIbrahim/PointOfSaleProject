        text-align: center; font-size: 11px; font-weight: 700;
        margin-bottom: 4px; opacity: .85;
    }
    .cr-line { border-top: 2px solid #000; margin: 5px 0; }
    .cr-line-dashed { border-top: 1.5px dashed #000; margin: 5px 0; }

    .cr-section-title {
        text-align: center; font-size: 10px; font-weight: 900;
        background: #000; color: #fff;
        padding: 2px 4px; margin: 4px 0 2px;
    }
    .cr-row {
        display: flex; justify-content: space-between;
        font-size: 11px; padding: 1px 0;
    }
    .cr-bold { font-weight: 900; }
    .cr-discount { color: #1b5e20; }
    .cr-void     { color: #b71c1c; }

    /* Cashier table */
    .cr-table { width: 100%; border-collapse: collapse; margin: 3px 0; }
    .cr-table th {
        background: #424242; color: #fff;
        font-size: 10px; font-weight: 900;
        padding: 3px 2px; border: 1px solid #000;
        text-align: center;
    }
    .cr-table td {
        font-size: 10.5px; font-weight: 600;
        padding: 2px 3px; border: 1px solid #ccc;
    }
    .cr-table .num { text-align: center; }
    .cr-table .lbl-cell { text-align: center; font-size: 10px; }
    .cr-table .item-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100px; }

    .cr-total-row td { background: #f5f5f5; border-top: 2px solid #000; font-size: 11.5px; }

    /* Reason rows (cashier) */
    .reason-row td { font-size: 9.5px; padding: 1px 4px; border: none; }
    .reason-void { background: #fff5f5; color: #c62828; }
    .reason-disc { background: #f0fff4; color: #2e7d32; }
