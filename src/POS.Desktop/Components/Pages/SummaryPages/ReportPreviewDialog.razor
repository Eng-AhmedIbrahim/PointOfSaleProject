    /* ════════════════════════════
       A4 STYLES
    ════════════════════════════ */
    .a4-content { width: 100%; }
    .a4-header  { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; }

    .brand-text       { font-size: 28px; font-weight: 900; color: #1565c0; letter-spacing: 2px; }
    .report-title-main{ font-size: 16px; font-weight: 700; color: #444; margin-top: 4px; }

    .a4-info-box { border: 2px solid #333; min-width: 200px; }
    .a4-info-row { display: flex; border-bottom: 1px solid #ccc; }
    .a4-info-row:last-child { border-bottom: none; }
    .a4-lbl { background: #eeeeee; padding: 6px 10px; font-size: 12px; font-weight: 700; white-space: nowrap; border-left: 2px solid #333; border-right: 2px solid #333; }
    .a4-val { padding: 6px 10px; font-size: 12px; font-weight: 800; flex: 1; }

    /* Financial summary cards strip */
    .a4-fin-grid {
        display: flex; gap: 10px; flex-wrap: wrap;
        margin-bottom: 24px;
    }
    .a4-fin-card {
        flex: 1; min-width: 100px;
        border-radius: 8px; padding: 12px 16px;
        box-shadow: 0 2px 6px rgba(0,0,0,.12);
        text-align: center;
    }
    .a4-fin-total { background: #e3f2fd; border-left: 4px solid #1565c0; }
    .a4-fin-cash  { background: #e8f5e9; border-left: 4px solid #2e7d32; }
    .a4-fin-card2 { background: #ede7f6; border-left: 4px solid #6a1b9a; }
    .a4-fin-disc  { background: #fff8e1; border-left: 4px solid #f9a825; }
    .a4-fin-void  { background: #fce4ec; border-left: 4px solid #c62828; }
    .a4-fin-label { font-size: 11px; font-weight: 700; opacity: .75; margin-bottom: 4px; }
    .a4-fin-value { font-size: 17px; font-weight: 900; }

    /* A4 section titles */
    .a4-section-title {
        font-size: 13px; font-weight: 900;
        background: #1a237e; color: #fff;
        padding: 6px 14px; margin: 18px 0 0;
        border-radius: 4px 4px 0 0;
    }

    /* A4 table */
    .a4-table { width: 100%; border-collapse: collapse; }
    .a4-table th {
        background: #e8eaf6; padding: 10px 12px;
        border: 1px solid #9fa8da; font-weight: 900; font-size: 13px;
    }
    .a4-table td { padding: 9px 12px; border: 1px solid #ddd; font-size: 13px; }
    .a4-table tbody tr:nth-child(even) { background: #f9f9f9; }
    .a4-total-row td { background: #e8eaf6; border: 2px solid #3949ab; font-size: 14px; padding: 10px 12px; }

    /* Reason rows (A4) */
    .a4-reason-void { background: #fff5f5; }
    .a4-reason-void td { color: #c62828; font-size: 11px; padding: 4px 12px; border: none; border-bottom: 1px solid #ffcdd2; }
    .a4-reason-disc { background: #f0fff4; }
    .a4-reason-disc td { color: #2e7d32; font-size: 11px; padding: 4px 12px; border: none; border-bottom: 1px solid #c8e6c9; }
    .a4-by { opacity: .7; }

    .a4-footer {
        margin-top: 30px; text-align: center;
        font-size: 11px; color: #777;
        border-top: 1px dashed #ccc; padding-top: 10px;
    }

    /* ── Utilities ── */
    .fw-bold { font-weight: 900 !important; }
    .text-center { text-align: center !important; }
    .text-right  { text-align: right !important; }
    .text-left   { text-align: left !important; }
</style>

@code {
    [Parameter] public string ReportTitle { get; set; } = "";
    [Parameter] public string BranchName  { get; set; } = "Main Branch";
    [Parameter] public DateTime ReportDate { get; set; } = DateTime.Today;
    [Parameter] public List<SalesItemSummaryDto> Items { get; set; } = new();
    [Parameter] public SalesSummaryDto SummaryData { get; set; } = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private List<string> _printers = new();
    private bool _useA4 = false;
    private bool _isArabic = true;
    private bool _showOrderDetails = true;
    private bool _onlyVoidDiscount = false;
    private bool _showVoidDiscountDetails = true;

    private IEnumerable<OrderDto> GetFilteredOrders()
    {
        if (SummaryData.DetailedOrders == null) return Enumerable.Empty<OrderDto>();
        var orders = SummaryData.DetailedOrders.AsEnumerable();
        if (_onlyVoidDiscount)
            orders = orders.Where(o => (o.VoidAmount ?? 0) > 0 || (o.TotalDiscount ?? 0) > 0);
        return orders;
    }

    protected override async Task OnInitializedAsync()
    {
        _printers = await PrinterServices.GetInstalledPrinters();
        _isArabic = Localizer.GetCurrentLanguage() == "ar";
    }

    private string GetPaperClass() => _useA4 ? "report-paper-a4" : "report-paper-cashier";
    private void Cancel() => MudDialog.Cancel();
    private async Task QuickPrint() => await PrintTo(null);

    private async Task PrintTo(string? printerName)
    {
        try
        {
            Snackbar.Add(_isArabic ? "جاري تحضير التقرير..." : "Preparing report...", Severity.Info);

            var dataToPrint = new SalesSummaryDto
            {
                PosDate    = SummaryData.PosDate,
                StaffName  = SummaryData.StaffName,
                Overall    = SummaryData.Overall,
                DetailedOrders = _showOrderDetails ? GetFilteredOrders().ToList() : new List<OrderDto>()
            };

            await PrintOrderService.PrintSalesSummaryAsync(dataToPrint, Items, printerName, _useA4, _isArabic);
            Snackbar.Add(_isArabic ? "تم إرسال الأمر للطابعة" : "Print command sent", Severity.Success);
            MudDialog.Close();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["Error"] + ": " + ex.Message, Severity.Error);
        }
    }
}
