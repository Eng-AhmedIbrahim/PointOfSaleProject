@page "/pos"
@layout PosScreenLayout
@inject CommonProperties _commonProperties
@inject Section4ButtonsServices _section4ButtonsServices
@inject CartService _cartService
@inject HandelDeliveryInvocation _handelDeliveryInvocation
@inject LocalizationService Localizer
@inject ICategoryServices _categoryServices
@inject IJSRuntime JsRuntime
@inject ICustomizationSettingsService CustomizationSettingsService
@inject IAppDateService _appDate
@inject IOrderSettingsService _orderSettingsService
@inject IBranchService _branchService
@inject IPrintOrderService _printOrderService
@inject IPosFeatureSettingsService _featureSettingsService
@inject IDialogService DialogService
@implements IDisposable

<link href="section4-footer.css" rel="stylesheet" />

<MudGrid Spacing="0" Justify="Justify.Center" Class="overflow-hidden" Style="height: 100%;" tabindex="0">
    <MudItem xs="2" Class="section-container border-r border-solid custom-border-color">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["Categories"]</MudText>
        <div class="full-height overflow-y-auto pa-0 ma-0">
            @foreach (var category in _categories ?? [])
            {
                <button class="category-btn" @onclick="async () => await InvokeItems(category.Id)">
                    @(Localizer.GetCurrentLanguage() == "ar" ? category.ArabicName : (category.EnglishName ?? category.ArabicName))
                </button>
            }
        </div>
    </MudItem>
    <!-- Section 2 -->

    <MudItem xs="4" Class="section-container border-r border-solid custom-border-color">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["SalesItems"]</MudText>
        <div class="full-height overflow-y-auto pa-0 ma-0 sales-grid-container">
            @foreach (var item in _itemByCatId)
            {
                <button class="item-button" @onclick="@(() => AddItemToSection4(item))">
                    <span class="item-text">@(Localizer.GetCurrentLanguage() == "ar" ? item.ArabicName : (item.EnglishName ?? item.ArabicName))</span>
                </button>
            }
        </div>
    </MudItem>


    <!-- Section 3 -->
    <MudItem xs="1" Class="section-container border-r border-solid custom-border-color" Style="max-width: 8.33%; flex: 0 0 8.33%;">
        <MudText Typo="Typo.h6" Class="section-label">@Localizer["Actions"]</MudText>
        <div class="full-height">
            <Section3 />
        </div>
    </MudItem>

    <!-- Section 4 -->
    <MudItem xs="5" Class="section-container border-l border-solid custom-border-color">
        <div class="d-flex align-center gap-1">
            <MudText Typo="Typo.h6" Class="section4-label flex-grow-1">
                @(_commonProperties.CurrentPosMode == "Delivery" ? Localizer["DeliveryService"] : _commonProperties.CurrentPosMode + " " + Localizer["Order"])
            </MudText>
            
            @if (_commonProperties.CurrentPosMode == "Delivery" && (_dispatcherSettings.IsDispatcher || canChangeBranch))
            {
                <div class="branch-selector-container d-flex align-center gap-2">
                    <MudText Typo="Typo.caption" Class="branch-label">@Localizer["Branch"]</MudText>
                    <MudSelect T="int" Value="@(_commonProperties.BranchDetails?.Id ?? 0)" ValueChanged="OnBranchChanged" 
                              Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="branch-select-pos" Style="min-width: 120px;">
                        @foreach (var branch in _branches ?? [])
                        {
                            <MudSelectItem Value="@branch.Id">@branch.Name</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            }
        </div>

        <div class="full-height d-flex flex-column">
            @if (_commonProperties.UpdateDeliveryOrder || _commonProperties.UpdateDineInOrder)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-1 py-1" Style="font-size: 0.9rem; font-weight: bold;">
                    @Localizer["ReceiptBelongsToOrder"] @(_commonProperties.UpdateDineInOrder ? _commonProperties.DineInOrderValues?.OrderID : _commonProperties.OrderDto?.OrderId)
                </MudAlert>
            }
            <!-- Order Table - Fills remaining space -->
            <div class="flex-grow-1 overflow-y-auto">
                <Section4Table Items="_commonProperties.TableItems" OnItemsChanged="OnSection4ItemsChanged" />
            </div>

            <!-- Fixed Bottom Sections - Compact Layout -->
            <div class="section-footer-compact">
                <!-- Notes Field -->
                <MudTextField ShrinkLabel="true"
                               @bind-Value="_commonProperties.OrderNote"
                               Immediate="true"
                               Lines="1"
                               Margin="Margin.Dense"
                               Placeholder="@Localizer["Notes"]"
                               Variant="Variant.Outlined"
                               Class="notes-field" />

                <!-- Action Buttons - No spacing -->
                <div class="action-buttons-row">
                    <Section4Buttons />
                </div>

                <!-- Finance Component - Compact -->
                <div class="finance-section-compact">
                    <FinanceComponent Settings="_commonProperties._financeSettingsList" />
                </div>
            </div>
        </div>
    </MudItem>
</MudGrid>