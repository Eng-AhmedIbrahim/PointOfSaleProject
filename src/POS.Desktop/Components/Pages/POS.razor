@page "/pos"
@using BlazorBase.ERPFrontServices.PrintOrderServices
@layout PosScreenLayout
@inject CommonProperties _commonProperties
@inject ICategoryServices _categoryServices
@inject IJSRuntime JsRuntime
@inject ICustomizationSettingsService CustomizationSettingsService
@inject Section4ButtonsServices _section4ButtonsServices
@inject CartService _cartService
@inject AppDateService _appDate
@inject OrderSettingsService _orderSettingsService
@inject HandelDeliveryInvocation _handelDeliveryInvocation
@inject BranchService _branchService
@inject IPrintOrderService _printOrderService
@inject Section4ButtonsServices _services
@implements IDisposable

<link href="section4-footer.css" rel="stylesheet" />

<MudGrid Spacing="0" Justify="Justify.Center" Class="overflow-hidden" Style="height: 100%;" tabindex="0">
    <MudItem xs="2" Class="section-container border-r border-solid custom-border-color">
        <MudText Typo="Typo.h6" Class="section-label">Categories</MudText>
        <div class="full-height overflow-y-auto pa-0 ma-0">
            @foreach (var category in _categories ?? [])
            {
                <button class="category-btn" @onclick="async () => await InvokeItems(category.Id)">
                    @category.ArabicName
                </button>
            }
        </div>
    </MudItem>
    <!-- Section 2 -->

    <MudItem xs="4" Class="section-container border-r border-solid custom-border-color">
        <MudText Typo="Typo.h6" Class="section-label">Sales Items</MudText>
        <div class="full-height overflow-y-auto pa-0 ma-0 sales-grid-container">
            @foreach (var item in _itemByCatId)
            {
                <button class="item-button" @onclick="@(() => AddItemToSection4(item))">
                    <span class="item-text">@item.ArabicName</span>
                </button>
            }
        </div>
    </MudItem>


    <!-- Section 3 -->
    <MudItem xs="1" Class="section-container border-r border-solid custom-border-color" Style="max-width: 8.33%; flex: 0 0 8.33%;">
        <MudText Typo="Typo.h6" Class="section-label">Actions</MudText>
        <div class="full-height">
            <Section3 />
        </div>
    </MudItem>

    <!-- Section 4 -->
    <MudItem xs="5" Class="section-container border-l border-solid custom-border-color">
        <MudText Typo="Typo.h6" Class="section4-label">@_commonProperties.CurrentPosMode Order @_handelDeliveryInvocation.DeliveryDetails </MudText>
        <div class="full-height d-flex flex-column">
            <!-- Order Table - Fills remaining space -->
            <div class="flex-grow-1 overflow-y-auto">
                <Section4Table Items="_commonProperties.TableItems" OnItemsChanged="OnSection4ItemsChanged" />
            </div>

            <!-- Fixed Bottom Sections - Compact Layout -->
            <div class="section-footer-compact">
                <!-- Notes Field -->
                <MudTextField ShrinkLabel="true"
                               @bind-Value="_commonProperties.OrderNote"
                               Immediate="true"
                               Lines="1"
                               Margin="Margin.Dense"
                               Placeholder="Notes"
                               Variant="Variant.Outlined"
                               Class="notes-field" />

                <!-- Action Buttons - No spacing -->
                <div class="action-buttons-row">
                    <Section4Buttons />
                </div>

                <!-- Finance Component - Compact -->
                <div class="finance-section-compact">
                    <FinanceComponent Settings="_commonProperties._financeSettingsList" />
                </div>
            </div>
        </div>
    </MudItem>
</MudGrid>