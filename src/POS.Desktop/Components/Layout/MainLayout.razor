@inherits LayoutComponentBase
@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

@using POS.Core.Services.Contract.PosFeatureServices
@inject CommonProperties _commonProperties
@inject ISnackbar _snackbar
@inject BlazorBase.Services.LocalizationService Localizer

@* <NavigationLock ConfirmExternalNavigation='_commonProperties.TableItems?.Any() == true' 
                OnBeforeInternalNavigation="HandleInternalNavigation" /> *@

@implements IDisposable

@inject IPosFeatureSettingsService _featureSettingsService

@inject BlazorBase.HandelDeliveryInvocation _deliveryInvocation

@code {
    private Action? _stateChangedHandler;

    protected override void OnInitialized()
    {
        _stateChangedHandler = async () => 
        {
            try { await InvokeAsync(StateHasChanged); } catch { }
        };

        _commonProperties.OnChange += _stateChangedHandler;
        _deliveryInvocation.OnShowNotification += ShowNotification;
    }

    private async void ShowNotification(string message, Severity severity)
    {
        await InvokeAsync(() => _snackbar.Add(message, severity));
    }

    private void HandleInternalNavigation(LocationChangingContext context)
    {
        if (context.TargetLocation.Contains("/pos", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        if (_commonProperties.TableItems?.Any() == true)
        {
            _snackbar.Add(Localizer["PleaseCompleteOrder"], Severity.Warning);
            context.PreventNavigation();
        }
    }

    public void Dispose()
    {
        if (_stateChangedHandler != null)
        {
            _commonProperties.OnChange -= _stateChangedHandler;
        }
        _deliveryInvocation.OnShowNotification -= ShowNotification;
    }
}
<div class="page">
    @* <main> *@
        @* <NavBar /> *@

        @* <article class="content px-4"> *@
            @Body
        @* </article> *@
    @* </main> *@
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>