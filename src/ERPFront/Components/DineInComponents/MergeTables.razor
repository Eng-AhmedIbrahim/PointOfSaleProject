@using MudBlazor
@inject ISnackbar _snackbar
@inject CommonProperties _commonProperties
@inject IDialogService _dialogService

<MudDialog FullWidth="true" MaxWidth="MaxWidth.Medium">
    <TitleContent>
        <MudText Typo="Typo.h6">Merge Tables</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                    @foreach (var table in _tables ?? new())
                    {
                        <MudButton Size="Size.Large"
                                   Variant="Variant.Filled"
                                   DisableElevation="true"
                                   Class="@GetTableClass(table)"
                                   OnClick="() => ToggleTableSelection(table)">
                            <MudStack Row="false" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@( Icons.Material.Filled.TableRestaurant )" Size="Size.Large" />
                                <MudText Typo="Typo.subtitle2">@table.RelatedTableName</MudText>
                            </MudStack>
                        </MudButton>
                    }
                </MudStack>
            </MudItem>

            <MudItem xs="12" Class="text-center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="MergeSelectedTables"
                           Disabled="@IsMergeDisabled">
                    <MudIcon Icon="@(Icons.Material.Filled.Merge)" />
                    Merge Tables
                </MudButton>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CloseDialog" Color="Color.Secondary">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<DineInOrderDetails> _tables = new();
    private HashSet<int> SelectedTableIds = new();
    public List<DineInOrderDetails> TablesToMigrates = new();

    protected override Task OnInitializedAsync()
    {
        if (_commonProperties.DineInOrdersDetails != null)
        {
            _tables = _commonProperties.DineInOrdersDetails.Values
                .SelectMany(x => x)
                .Where(x => !string.IsNullOrEmpty(x.RelatedTableName))
                .ToList();
        }
        return base.OnInitializedAsync();
    }

    private void ToggleTableSelection(DineInOrderDetails table)
    {
        if (table?.RelatedTableId == null) return;

        if (SelectedTableIds.Contains(table.RelatedTableId.Value))
        {
            SelectedTableIds.Remove(table.RelatedTableId.Value);
            TablesToMigrates.Remove(table);
            table.IsMigrated = false;
            table.MergedTableIds.Clear();
        }
        else
        {
            if (!TablesToMigrates.Any())
                table.MergedTableIds.Add(table.RelatedTableId.Value);
            else
            {
                var mergeGroup = TablesToMigrates.SelectMany(t => t.MergedTableIds).Distinct().ToList();
                mergeGroup.Add(table.RelatedTableId.Value);

                foreach (var t in TablesToMigrates)
                {
                    t.MergedTableIds = new List<int>(mergeGroup);
                }

                table.MergedTableIds = new List<int>(mergeGroup);
            }

            SelectedTableIds.Add(table.RelatedTableId.Value);
            TablesToMigrates.Add(table);
            table.IsMigrated = true;
        }

        StateHasChanged();
    }

    private void MergeSelectedTables()
    {
        if (TablesToMigrates.Count < 2)
        {
            _snackbar.Add("Select at least two tables to merge.", Severity.Warning);
            return;
        }

        var mergedTableIds = TablesToMigrates.Select(t => t.RelatedTableId ?? 0).ToList();



        foreach (var table in TablesToMigrates)
        {
            table.IsMigrated = true;
            table.MergedTableIds = new List<int>(mergedTableIds); 
        }

        _snackbar.Add("Tables merged successfully!", Severity.Success);
        CloseDialog();
        StateHasChanged();
    }

    private bool IsMergeDisabled => SelectedTableIds.Count < 2;

    private string GetTableClass(DineInOrderDetails table)
    {
        if (table == null || table.RelatedTableId == null)
            return "order-button";

        if (table.IsMigrated)
        {
            return "order-button merged";
        }

        return "order-button";
    }


    private void CloseDialog()
    {
        _commonProperties.DialogReference?.Close();
    }

}


<style>
    .merged {
        background-color: #ffcc00 !important;
        color: black !important;
        font-weight: bold;
    }

</style>