<MudStack Spacing="0" StretchItems="StretchItems.All" Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
    <MudButton Variant="Variant.Text"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Discount"
               Color="Color.Primary">
        خصم
    </MudButton>
    <MudButton Variant="Variant.Text"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.SetMeal"
               Color="Color.Primary">
        الوجبات
    </MudButton>
    <MudButton Variant="Variant.Text"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Alarm"
               Color="Color.Primary">
        الانتظار
    </MudButton>
    <MudButton Variant="Variant.Text"
               Size="Size.Large"
               OnClick="ToggleDrawer"
               StartIcon="@Icons.Material.Filled.Settings"
               Color="Color.Primary">
        اعدادات
    </MudButton>
</MudStack>

<SettingsDrawer @bind-Open="_drawerOpen">
    @* <MudText>Drawer Content Goes Here</MudText> *@
</SettingsDrawer>

@code {
    private bool _drawerOpen;
    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
