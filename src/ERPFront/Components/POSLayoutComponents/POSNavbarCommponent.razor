@inject CommonProperties _commonProperties

<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.Center">
    <img src="/images/Logo.png" alt="Logo" style="width: 40px; height: 40px;" />
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.TableRestaurant"
               Class="@( _commonProperties.CurrentPosMode == "Tables" ? "btn-success" : "button-color")"
               OnClick='() => SetMode("Tables")'>
        طاولات
    </MudButton>
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.DeliveryDining"
               Class="@( _commonProperties.CurrentPosMode == "Delivery" ? "btn-success" : "button-color")"
               OnClick='() => SetMode("Delivery")'>
        توصيل للمنازل
    </MudButton>
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.DirectionsRun"
               Class="@( _commonProperties.CurrentPosMode == "TakeAway" ? "btn-success" : "button-color")"
               OnClick='() => SetMode("TakeAway")'>
        تيك أواي
    </MudButton>

    <MudSpacer />

    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.AttachMoney"
               Class="button-color"
                >
        الحسابات
    </MudButton>
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.AreaChart"
               Class="button-color">
        ملخص
    </MudButton>
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.PushPin"
               Class="button-color">
        توزيع
    </MudButton>
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Checklist"
               Class="button-color">
        الطلبات
    </MudButton>
</MudStack>


@code {
    private void SetMode(string mode)
    {
        if (_commonProperties.CurrentPosMode != mode)
        {
            _commonProperties.CurrentPosMode = mode;
            InvokeAsync(StateHasChanged);
        }
    }
}

<style>
    .button-color {
        background-color: #114484 !important;
        color:white
    }

    .btn-success {
        background-color: #28a745; /* Green */
        color: white;
    }
</style>