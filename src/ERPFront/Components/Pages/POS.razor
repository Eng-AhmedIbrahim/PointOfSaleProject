@page "/pos"
@page "/"
@using MudBlazor
@using System.Globalization

@layout PosScreenLayout

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Style="padding:0">
    <MudGrid Spacing="0" Justify="Justify.Center">
        <!-- Section 1 -->
        <MudItem xs="2" Class="full-height">
            <MudText Typo="Typo.h6" Class="section-label">Section 1</MudText>
            <MudPaper Elevation="1" Height="93%" Class="overflow-y-auto overflow-x-hidden">
                <!-- Add content for Section 1 here -->
                <MudStack Spacing="0" Class="z-0 ma-n2">
                    @for (var i = 0; i < 30; i++)
                    {
                        var i1 = i;
                        <MudButton Variant="Variant.Filled"
                                   Class="mt-1"
                                   Style="@($"padding: {_spacing * 4}px; font-size: {_spacing * 4}px;")">
                            Item @i1.ToString()
                        </MudButton>
                    }
                </MudStack>
                @* <MudSlider Class="z-10 my-n2" *@
                @*            @bind-Value="_spacing" *@
                @*            Style="width: 450px; height: 16px;" *@
                @*            Vertical="true" *@
                @*            Min="4" *@
                @*            Max="10"> *@
                @*     Spacing: @_spacing.ToString(CultureInfo.InvariantCulture) *@
                @* </MudSlider> *@
            </MudPaper>
        </MudItem>

        <!-- Section 2 -->
        <MudItem xs="4">
            <MudPaper Elevation="1" Height="100%">
                <MudText Typo="Typo.h6" Class="section-label">Section 2</MudText>
                <!-- Add content for Section 2 here -->
            </MudPaper>
        </MudItem>

        <!-- Section 3 -->
        <MudItem xs="2">
            <MudPaper Elevation="1" Height="100%">
                <MudText Typo="Typo.h6" Class="section-label">Section 3</MudText>
                <!-- Add content for Section 3 here -->
                <MudSlider @bind-Value="_spacing"
                           Vertical="true"
                           Min="4"
                           Max="10">
                    Spacing: @_spacing.ToString(CultureInfo.InvariantCulture)
                </MudSlider>
            </MudPaper>
        </MudItem>

        <!-- Section 4 -->
        <MudItem xs="4">
            <MudPaper Elevation="1" Height="100%">
                <MudText Typo="Typo.h6" Class="section-label">Section 4</MudText>
                <!-- Add content for Section 4 here -->


            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private double _spacing = 4.0;
}


<style>

    .full-height {
        height: calc(100vh - 96px) !important;
    }


    .section-label {
        background-color: #022e66 !important;
        color: var(--mud-palette-primary-text);
        padding: 8px;
        text-align: center;
        font-size: 1rem;
        border-bottom: 1px solid var(--mud-palette-primary-light);
    }
</style>