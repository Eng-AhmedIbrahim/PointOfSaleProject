@page "/pos"
@using BlazorBase
@using ERPFront.Components.PosComponent
@layout PosScreenLayout
@inject IHttpClientFactory _clientFactory
@inject CommonProsperities  _commonProsperities
@inject IJSRuntime JS


<MudGrid Spacing="0" Justify="Justify.Center" Class="overflow-hidden">
    <!-- Section 1 -->
    <MudItem xs="2">
        <MudText Typo="Typo.h6" Class="section-label">Section 1</MudText>
        <MudPaper Elevation="1" Height="100%" Class="rounded-0 overflow-y-auto overflow-x-hidden full-height">
            <MudGrid Spacing="0">
                @foreach (var category in _categories ?? new List<CategoryToReturnDto>())
                {
                    <MudButton Variant="Variant.Filled"
                               FullWidth="true"
                               Style="@($"padding: {20}px; font-size: {20}px;")"
                               OnClick="()=>InvokeItems(category.Id)">
                        @category.ArabicName
                    </MudButton>
                }
            </MudGrid>
        </MudPaper>
    </MudItem>

    <!-- Section 2 -->

    <MudItem xs="4" Class="full-height">
        <MudText Typo="Typo.h6" Class="section-label">Sales Items</MudText>
        <MudPaper Elevation="1" Class="overflow-y-auto overflow-x-hidden section-height">
            <MudStack Row="true" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap" StretchItems="StretchItems.All" Spacing="0">
                @foreach (var item in _itemByCatId)
                {
                    <MudButton Size="Size.Large" Variant="Variant.Filled"
                               Class="same-width"
                               Style="@($"padding:{_commonProsperities._salesItemsHorizontalSider * 4}px;font-size:{_commonProsperities._salesItemsVerticalSlider * 4}px;width:{_commonProsperities._salesItemsHorizontalSider * 20}px;font-weight: bolder;")"
                               OnClick="@(() => AddItemToSection4(item))">
                        @item.ArabicName
                    </MudButton>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- Section 3 -->
    <MudItem xs="2">
        <MudText Typo="Typo.h6" Class="section-label">Section 3</MudText>
        <MudPaper Elevation="1" Height="100%" Class="rounded-0 overflow-y-auto overflow-x-hidden full-height">
            <Section3/>
        </MudPaper>
    </MudItem>

    <!-- Section 4 -->
    @* <MudItem xs="4"> *@
    @*     <MudText Typo="Typo.h6" Class="section-label">Section 4</MudText> *@
    @*     <MudPaper Elevation="1" Height="100%" Class="rounded-0 full-height overflow-y-auto overflow-x-hidden"> *@
    @*         <!-- Add content for Section 4 here --> *@
    @*         <MudPaper MaxHeight="65%" Class="rounded-0 overflow-y-auto"> *@
    @*             <Section4Table Items="_commonProsperities._tableItems" OnItemsChanged="OnSection4ItemsChanged" /> *@

    @*         </MudPaper> *@

    @*     </MudPaper> *@
    @* </MudItem> *@

    <MudItem xs="4">
        <MudText Typo="Typo.h6" Class="section-label">Section 4</MudText>
        <MudPaper Elevation="1" Height="100%" Class="rounded-0 full-height overflow-y-auto overflow-x-hidden">
            <!-- Add content for Section 4 here -->
            <MudPaper MaxHeight="65%" Class="rounded-0 overflow-y-auto">
                <Section4Table Items="_commonProsperities._tableItems" OnItemsChanged="OnSection4ItemsChanged" />
            </MudPaper>
        </MudPaper>
    </MudItem>
</MudGrid>



@code {
    private double _spacing = 4.0;

    private void HandleItemsFetched(ICollection<MenuSalesItemsToReturnDto> items)
    {
        _itemByCatId = items;
        StateHasChanged();
    }
}


<style>
    .full-height {
        height: calc(100vh - 90.25px - 41.59px) !important;
        max-height: calc(100vh - 90.25px - 41.59px) !important;
        box-sizing: border-box;
    }


    .section-label {
        background-color: #022e66 !important; /*var(--mud-palette-primary)*/ /*1366ce*/
        color: var(--mud-palette-primary-text);
        padding: 8px;
        text-align: center;
        font-size: 1rem;
        border-bottom: 1px solid var(--mud-palette-primary-light);
    }

    .same-width {
        width: 120px;
        min-width: 120px;
        text-align: center;
    }
</style>